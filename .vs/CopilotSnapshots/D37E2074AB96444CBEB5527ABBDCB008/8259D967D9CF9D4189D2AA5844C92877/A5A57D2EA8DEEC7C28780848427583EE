<Window x:Class="POSSystem.Windows.ReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Receipt" Height="580" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#ECF0F1"/>
            <Setter Property="Background" Value="#2C3E50"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#1A252F"/>
            <Setter Property="Padding" Value="4,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#34495E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50"
                Padding="20,16" Margin="0,0,0,0">
            <StackPanel>
                <Label Content="🧾  RECEIPT"
                       FontSize="22" FontWeight="Bold"
                       Foreground="White"
                       HorizontalContentAlignment="Center"
                       Padding="0"/>
                <Label x:Name="lblSaleInfo"
                       Content="Sale #"
                       FontSize="12" Foreground="#1ABC9C"
                       HorizontalContentAlignment="Center"
                       Padding="0"/>
            </StackPanel>
        </Border>

        <!-- Column Headers -->
        <Border Grid.Row="1" Background="#2C3E50"
                BorderBrush="#1A252F" BorderThickness="0,0,0,1"
                Padding="15,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="PRODUCT"
                       FontSize="10" Foreground="#BDC3C7"
                       FontWeight="Bold" Padding="0"/>
                <Label Grid.Column="1" Content="QTY"
                       FontSize="10" Foreground="#BDC3C7"
                       FontWeight="Bold" Padding="0"
                       HorizontalContentAlignment="Center"/>
                <Label Grid.Column="2" Content="TOTAL"
                       FontSize="10" Foreground="#BDC3C7"
                       FontWeight="Bold" Padding="0"
                       HorizontalContentAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Items List -->
        <ListView Grid.Row="2" x:Name="lvReceiptItems"
                  Background="#2C3E50"
                  BorderBrush="#1A252F"
                  BorderThickness="0,0,0,1"
                  Margin="0">
            <ListView.View>
                <GridView>
                    <GridView.ColumnHeaderContainerStyle>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </GridView.ColumnHeaderContainerStyle>
                    <GridViewColumn Width="170"
                                    DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Width="60"
                                    DisplayMemberBinding="{Binding Quantity}"/>
                    <GridViewColumn Width="100"
                                    DisplayMemberBinding="{Binding PriceDisplay}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Total -->
        <Border Grid.Row="3" Background="#2C3E50"
                BorderBrush="#1A252F" BorderThickness="0,0,0,1"
                Padding="15,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="TOTAL AMOUNT"
                       FontSize="13" FontWeight="Bold"
                       Foreground="#BDC3C7" Padding="0"
                       VerticalContentAlignment="Center"/>
                <Label Grid.Column="1"
                       x:Name="lblReceiptTotal"
                       Content="LBP 0"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#1ABC9C" Padding="0"/>
            </Grid>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="4" Background="#2C3E50" Padding="0">
            <StackPanel>
                <Label Content="Thank you for your purchase! 😊"
                       FontSize="12" Foreground="White"
                       HorizontalContentAlignment="Center"
                       Padding="10,8,10,4"/>
                <Grid Margin="15,4,15,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="🖨️  Print"
                            Height="40" Margin="0,0,5,0"
                            Background="#2E7D32"
                            Foreground="White"
                            FontSize="13" FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnPrintReceipt_Click"/>

                    <Button Grid.Column="1"
                            Content="📄  PDF"
                            Height="40" Margin="0,0,5,0"
                            Background="#0D47A1"
                            Foreground="White"
                            FontSize="13" FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnExportPdf_Click"/>

                    <Button Grid.Column="2"
                            Content="✕  Close"
                            Height="40"
                            Background="#B71C1C"
                            Foreground="White"
                            FontSize="13" FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnClose_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
