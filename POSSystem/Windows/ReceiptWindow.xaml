<Window x:Class="POSSystem.Windows.ReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Receipt" Height="620" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F3F3F3">

    <Window.Resources>

        <!-- Gradient brushes matching MainWindow -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- Shared action button style -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height"          Value="40"/>
            <Setter Property="FontFamily"      Value="Segoe UI, Tahoma"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="#1A1A1A"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1" Padding="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder"  Property="Background"  Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder"  Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#D4D4D4" Offset="0"/>
                                            <GradientStop Color="#E0E0E0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary (Print — blue accent) -->
        <Style x:Key="ActionBtnPrimary" TargetType="Button"
               BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#005A9E" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="#4488CC" BorderThickness="1"
                                    CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        CornerRadius="1" Padding="4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#2B84D8" Offset="0"/>
                                            <GradientStop Color="#0062B0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#3A94E8" Offset="0"/>
                                            <GradientStop Color="#1172C0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#004E8C" Offset="0"/>
                                            <GradientStop Color="#0062B0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger (Close — red) -->
        <Style x:Key="ActionBtnDanger" TargetType="Button"
               BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Foreground" Value="#B00000"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#880000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ListView item style — light theme -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground"       Value="#1A1A1A"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0,0,0,1"/>
            <Setter Property="BorderBrush"      Value="#E0E0E0"/>
            <Setter Property="Padding"          Value="4,6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBE9FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Background="#F3F3F3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Column headers -->
            <RowDefinition Height="*"/>      <!-- Items list -->
            <RowDefinition Height="Auto"/>   <!-- Totals -->
            <RowDefinition Height="Auto"/>   <!-- Footer + buttons -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <Label x:Name="lblHeaderTitle"
                           Content="🧾  RECEIPT"
                           FontFamily="Segoe UI, Tahoma"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#1A1A1A" Padding="0"/>
                    <Label x:Name="lblSaleInfo"
                           Content="Sale #"
                           FontFamily="Segoe UI, Tahoma"
                           FontSize="11" Foreground="#4466AA"
                           Padding="0"/>
                </StackPanel>

                <!-- DB status badge style from MainWindow -->
                <Border Grid.Column="1"
                        BorderBrush="#B8B8B8" BorderThickness="1"
                        CornerRadius="3" Padding="10,4"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#F8F8F8" Offset="0"/>
                            <GradientStop Color="#E8E8E8" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Label x:Name="lblStoreBadge"
                           Content="POS System"
                           FontFamily="Segoe UI, Tahoma"
                           FontSize="10" FontWeight="Bold"
                           Foreground="#555555" Padding="0"/>
                </Border>
            </Grid>
        </Border>

        <!-- ══ COLUMN HEADERS ══ -->
        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="0,0,0,1"
                Padding="14,7">
            <Border.Effect>
                <DropShadowEffect BlurRadius="3" ShadowDepth="1"
                                  Opacity="0.08" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="PRODUCT"
                       FontFamily="Segoe UI, Tahoma"
                       FontSize="9" FontWeight="Bold"
                       Foreground="#888888" Padding="0"/>
                <Label Grid.Column="1" Content="QTY"
                       FontFamily="Segoe UI, Tahoma"
                       FontSize="9" FontWeight="Bold"
                       Foreground="#888888" Padding="0"
                       HorizontalContentAlignment="Center"/>
                <Label Grid.Column="2" Content="TOTAL"
                       FontFamily="Segoe UI, Tahoma"
                       FontSize="9" FontWeight="Bold"
                       Foreground="#888888" Padding="0"
                       HorizontalContentAlignment="Right"/>
            </Grid>
        </Border>

        <!-- ══ ITEMS LIST ══ -->
        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1"
                                  Opacity="0.07" Color="#000000"/>
            </Border.Effect>
            <ListView x:Name="lvReceiptItems"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="#1A1A1A"
                      FontFamily="Segoe UI, Tahoma"
                      FontSize="12">
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Width="175"
                                        DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Width="60"
                                        DisplayMemberBinding="{Binding Quantity}"/>
                        <GridViewColumn Width="105"
                                        DisplayMemberBinding="{Binding PriceDisplay}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- ══ TOTALS CARD ══ -->
        <Border Grid.Row="3"
                Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="0,0,0,1"
                Padding="14,12" Margin="0,0,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1"
                                  Opacity="0.07" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <Label Content="TOTAL AMOUNT"
                           FontFamily="Segoe UI, Tahoma"
                           FontSize="9" FontWeight="Bold"
                           Foreground="#888888" Padding="0"/>
                    <Label x:Name="lblReceiptTotal"
                           Content="LBP 0"
                           FontFamily="Segoe UI, Tahoma"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#1A7A1A" Padding="0"/>
                </StackPanel>

                <!-- Payment summary pills -->
                <StackPanel Grid.Column="1"
                            Orientation="Vertical"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Label x:Name="lblPaymentMethod"
                           Content=""
                           FontFamily="Segoe UI, Tahoma"
                           FontSize="10" FontWeight="Bold"
                           Foreground="#4466AA"
                           HorizontalContentAlignment="Right"
                           Padding="0"/>
                    <Label x:Name="lblChangeDue"
                           Content=""
                           FontFamily="Segoe UI, Tahoma"
                           FontSize="10" Foreground="#5F5F5F"
                           HorizontalContentAlignment="Right"
                           Padding="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ FOOTER + BUTTONS ══ -->
        <Border Grid.Row="4"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,1,0,0"
                Padding="14,10">
            <StackPanel>
                <!-- Footer text from Settings -->
                <Label x:Name="lblFooter"
                       Content="Thank you for your purchase!"
                       FontFamily="Segoe UI, Tahoma"
                       FontSize="11" Foreground="#4466AA"
                       FontStyle="Italic"
                       HorizontalContentAlignment="Center"
                       Padding="0" Margin="0,0,0,10"/>

                <!-- Action buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource ActionBtnPrimary}"
                            Click="btnPrintReceipt_Click">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="🖨️" FontSize="13" Padding="0,0,4,0"
                                   VerticalContentAlignment="Center"/>
                            <Label Content="Print" FontFamily="Segoe UI, Tahoma"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="White" Padding="0"
                                   VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Style="{StaticResource ActionBtn}"
                            Click="btnExportPdf_Click">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="📄" FontSize="13" Padding="0,0,4,0"
                                   VerticalContentAlignment="Center"/>
                            <Label Content="PDF" FontFamily="Segoe UI, Tahoma"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="#1A1A1A" Padding="0"
                                   VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4"
                            Style="{StaticResource ActionBtnDanger}"
                            Click="btnClose_Click">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="✕" FontSize="13" Padding="0,0,4,0"
                                   VerticalContentAlignment="Center"
                                   Foreground="#B00000"/>
                            <Label Content="Close" FontFamily="Segoe UI, Tahoma"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="#B00000" Padding="0"
                                   VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </Grid>
            </StackPanel>
        </Border>

    </Grid>
</Window>
