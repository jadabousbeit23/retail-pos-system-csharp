<Window x:Class="POSSystem.Windows.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Color Picker"
        Width="400" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <Window.Resources>
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#B8B8B8"/>
            <Setter Property="Background" Value="{StaticResource BtnFace}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEF4FF"/>
                                <Setter Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Label Grid.Row="0" Content="🎨 Select Custom Color"
               FontSize="16" FontWeight="Bold"
               Foreground="#2B6CC4" Margin="0,0,0,12"
               FontFamily="Segoe UI, Tahoma"/>

        <!-- Color Wheel Canvas -->
        <Border Grid.Row="1" Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="1"
                Margin="0,0,0,12">
            <Canvas x:Name="colorCanvas" 
                    Width="350" Height="300"
                    Background="Transparent"
                    MouseMove="colorCanvas_MouseMove"
                    MouseLeftButtonDown="colorCanvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="colorCanvas_MouseLeftButtonUp">
                <!-- Color wheel drawn in code -->
                <Ellipse x:Name="colorWheel" 
                         Width="280" Height="280"
                         Canvas.Left="35" Canvas.Top="10"/>
                <Ellipse x:Name="brightnessOverlay"
                         Width="280" Height="280"
                         Canvas.Left="35" Canvas.Top="10"
                         Fill="Transparent"/>
                <!-- Selection indicator -->
                <Ellipse x:Name="selectionIndicator"
                         Width="12" Height="12"
                         Fill="White"
                         Stroke="Black"
                         StrokeThickness="2"
                         Canvas.Left="169" Canvas.Top="144"/>
            </Canvas>
        </Border>

        <!-- Current Color Preview -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Label Content="SELECTED COLOR" FontSize="10" 
                       Foreground="#555555" FontWeight="Bold"
                       FontFamily="Segoe UI, Tahoma"/>
                <TextBox x:Name="txtSelectedColor" 
                         Text="#4CAF50"
                         FontSize="14" FontFamily="Consolas"
                         Padding="8,6" Background="#FFFFFF"
                         BorderBrush="#99AABB" BorderThickness="1"/>
            </StackPanel>

            <Border Grid.Column="1" 
                    x:Name="previewBorder"
                    Background="#4CAF50"
                    CornerRadius="6"
                    Margin="12,20,0,0"
                    BorderBrush="#99AABB" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2"/>
                </Border.Effect>
            </Border>
        </Grid>

        <!-- Sliders -->
        <Grid Grid.Row="3" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                <Label Content="HUE" FontSize="9" Foreground="#888888" 
                       FontWeight="Bold" Padding="0"/>
                <Slider x:Name="sliderHue" Minimum="0" Maximum="360" 
                        ValueChanged="Slider_ValueChanged"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                <Label Content="SATURATION" FontSize="9" Foreground="#888888" 
                       FontWeight="Bold" Padding="0"/>
                <Slider x:Name="sliderSaturation" Minimum="0" Maximum="100" 
                        Value="70" ValueChanged="Slider_ValueChanged"/>
            </StackPanel>

            <StackPanel Grid.Row="2">
                <Label Content="BRIGHTNESS" FontSize="9" Foreground="#888888" 
                       FontWeight="Bold" Padding="0"/>
                <Slider x:Name="sliderBrightness" Minimum="20" Maximum="100" 
                        Value="50" ValueChanged="Slider_ValueChanged"/>
            </StackPanel>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="OK" Width="90" Height="36"
                    Margin="0,0,8,0" IsDefault="True"
                    Style="{StaticResource BigBtn}"
                    Click="btnOK_Click"/>
            <Button Content="Cancel" Width="90" Height="36"
                    IsCancel="True"
                    Style="{StaticResource BigBtn}"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>