<Window x:Class="POSSystem.Windows.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Payment"
        Height="720" Width="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <!--
    ═══════════════════════════════════════════════════════════
      CLASSIC WINDOWS LIGHT THEME
        Page bg       : #F0F0F0
        Surface       : #FAFAFA
        Button face   : #FDFDFD → #E8E8E8
        Button hover  : #EEF4FF → #D0DFFA
        Button press  : #D8D8D8 → #E4E4E4
        Bevel outer   : #B8B8B8
        Bevel hi      : #FFFFFF / shadow #A0A0A0
        Header        : soft sky-blue gradient
        Edit border   : #99AABB / inner #FFFFFF
        Text primary  : #1A1A1A
        Text muted    : #555555
        Text subtle   : #888888
        Accent blue   : #2B6CC4
        Green total   : #1A7A1A
        Amber disc    : #A0520A
        Red delete    : #B00000
    ═══════════════════════════════════════════════════════════
    -->

    <Window.Resources>

        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header — very soft sky blue -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush — top-left highlight / bottom-right shadow -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- Mode button styles -->
        <Style x:Key="ModeBtn" TargetType="Button">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource BtnFace}"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeBtnActive" TargetType="Button" BasedOn="{StaticResource ModeBtn}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#4A90D9" Offset="0"/>
                        <GradientStop Color="#2B6CC4" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Numpad key style -->
        <Style x:Key="NumKey" TargetType="Button">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#C0C0C0" BorderThickness="1"
                                CornerRadius="4">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="3">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="2" Padding="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Big action button style -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green confirm button -->
        <LinearGradientBrush x:Key="ConfirmFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E0F5E0" Offset="0"/>
            <GradientStop Color="#B0E0B0" Offset="0.5"/>
            <GradientStop Color="#88CC88" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ConfirmHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EAFAEA" Offset="0"/>
            <GradientStop Color="#C0EAC0" Offset="0.5"/>
            <GradientStop Color="#98DC98" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ConfirmPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#70B870" Offset="0"/>
            <GradientStop Color="#90CC90" Offset="1"/>
        </LinearGradientBrush>

    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Label Content="💳  Payment" FontSize="18" FontWeight="Bold"
                           Foreground="#1A1A1A" FontFamily="Segoe UI, Tahoma" Padding="0"/>
                    <Label x:Name="lblRateInfo" Content="Rate: LBP 90,000 = $1.00"
                           FontSize="11" Foreground="#555555" FontFamily="Segoe UI, Tahoma" Padding="0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Label Content="TOTAL DUE" FontSize="10" FontWeight="Bold"
                           Foreground="#888888" FontFamily="Segoe UI, Tahoma" Padding="0" HorizontalContentAlignment="Right"/>
                    <Label x:Name="lblTotalLBP" Content="LBP 0"
                           FontSize="22" FontWeight="Bold" Foreground="#1A1A1A" FontFamily="Segoe UI, Tahoma" Padding="0"/>
                    <Label x:Name="lblTotalUSD" Content="$0.00"
                           FontSize="14" Foreground="#2B6CC4" FontFamily="Segoe UI, Tahoma" Padding="0"
                           HorizontalContentAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MODE SELECTOR -->
        <Border Grid.Row="1" Background="#FAFAFA"
                BorderBrush="#D8D8D8" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="btnModeCashUSD"
                        Margin="0,0,6,0" Style="{StaticResource ModeBtnActive}"
                        Click="btnMode_Click">
                    <StackPanel>
                        <Label Content="💵" FontSize="18" Padding="0" HorizontalContentAlignment="Center"/>
                        <Label Content="Cash USD" FontSize="12" FontWeight="Normal" FontFamily="Segoe UI, Tahoma" Padding="0" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" x:Name="btnModeCashLBP"
                        Margin="0,0,6,0" Style="{StaticResource ModeBtn}"
                        Click="btnMode_Click">
                    <StackPanel>
                        <Label Content="💴" FontSize="18" Padding="0" HorizontalContentAlignment="Center"/>
                        <Label Content="Cash LBP" FontSize="12" FontWeight="Normal" FontFamily="Segoe UI, Tahoma" Padding="0" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" x:Name="btnModeCard"
                        Margin="0,0,6,0" Style="{StaticResource ModeBtn}"
                        Click="btnMode_Click">
                    <StackPanel>
                        <Label Content="💳" FontSize="18" Padding="0" HorizontalContentAlignment="Center"/>
                        <Label Content="Card" FontSize="12" FontWeight="Normal" FontFamily="Segoe UI, Tahoma" Padding="0" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" x:Name="btnModeMixed"
                        Style="{StaticResource ModeBtn}"
                        Click="btnMode_Click">
                    <StackPanel>
                        <Label Content="🔀" FontSize="18" Padding="0" HorizontalContentAlignment="Center"/>
                        <Label Content="Mixed" FontSize="12" FontWeight="Normal" FontFamily="Segoe UI, Tahoma" Padding="0" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="2" Margin="16,12,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="256"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: input panels -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Single-mode panel (Cash USD / Cash LBP / Card) -->
                <Border Grid.Row="0" x:Name="pnlSingle"
                        Background="#FAFAFA" BorderBrush="#C0C0C0"
                        BorderThickness="1" Padding="16,14" Margin="0,0,0,10">
                    <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Label x:Name="lblSingleTitle" Content="CASH PAID (USD)"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="#888888" FontFamily="Segoe UI, Tahoma" Padding="0" Margin="0,0,0,6"/>
                                <Border x:Name="bdSingleInput" BorderBrush="#2B6CC4"
                                        BorderThickness="1.5" Background="#FFFFFF" CornerRadius="0">
                                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <Label x:Name="lblSinglePrefix" Content="$"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="#2B6CC4" FontFamily="Segoe UI, Tahoma"
                                                   VerticalContentAlignment="Center"
                                                   Padding="10,0,4,0"/>
                                            <TextBox x:Name="txtSingleAmount"
                                                     Background="Transparent" Foreground="#2B6CC4"
                                                     BorderThickness="0" FontSize="26" FontWeight="Bold"
                                                     FontFamily="Segoe UI, Tahoma"
                                                     Padding="4,10" Text="0" MinWidth="200"
                                                     TextChanged="txtPayment_Changed"
                                                     GotFocus="txtInput_GotFocus"
                                                     PreviewKeyDown="txtInput_PreviewKeyDown"/>
                                        </StackPanel>
                                    </Border>
                                </Border>
                                <Label x:Name="lblSingleConvert" Content=""
                                       FontSize="12" Foreground="#555555" FontFamily="Segoe UI, Tahoma"
                                       Padding="0" Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- Change box -->
                            <Border Grid.Column="1" Background="#F0FFF0"
                                    BorderBrush="#70AA70" BorderThickness="1"
                                    CornerRadius="3" Padding="16,10"
                                    VerticalAlignment="Center" Margin="16,0,0,0"
                                    x:Name="pnlChange">
                                <StackPanel>
                                    <Label Content="CHANGE" FontSize="10" FontWeight="Bold"
                                           Foreground="#888888" FontFamily="Segoe UI, Tahoma" Padding="0"
                                           HorizontalContentAlignment="Center"/>
                                    <Label x:Name="lblChangeLine1"
                                           Content="$0.00" FontSize="20" FontWeight="Bold"
                                           Foreground="#1A7A1A" FontFamily="Segoe UI, Tahoma" Padding="0"
                                           HorizontalContentAlignment="Center"/>
                                    <Label x:Name="lblChangeLine2"
                                           Content="LBP 0" FontSize="13"
                                           Foreground="#555555" FontFamily="Segoe UI, Tahoma" Padding="0"
                                           HorizontalContentAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Border>

                <!-- Mixed panel -->
                <Border Grid.Row="0" x:Name="pnlMixed"
                        Background="#FAFAFA" BorderBrush="#C0C0C0"
                        BorderThickness="1" Padding="16,14" Margin="0,0,0,10"
                        Visibility="Collapsed">
                    <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1">
                        <StackPanel>
                            <Label Content="MIXED PAYMENT — enter amounts in any combination"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#888888" FontFamily="Segoe UI, Tahoma" Padding="0" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <Label Content="CASH (USD)" FontSize="10" FontWeight="Bold"
                                           Foreground="#888888" FontFamily="Segoe UI, Tahoma" Padding="0" Margin="0,0,0,4"/>
                                    <Border BorderBrush="#2B6CC4" BorderThickness="1"
                                            Background="#FFFFFF" CornerRadius="0">
                                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal">
                                                <Label Content="$" FontSize="16" FontWeight="Bold"
                                                       Foreground="#2B6CC4" FontFamily="Segoe UI, Tahoma"
                                                       VerticalContentAlignment="Center" Padding="6,0,2,0"/>
                                                <TextBox x:Name="txtMixedUSD"
                                                         Background="Transparent" Foreground="#2B6CC4"
                                                         BorderThickness="0" FontSize="18" FontWeight="Bold"
                                                         FontFamily="Segoe UI, Tahoma"
                                                         Padding="4,9" Text="0"
                                                         TextChanged="txtPayment_Changed"
                                                         GotFocus="txtInput_GotFocus"
                                                         PreviewKeyDown="txtInput_PreviewKeyDown"/>
                                            </StackPanel>
                                        </Border>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <Label Content="CASH (LBP)" FontSize="10" FontWeight="Bold"
                                           Foreground="#888888" FontFamily="Segoe UI, Tahoma" Padding="0" Margin="0,0,0,4"/>
                                    <Border BorderBrush="#A0520A" BorderThickness="1"
                                            Background="#FFFFFF" CornerRadius="0">
                                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                                            <TextBox x:Name="txtMixedLBP"
                                                     Background="Transparent" Foreground="#A0520A"
                                                     BorderThickness="0" FontSize="18" FontWeight="Bold"
                                                     FontFamily="Segoe UI, Tahoma"
                                                     Padding="8,9" Text="0"
                                                     TextChanged="txtPayment_Changed"
                                                     GotFocus="txtInput_GotFocus"
                                                     PreviewKeyDown="txtInput_PreviewKeyDown"/>
                                        </Border>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <Label Content="CARD (LBP)" FontSize="10" FontWeight="Bold"
                                           Foreground="#888888" FontFamily="Segoe UI, Tahoma" Padding="0" Margin="0,0,0,4"/>
                                    <Border BorderBrush="#555555" BorderThickness="1"
                                            Background="#FFFFFF" CornerRadius="0">
                                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                                            <TextBox x:Name="txtMixedCard"
                                                     Background="Transparent" Foreground="#555555"
                                                     BorderThickness="0" FontSize="18" FontWeight="Bold"
                                                     FontFamily="Segoe UI, Tahoma"
                                                     Padding="8,9" Text="0"
                                                     TextChanged="txtPayment_Changed"
                                                     GotFocus="txtInput_GotFocus"
                                                     PreviewKeyDown="txtInput_PreviewKeyDown"/>
                                        </Border>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Border Background="#F0F0F0" Margin="0,12,0,0"
                                    Padding="12,10" CornerRadius="0">
                                <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <Label Content="TOTAL PAID" FontSize="9" FontWeight="Bold"
                                                   Foreground="#888888" FontFamily="Segoe UI, Tahoma" Padding="0"/>
                                            <Label x:Name="lblMixedPaid"
                                                   Content="LBP 0" FontSize="14" FontWeight="Bold"
                                                   Foreground="#1A1A1A" FontFamily="Segoe UI, Tahoma" Padding="0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <Label Content="REMAINING" FontSize="9" FontWeight="Bold"
                                                   Foreground="#888888" FontFamily="Segoe UI, Tahoma" Padding="0"/>
                                            <Label x:Name="lblMixedRemaining"
                                                   Content="LBP 0" FontSize="14" FontWeight="Bold"
                                                   Foreground="#B00000" FontFamily="Segoe UI, Tahoma" Padding="0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <Label Content="CHANGE" FontSize="9" FontWeight="Bold"
                                                   Foreground="#888888" FontFamily="Segoe UI, Tahoma" Padding="0"/>
                                            <Label x:Name="lblMixedChange"
                                                   Content="LBP 0" FontSize="14" FontWeight="Bold"
                                                   Foreground="#1A7A1A" FontFamily="Segoe UI, Tahoma" Padding="0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Border>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Quick amounts -->
                <Border Grid.Row="1" Background="#FAFAFA"
                        BorderBrush="#C0C0C0" BorderThickness="1" Padding="14,12">
                    <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1">
                        <StackPanel>
                            <Label Content="QUICK AMOUNTS"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#888888" FontFamily="Segoe UI, Tahoma" Padding="0" Margin="0,0,0,8"/>
                            <WrapPanel x:Name="wpQuick"/>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>

            <!-- RIGHT: numpad -->
            <Border Grid.Column="1" Background="#FAFAFA"
                    BorderBrush="#C0C0C0" BorderThickness="1" Padding="10">
                <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="52"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Display -->
                        <Border Grid.Row="0" Background="#FFFFFF"
                                BorderBrush="#99AABB" BorderThickness="1"
                                CornerRadius="0" Margin="0,0,0,8">
                            <Border BorderBrush="#FFFFFF" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" x:Name="txtNumDisplay"
                                             Background="Transparent" Foreground="#2B6CC4"
                                             BorderThickness="0" FontSize="22" FontWeight="Bold"
                                             FontFamily="Segoe UI, Tahoma"
                                             Padding="10,0" IsReadOnly="True"
                                             TextAlignment="Right" VerticalContentAlignment="Center"/>
                                    <Label Grid.Column="1" x:Name="lblNumUnit"
                                           Content="USD" Foreground="#888888"
                                           FontSize="11" FontWeight="Bold"
                                           FontFamily="Segoe UI, Tahoma"
                                           VerticalContentAlignment="Center"
                                           Padding="0,0,8,0"/>
                                </Grid>
                            </Border>
                        </Border>

                        <!-- Keys -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Row="0" Grid.Column="0" Content="7" Style="{StaticResource NumKey}" Click="numKey_Click"/>
                            <Button Grid.Row="0" Grid.Column="1" Content="8" Style="{StaticResource NumKey}" Click="numKey_Click"/>
                            <Button Grid.Row="0" Grid.Column="2" Content="9" Style="{StaticResource NumKey}" Click="numKey_Click"/>
                            <Button Grid.Row="1" Grid.Column="0" Content="4" Style="{StaticResource NumKey}" Click="numKey_Click"/>
                            <Button Grid.Row="1" Grid.Column="1" Content="5" Style="{StaticResource NumKey}" Click="numKey_Click"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="6" Style="{StaticResource NumKey}" Click="numKey_Click"/>
                            <Button Grid.Row="2" Grid.Column="0" Content="1" Style="{StaticResource NumKey}" Click="numKey_Click"/>
                            <Button Grid.Row="2" Grid.Column="1" Content="2" Style="{StaticResource NumKey}" Click="numKey_Click"/>
                            <Button Grid.Row="2" Grid.Column="2" Content="3" Style="{StaticResource NumKey}" Click="numKey_Click"/>
                            <Button Grid.Row="3" Grid.Column="0" Content="." Style="{StaticResource NumKey}" Click="numKey_Click"/>
                            <Button Grid.Row="3" Grid.Column="1" Content="0" Style="{StaticResource NumKey}" Click="numKey_Click"/>
                            <Button Grid.Row="3" Grid.Column="2" Content="⌫"
                                    Foreground="#B00000"
                                    Style="{StaticResource NumKey}" Click="numBackspace_Click"/>
                        </Grid>

                        <!-- Apply + CLR -->
                        <Grid Grid.Row="2" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="✔ Apply"
                                    Height="36" Margin="0,0,4,0"
                                    Foreground="#1A1A1A"
                                    Style="{StaticResource BigBtn}" FontSize="12"
                                    Click="numApply_Click"/>
                            <Button Grid.Column="1" Content="CLR"
                                    Height="36" Margin="4,0,0,0"
                                    Foreground="#555555"
                                    Style="{StaticResource BigBtn}" FontSize="12"
                                    Click="numClear_Click"/>
                        </Grid>
                    </Grid>
                </Border>
            </Border>
        </Grid>

        <!-- CONFIRM / CANCEL -->
        <Grid Grid.Row="3" Margin="16,12,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" x:Name="lblError"
                   Content="" FontSize="12" FontWeight="Bold"
                   Foreground="#B00000" FontFamily="Segoe UI, Tahoma" 
                   VerticalContentAlignment="Center" Padding="0"/>
            <Button Grid.Column="1" Content="✕  Cancel"
                    Height="46" Padding="24,0" Margin="0,0,8,0"
                    Foreground="#1A1A1A"
                    Style="{StaticResource BigBtn}" FontSize="14"
                    Click="btnCancel_Click"/>
            <Button Grid.Column="2" Content="✅  CONFIRM PAYMENT"
                    Height="46" Padding="32,0"
                    Foreground="#1A3A1A" FontSize="15" FontWeight="Bold"
                    FontFamily="Segoe UI, Tahoma" Cursor="Hand"
                    Click="btnConfirm_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#70AA70" BorderThickness="1" CornerRadius="4">
                            <Border x:Name="InnerBorder" BorderThickness="1" CornerRadius="3">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#C8F0C8" Offset="0"/>
                                        <GradientStop Color="#C8F0C8" Offset="0.49"/>
                                        <GradientStop Color="#508050" Offset="0.50"/>
                                        <GradientStop Color="#508050" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border x:Name="FaceBorder" CornerRadius="2" Padding="4"
                                        Background="{StaticResource ConfirmFace}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource ConfirmHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource ConfirmPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#508050" Offset="0"/>
                                            <GradientStop Color="#508050" Offset="0.49"/>
                                            <GradientStop Color="#C8F0C8" Offset="0.50"/>
                                            <GradientStop Color="#C8F0C8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>