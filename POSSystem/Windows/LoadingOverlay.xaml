<UserControl x:Class="POSSystem.Controls.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="Auto" 
             Visibility="Collapsed">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BackdropBrush" Color="#F0F0F0" Opacity="0.85"/>

        <LinearGradientBrush x:Key="ProgressBarBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8E8E8" Offset="0"/>
            <GradientStop Color="#D0D0D0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ProgressBarFill" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#2B6CC4" Offset="0.5"/>
            <GradientStop Color="#1A5A9E" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackdropBrush}">
        <Border Width="320" Height="120" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                Background="#FAFAFA"
                BorderBrush="#B8B8B8" 
                BorderThickness="1"
                CornerRadius="4">

            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="4" Opacity="0.15" Color="#000000"/>
            </Border.Effect>

            <Border BorderBrush="#FFFFFF" BorderThickness="1" CornerRadius="3">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="lblMessage" 
                               Text="Processing..." 
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="14" 
                               FontWeight="SemiBold"
                               Foreground="#1A1A1A"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <Border Grid.Row="1" 
                            Height="24" 
                            Background="{StaticResource ProgressBarBackground}"
                            BorderBrush="#99AABB" 
                            BorderThickness="1"
                            CornerRadius="2">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1" CornerRadius="1">
                            <ProgressBar x:Name="progressBar" 
                                         IsIndeterminate="True"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{StaticResource ProgressBarFill}"/>
                        </Border>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>