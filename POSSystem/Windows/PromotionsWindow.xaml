<Window x:Class="POSSystem.Windows.PromotionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Promotions &amp; Discounts"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <!--
    ═══════════════════════════════════════════════════════════
      CLASSIC WINDOWS LIGHT THEME  — matches FastSalesWindow
        Page bg       : #F0F0F0
        Surface       : #FAFAFA
        Button face   : #FDFDFD → #E8E8E8
        Button hover  : #EEF4FF → #D0DFFA
        Header        : soft sky-blue gradient
        Edit border   : #99AABB / inner #FFFFFF
        Text primary  : #1A1A1A
        Text muted    : #555555
        Accent blue   : #2B6CC4
        Green         : #1A7A1A
        Red delete    : #B00000
    ═══════════════════════════════════════════════════════════
    -->

    <Window.Resources>

        <!-- Field label style -->
        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
        </Style>

        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header — soft sky blue -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Column header -->
        <LinearGradientBrush x:Key="ColHeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F8F8F8" Offset="0"/>
            <GradientStop Color="#E4E4E4" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Raised 3-D bevel button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Save button — blue accent -->
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#2B6CC4" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#4A90D9" Offset="0"/>
                                            <GradientStop Color="#2B6CC4" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#5AA0E9" Offset="0"/>
                                            <GradientStop Color="#3B7CD4" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#1B5CB4" Offset="0"/>
                                            <GradientStop Color="#2B6CC4" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Delete button — red -->
        <Style x:Key="DeleteBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#B00000"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0A0A0"/>
            <Setter Property="Background" Value="#FDF2F2"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Background="{TemplateBinding Background}">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="#FCE8E8"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#C42B1C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="#F5D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle button style -->
        <Style x:Key="ToggleBtnStyle" TargetType="ToggleButton">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="OuterBorder"
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="OuterBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListView rows -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                    <Setter Property="Foreground" Value="#1A3A8A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                    <Setter Property="Foreground" Value="#0A2060"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- GridViewColumnHeader -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{StaticResource ColHeaderBrush}"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- Input border style -->
        <Style x:Key="InputBorder" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#99AABB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Input text style -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="#2B6CC4"/>
        </Style>

        <!-- FIX: ComboBox style with solid background and clear dropdown -->
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,6"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="Foreground" Value="#1A1A1A"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#EEF4FF"/>
                                <Setter Property="Foreground" Value="#1A3A8A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#C8DBFA"/>
                                <Setter Property="Foreground" Value="#0A2060"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Form -->
            <RowDefinition Height="*"/>
            <!-- List -->
            <RowDefinition Height="44"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Title badge -->
                <Border Grid.Column="0"
                        BorderBrush="#B8B8B8" BorderThickness="1"
                        CornerRadius="3" Margin="10,9,0,9">
                    <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1" CornerRadius="2">
                        <Border CornerRadius="1" Padding="16,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#4A90D9" Offset="0"/>
                                    <GradientStop Color="#2B6CC4" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label Content="🏷️  PROMOTIONS"
                                   Foreground="White"
                                   FontFamily="Segoe UI, Tahoma" FontSize="14" FontWeight="Bold"
                                   VerticalContentAlignment="Center"/>
                        </Border>
                    </Border>
                </Border>

                <Label Grid.Column="1"
                       Content="Configure discounts and special offers"
                       Foreground="#4466AA" FontFamily="Segoe UI, Tahoma" FontSize="12"
                       VerticalContentAlignment="Center" Margin="16,0,0,0"/>
            </Grid>
        </Border>

        <!-- ══ FORM ══ -->
        <Border Grid.Row="1"
                Background="#FAFAFA"
                BorderBrush="#C0C0C0" BorderThickness="1"
                Margin="10,10,10,0" Padding="14,12">
            <StackPanel>
                <Label Content="CREATE NEW PROMOTION"
                       FontSize="10" FontWeight="Bold"
                       Foreground="#8A8A8A" Padding="0" Margin="0,0,0,10"/>

                <!-- Row 1 -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <!-- Name -->
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <Label Content="PROMOTION NAME" 
                               Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox x:Name="txtPromoName" Style="{StaticResource InputBox}"/>
                        </Border>
                    </StackPanel>

                    <!-- Type -->
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <Label Content="TYPE" 
                               Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <ComboBox x:Name="cmbPromoType" Style="{StaticResource ComboStyle}"
                                      SelectionChanged="cmbPromoType_Changed"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="% Discount"/>
                                <ComboBoxItem Content="Fixed Amount Off"/>
                                <ComboBoxItem Content="Buy X Get Y Free"/>
                            </ComboBox>
                        </Border>
                    </StackPanel>

                    <!-- Value -->
                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                        <Label x:Name="lblValueLabel" Content="DISCOUNT %" 
                               Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox x:Name="txtPromoValue" Style="{StaticResource InputBox}" Text="10"/>
                        </Border>
                    </StackPanel>

                    <!-- Min Qty -->
                    <StackPanel Grid.Column="3" Margin="0,0,8,0">
                        <Label x:Name="lblMinQtyLabel" Content="MIN QTY TO BUY"
                               Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox x:Name="txtMinQty" Style="{StaticResource InputBox}" Text="2"/>
                        </Border>
                    </StackPanel>

                    <!-- Free Qty -->
                    <StackPanel Grid.Column="4">
                        <Label x:Name="lblFreeQtyLabel" Content="FREE QTY"
                               Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox x:Name="txtFreeQty" Style="{StaticResource InputBox}" Text="1"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Row 2 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Applies To -->
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <Label Content="APPLIES TO"
                               Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <ComboBox x:Name="cmbAppliesTo" Style="{StaticResource ComboStyle}"
                                      SelectedIndex="0"
                                      SelectionChanged="cmbAppliesTo_Changed">
                                <ComboBoxItem Content="All Products"/>
                                <ComboBoxItem Content="Category"/>
                                <ComboBoxItem Content="Specific Product"/>
                            </ComboBox>
                        </Border>
                    </StackPanel>

                    <!-- Applies To Value -->
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <Label x:Name="lblAppliesToValue"
                               Content="CATEGORY / PRODUCT NAME"
                               Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox x:Name="txtAppliesToValue" 
                                     Style="{StaticResource InputBox}"
                                     IsEnabled="False"/>
                        </Border>
                    </StackPanel>

                    <!-- Start Date -->
                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                        <Label Content="START DATE"
                               Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox x:Name="txtStartDate" 
                                     Style="{StaticResource InputBox}"
                                     ToolTip="dd/MM/yyyy (leave blank = always)"/>
                        </Border>
                    </StackPanel>

                    <!-- End Date -->
                    <StackPanel Grid.Column="3" Margin="0,0,8,0">
                        <Label Content="END DATE"
                               Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox x:Name="txtEndDate" 
                                     Style="{StaticResource InputBox}"
                                     ToolTip="dd/MM/yyyy (leave blank = no expiry)"/>
                        </Border>
                    </StackPanel>

                    <!-- Save button -->
                    <Button Grid.Column="4"
                            Content="➕ Save"
                            Height="34" Padding="16,0" Margin="0,18,6,0"
                            Style="{StaticResource SaveBtn}"
                            Click="btnSavePromo_Click"/>

                    <!-- Message -->
                    <Label Grid.Column="5" x:Name="lblMessage"
                           Content="" FontSize="12" FontWeight="SemiBold"
                           Foreground="#107C10" VerticalContentAlignment="Center"
                           Padding="0" Margin="0,18,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ══ LIST ══ -->
        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="1"
                Margin="10,10,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- List header -->
                <Border Grid.Row="0" Background="{StaticResource ColHeaderBrush}"
                        BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="12,8">
                    <Label Content="Active &amp; Scheduled Promotions"
                           FontSize="13" FontWeight="Bold"
                           Foreground="#1A1A1A" Padding="0"/>
                </Border>

                <ListView Grid.Row="1" x:Name="lvPromos"
                          Background="Transparent" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="ID"           Width="50"  DisplayMemberBinding="{Binding Id}"/>
                            <GridViewColumn Header="Name"         Width="180" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Type"         Width="130" DisplayMemberBinding="{Binding Type}"/>
                            <GridViewColumn Header="Value"        Width="110" DisplayMemberBinding="{Binding ValueDisplay}"/>
                            <GridViewColumn Header="Applies To"   Width="120" DisplayMemberBinding="{Binding AppliesTo}"/>
                            <GridViewColumn Header="Target"       Width="140" DisplayMemberBinding="{Binding AppliesToValue}"/>
                            <GridViewColumn Header="Start"        Width="90"  DisplayMemberBinding="{Binding StartDate}"/>
                            <GridViewColumn Header="End"          Width="90"  DisplayMemberBinding="{Binding EndDate}"/>
                            <GridViewColumn Header="Active"       Width="70">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ToggleButton IsChecked="{Binding IsActive, Mode=OneWay}"
                                                      Content="{Binding ActiveLabel}"
                                                      Width="60" Height="24"
                                                      Background="{Binding ActiveColor}"
                                                      Foreground="White"
                                                      FontSize="10" FontWeight="SemiBold"
                                                      BorderThickness="1" BorderBrush="#FFFFFF"
                                                      Tag="{Binding Id}"
                                                      Style="{StaticResource ToggleBtnStyle}"
                                                      Click="btnToggle_Click"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header=""             Width="50">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕"
                                                Width="32" Height="22"
                                                Style="{StaticResource DeleteBtn}"
                                                Tag="{Binding Id}"
                                                Click="btnDeletePromo_Click"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- ══ FOOTER ══ -->
        <Border Grid.Row="3" Background="#F0F0F0"
                BorderBrush="#D0D0D0" BorderThickness="0,1,0,0"
                Padding="10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0"
                       Content="💡 Active promotions are automatically applied in Fast Sale and Grid Sale"
                       Foreground="#555555" FontSize="11"
                       VerticalContentAlignment="Center" Padding="0"/>

                <Button Grid.Column="1" Content="✕  Close"
                        Height="34" Padding="20,0"
                        Style="{StaticResource BigBtn}"
                        Click="btnClose_Click"/>
            </Grid>
        </Border>

    </Grid>

</Window>