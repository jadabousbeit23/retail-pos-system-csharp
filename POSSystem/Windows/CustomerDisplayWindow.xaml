<Window x:Class="POSSystem.Windows.CustomerDisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Display"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        ShowInTaskbar="False"
        Background="#F0F0F0">

    <Grid x:Name="rootGrid" Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                Padding="30,16"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Label x:Name="lblStoreName"
                           Content="🛒  POS SYSTEM"
                           FontSize="32" FontWeight="Bold"
                           Foreground="#2B6CC4" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label Content="Thank you for shopping with us!"
                           FontSize="14"
                           Foreground="#555555" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Label x:Name="lblDate"
                           Content=""
                           FontSize="16" FontWeight="Bold"
                           Foreground="#555555" Padding="0"
                           HorizontalContentAlignment="Right"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblTime"
                           Content=""
                           FontSize="26" FontWeight="Bold"
                           Foreground="#2B6CC4" Padding="0"
                           HorizontalContentAlignment="Right"
                           FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->

        <!-- IDLE SCREEN -->
        <Grid x:Name="pnlIdle" Grid.Row="1"
              Visibility="Visible">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Label Content="🛍️"
                       FontSize="100"
                       HorizontalContentAlignment="Center"
                       Padding="0" Margin="0,0,0,20"/>
                <Label Content="Welcome!"
                       FontSize="52" FontWeight="Bold"
                       Foreground="#2B6CC4"
                       HorizontalContentAlignment="Center"
                       Padding="0"
                       FontFamily="Segoe UI, Tahoma"/>
                <Label Content="Please wait while we prepare your order"
                       FontSize="20"
                       Foreground="#555555"
                       HorizontalContentAlignment="Center"
                       Padding="0" Margin="0,10,0,0"
                       FontFamily="Segoe UI, Tahoma"/>
            </StackPanel>
        </Grid>

        <!-- CART SCREEN -->
        <Grid x:Name="pnlCart" Grid.Row="1"
              Visibility="Collapsed"
              Margin="30,20,30,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- Cart items -->
            <Border Grid.Column="0"
                    Background="#FFFFFF"
                    BorderBrush="#C0C0C0" BorderThickness="1"
                    Margin="0,0,16,0"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- List header -->
                    <Border Grid.Row="0"
                            Background="{StaticResource HeaderBrush}"
                            BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                            Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="ITEM"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#2B6CC4"
                                   Padding="0"
                                   FontFamily="Segoe UI, Tahoma"/>
                            <Label Grid.Column="1"
                                   Content="QTY"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#2B6CC4"
                                   Padding="0"
                                   HorizontalContentAlignment="Center"
                                   FontFamily="Segoe UI, Tahoma"/>
                            <Label Grid.Column="2"
                                   Content="PRICE"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#2B6CC4"
                                   Padding="0"
                                   HorizontalContentAlignment="Center"
                                   FontFamily="Segoe UI, Tahoma"/>
                            <Label Grid.Column="3"
                                   Content="TOTAL"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#2B6CC4"
                                   Padding="0"
                                   HorizontalContentAlignment="Right"
                                   FontFamily="Segoe UI, Tahoma"/>
                        </Grid>
                    </Border>

                    <ItemsControl Grid.Row="1"
                                  x:Name="icCartItems"
                                  Margin="0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="20,10"
                                        BorderBrush="#EBEBEB"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0"
                                               Content="{Binding ProductName}"
                                               FontSize="18"
                                               Foreground="#1A1A1A"
                                               Padding="0"
                                               FontFamily="Segoe UI, Tahoma"/>
                                        <Label Grid.Column="1"
                                               Content="{Binding Quantity}"
                                               FontSize="18"
                                               Foreground="#2E7D32"
                                               Padding="0"
                                               HorizontalContentAlignment="Center"
                                               FontFamily="Segoe UI, Tahoma"/>
                                        <Label Grid.Column="2"
                                               Content="{Binding UnitPriceText}"
                                               FontSize="18"
                                               Foreground="#2E7D32"
                                               Padding="0"
                                               HorizontalContentAlignment="Center"
                                               FontFamily="Segoe UI, Tahoma"/>
                                        <Label Grid.Column="3"
                                               Content="{Binding TotalPriceText}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#2E7D32"
                                               Padding="0"
                                               HorizontalContentAlignment="Right"
                                               FontFamily="Segoe UI, Tahoma"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- Totals panel -->
            <Border Grid.Column="1"
                    Background="#FFFFFF"
                    BorderBrush="#C0C0C0" BorderThickness="1"
                    Padding="24">
                <StackPanel VerticalAlignment="Center">

                    <Label Content="ORDER SUMMARY"
                           FontSize="16" FontWeight="Bold"
                           Foreground="#2B6CC4"
                           HorizontalContentAlignment="Center"
                           Padding="0" Margin="0,0,0,20"
                           FontFamily="Segoe UI, Tahoma"/>

                    <!-- Subtotal -->
                    <Border Background="#FAFAFA"
                            BorderBrush="#D0D0D0" BorderThickness="1"
                            Padding="16,12"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="Subtotal"
                                   FontSize="18"
                                   Foreground="#555555"
                                   Padding="0"
                                   FontFamily="Segoe UI, Tahoma"/>
                            <Label Grid.Column="1"
                                   x:Name="lblSubtotal"
                                   Content="$0.00"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1A1A1A"
                                   Padding="0"
                                   FontFamily="Segoe UI, Tahoma"/>
                        </Grid>
                    </Border>

                    <!-- Discount -->
                    <Border x:Name="pnlDiscount"
                            Background="#FFF5F5"
                            BorderBrush="#FFB8B8" BorderThickness="1"
                            Padding="16,12"
                            Margin="0,0,0,10"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Content="🏷️ Discount"
                                   FontSize="18"
                                   Foreground="#B71C1C"
                                   Padding="0"
                                   FontFamily="Segoe UI, Tahoma"/>
                            <Label Grid.Column="1"
                                   x:Name="lblDiscount"
                                   Content="-$0.00"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#B71C1C"
                                   Padding="0"
                                   FontFamily="Segoe UI, Tahoma"/>
                        </Grid>
                    </Border>

                    <!-- Total -->
                    <Border Background="#2E7D32"
                            BorderBrush="#1B5E20" BorderThickness="1"
                            Padding="16,18"
                            Margin="0,10,0,0">
                        <StackPanel>
                            <Label Content="TOTAL"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"
                                   HorizontalContentAlignment="Center"
                                   Padding="0"
                                   FontFamily="Segoe UI, Tahoma"/>
                            <Label x:Name="lblTotal"
                                   Content="$0.00"
                                   FontSize="46"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalContentAlignment="Center"
                                   Padding="0"
                                   FontFamily="Segoe UI, Tahoma"/>
                        </StackPanel>
                    </Border>

                    <!-- Item count -->
                    <Label x:Name="lblItemCount"
                           Content="0 items"
                           FontSize="14"
                           Foreground="#555555"
                           HorizontalContentAlignment="Center"
                           Padding="0" Margin="0,16,0,0"
                           FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- THANK YOU SCREEN -->
        <Grid x:Name="pnlThankYou" Grid.Row="1"
              Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Label Content="✅"
                       FontSize="100"
                       HorizontalContentAlignment="Center"
                       Padding="0" Margin="0,0,0,10"/>
                <Label Content="Thank You!"
                       FontSize="64" FontWeight="Bold"
                       Foreground="#2B6CC4"
                       HorizontalContentAlignment="Center"
                       Padding="0"
                       FontFamily="Segoe UI, Tahoma"/>
                <Label Content="Sale Complete"
                       FontSize="28"
                       Foreground="#555555"
                       HorizontalContentAlignment="Center"
                       Padding="0" Margin="0,10,0,20"
                       FontFamily="Segoe UI, Tahoma"/>
                <Border Background="#2E7D32"
                        BorderBrush="#1B5E20" BorderThickness="1"
                        Padding="40,20">
                    <StackPanel>
                        <Label Content="AMOUNT PAID"
                               FontSize="18"
                               Foreground="#FFFFFF"
                               HorizontalContentAlignment="Center"
                               Padding="0"
                               FontFamily="Segoe UI, Tahoma"/>
                        <Label x:Name="lblThankYouTotal"
                               Content="$0.00"
                               FontSize="56"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalContentAlignment="Center"
                               Padding="0"
                               FontFamily="Segoe UI, Tahoma"/>
                    </StackPanel>
                </Border>
                <Label Content="Please come again! 😊"
                       FontSize="22"
                       Foreground="#2B6CC4"
                       HorizontalContentAlignment="Center"
                       Padding="0" Margin="0,24,0,0"
                       FontFamily="Segoe UI, Tahoma"/>
            </StackPanel>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="#E0E0E0"
                Padding="30,10"
                BorderBrush="#C0C0C0" BorderThickness="0,1,0,0">
            <Label Content="🔒  Secure POS System  |  All transactions are recorded"
                   FontSize="13" Foreground="#555555"
                   HorizontalContentAlignment="Center"
                   Padding="0"
                   FontFamily="Segoe UI, Tahoma"/>
        </Border>
    </Grid>
</Window>