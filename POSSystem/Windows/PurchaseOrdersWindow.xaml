<Window x:Class="POSSystem.Windows.PurchaseOrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Purchase Orders"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>
        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- ListView rows -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 3D Bevel Button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="15,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="#B8B8B8" BorderThickness="1"
                        CornerRadius="3" Margin="10,9,8,9">
                    <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1" CornerRadius="2">
                        <Border CornerRadius="1" Padding="16,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#4A90D9" Offset="0"/>
                                    <GradientStop Color="#2B6CC4" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label Content="📦  Purchase Orders"
                                   Foreground="White"
                                   FontFamily="Segoe UI, Tahoma" FontSize="14" FontWeight="Bold"
                                   VerticalContentAlignment="Center"/>
                        </Border>
                    </Border>
                </Border>

                <Button Grid.Column="1"
                        Content="👥  Suppliers"
                        Width="120" Height="34"
                        Margin="4,10,0,10"
                        Style="{StaticResource BigBtn}"
                        Click="btnSuppliers_Click"/>
                <Button Grid.Column="2"
                        Content="➕  New Order"
                        Width="120" Height="34"
                        Margin="4,10,0,10"
                        Style="{StaticResource BigBtn}"
                        Click="btnNewOrder_Click"/>
                <Button Grid.Column="3"
                        Content="📄  Export PDF"
                        Width="120" Height="34"
                        Margin="4,10,0,10"
                        Style="{StaticResource BigBtn}"
                        Click="btnExportPdf_Click"/>
                <Button Grid.Column="4"
                        Content="✕  Close"
                        Width="90" Height="34"
                        Style="{StaticResource BigBtn}"
                        Click="btnClose_Click"/>
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0"
                       Content="🔍 Search:"
                       Foreground="#555555" FontWeight="Bold"
                       FontSize="12"
                       VerticalContentAlignment="Center"
                       Padding="0" Margin="0,0,8,0"
                       FontFamily="Segoe UI, Tahoma"/>

                <Border Grid.Column="1"
                        BorderBrush="#99AABB" BorderThickness="1"
                        Background="#FFFFFF" Margin="0,0,12,0">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <TextBox x:Name="txtSearch"
                                 Background="Transparent"
                                 Foreground="#1A1A1A"
                                 BorderThickness="0"
                                 FontSize="12" Padding="8,5"
                                 CaretBrush="#2B6CC4"
                                 TextChanged="txtSearch_TextChanged"
                                 FontFamily="Segoe UI, Tahoma"/>
                    </Border>
                </Border>

                <Label Grid.Column="2"
                       x:Name="lblOrderCount"
                       Content="📋  Orders"
                       Foreground="#2B6CC4" FontWeight="Bold"
                       FontSize="12"
                       VerticalContentAlignment="Center"
                       Padding="0"
                       FontFamily="Segoe UI, Tahoma"/>

                <Button Grid.Column="3"
                        Content="⏳ Pending"
                        Width="90" Height="30"
                        Margin="0,0,6,0"
                        Style="{StaticResource BigBtn}"
                        Click="btnFilterPending_Click"/>
                <Button Grid.Column="4"
                        Content="✅ Received"
                        Width="90" Height="30"
                        Margin="0,0,6,0"
                        Style="{StaticResource BigBtn}"
                        Click="btnFilterReceived_Click"/>
                <Button Grid.Column="5"
                        Content="❌ Cancelled"
                        Width="90" Height="30"
                        Margin="0,0,6,0"
                        Style="{StaticResource BigBtn}"
                        Click="btnFilterCancelled_Click"/>
                <Button Grid.Column="6"
                        Content="🔄 All"
                        Width="70" Height="30"
                        Style="{StaticResource BigBtn}"
                        Click="btnFilterAll_Click"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="12,12,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Orders list -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FFFFFF"
                        BorderBrush="#C0C0C0" BorderThickness="1">
                    <ListView x:Name="lvOrders"
                              Background="Transparent"
                              BorderThickness="0"
                              FontFamily="Segoe UI, Tahoma"
                              Margin="4"
                              SelectionChanged="lvOrders_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridView.ColumnHeaderContainerStyle>
                                    <Style TargetType="GridViewColumnHeader">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Style>
                                </GridView.ColumnHeaderContainerStyle>
                                <GridViewColumn Width="50"
                                    DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Width="150"
                                    DisplayMemberBinding="{Binding SupplierName}"/>
                                <GridViewColumn Width="100"
                                    DisplayMemberBinding="{Binding OrderDate}"/>
                                <GridViewColumn Width="55"
                                    DisplayMemberBinding="{Binding ItemCount}"/>
                                <GridViewColumn Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding StatusColor}"
                                                    CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="White"
                                                           FontSize="10"
                                                           FontWeight="Bold"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Width="150"
                                    DisplayMemberBinding="{Binding Notes}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <!-- Action buttons -->
                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="✅ Mark Received"
                            Height="38" Margin="0,0,5,0"
                            Style="{StaticResource BigBtn}"
                            Click="btnMarkReceived_Click"/>
                    <Button Grid.Column="1"
                            Content="❌ Cancel Order"
                            Height="38" Margin="0,0,5,0"
                            Style="{StaticResource BigBtn}"
                            Click="btnCancelOrder_Click"/>
                    <Button Grid.Column="2"
                            Content="🗑️ Delete"
                            Height="38"
                            Style="{StaticResource BigBtn}"
                            Click="btnDeleteOrder_Click"/>
                </Grid>
            </Grid>

            <!-- Order Detail Panel -->
            <Border Grid.Column="1" Background="#FAFAFA"
                    BorderBrush="#D0D0D0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Detail header -->
                    <Border Grid.Row="0" Background="#2B6CC4" Padding="12,8">
                        <Label Content="ORDER DETAILS"
                               Foreground="White" FontSize="13"
                               FontWeight="Bold" Padding="0"
                               FontFamily="Segoe UI, Tahoma"/>
                    </Border>

                    <!-- Order info -->
                    <Border Grid.Row="1" Background="#FFFFFF"
                            BorderBrush="#99AABB" BorderThickness="0,0,0,1"
                            Padding="12,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="Supplier:"
                                       Foreground="#2B6CC4" FontSize="11"
                                       FontWeight="Bold" Padding="0"
                                       FontFamily="Segoe UI, Tahoma"/>
                                <Label Grid.Column="1"
                                       x:Name="lblDetailSupplier"
                                       Content="—"
                                       Foreground="#1A1A1A" FontSize="11"
                                       FontWeight="Bold" Padding="0"
                                       FontFamily="Segoe UI, Tahoma"/>
                            </Grid>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="Order Date:"
                                       Foreground="#555555" FontSize="11"
                                       FontWeight="Bold" Padding="0"
                                       FontFamily="Segoe UI, Tahoma"/>
                                <Label Grid.Column="1"
                                       x:Name="lblDetailDate"
                                       Content="—"
                                       Foreground="#1A1A1A" FontSize="11"
                                       FontWeight="Bold" Padding="0"
                                       FontFamily="Segoe UI, Tahoma"/>
                            </Grid>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="Status:"
                                       Foreground="#555555" FontSize="11"
                                       FontWeight="Bold" Padding="0"
                                       FontFamily="Segoe UI, Tahoma"/>
                                <Label Grid.Column="1"
                                       x:Name="lblDetailStatus"
                                       Content="—"
                                       Foreground="#2B6CC4" FontSize="11"
                                       FontWeight="Bold" Padding="0"
                                       FontFamily="Segoe UI, Tahoma"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="Notes:"
                                       Foreground="#555555" FontSize="11"
                                       FontWeight="Bold" Padding="0"
                                       FontFamily="Segoe UI, Tahoma"/>
                                <Label Grid.Column="1"
                                       x:Name="lblDetailNotes"
                                       Content="—"
                                       Foreground="#1A1A1A" FontSize="11"
                                       FontWeight="Bold" Padding="0"
                                       FontFamily="Segoe UI, Tahoma"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Order items -->
                    <ListView Grid.Row="2" x:Name="lvOrderItems"
                              Background="Transparent"
                              BorderThickness="0"
                              FontFamily="Segoe UI, Tahoma"
                              Margin="4">
                        <ListView.View>
                            <GridView>
                                <GridView.ColumnHeaderContainerStyle>
                                    <Style TargetType="GridViewColumnHeader">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Style>
                                </GridView.ColumnHeaderContainerStyle>
                                <GridViewColumn Width="120"
                                    DisplayMemberBinding="{Binding ProductName}"/>
                                <GridViewColumn Width="45"
                                    DisplayMemberBinding="{Binding Quantity}"/>
                                <GridViewColumn Width="65"
                                    DisplayMemberBinding="{Binding UnitCostText}"/>
                                <GridViewColumn Width="70"
                                    DisplayMemberBinding="{Binding TotalCostText}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Order total -->
                    <Border Grid.Row="3" Background="#F4F4F4"
                            BorderBrush="#D0D0D0" BorderThickness="0,1,0,0"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="ORDER TOTAL"
                                   Foreground="#2B6CC4" FontSize="13"
                                   FontWeight="Bold" Padding="0"
                                   FontFamily="Segoe UI, Tahoma"/>
                            <Label Grid.Column="1"
                                   x:Name="lblOrderTotal"
                                   Content="LBP 0"
                                   Foreground="#1A1A1A" FontSize="18"
                                   FontWeight="Bold" Padding="0"
                                   FontFamily="Segoe UI, Tahoma"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>