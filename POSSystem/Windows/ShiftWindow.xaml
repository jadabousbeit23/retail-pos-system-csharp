<Window x:Class="POSSystem.Windows.ShiftWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shift Management"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <!--
    ═══════════════════════════════════════════════════════════
      CLASSIC WINDOWS LIGHT THEME  — softer, airier palette
        Page bg       : #F0F0F0  (standard Win dialog gray)
        Surface       : #FAFAFA
        Button face   : #FDFDFD → #E8E8E8
        Button hover  : #EEF4FF → #D0DFFA
        Button press  : #D8D8D8 → #E4E4E4
        Bevel outer   : #B8B8B8
        Bevel hi      : #FFFFFF / shadow #A0A0A0
        Header        : soft sky-blue gradient
        Edit border   : #99AABB / inner #FFFFFF
        Text primary  : #1A1A1A
        Text muted    : #555555
        Text subtle   : #888888
        Accent blue   : #2B6CC4
        Green total   : #1A7A1A
        Amber disc    : #A0520A
        Red error     : #B00000
    ═══════════════════════════════════════════════════════════
    -->

    <Window.Resources>

        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header — very soft sky blue -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Panel surface -->
        <LinearGradientBrush x:Key="PanelBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FAFAFA" Offset="0"/>
            <GradientStop Color="#F0F0F0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush — top-left highlight / bottom-right shadow -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- Open button — soft green -->
        <LinearGradientBrush x:Key="OpenFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E0F5E0" Offset="0"/>
            <GradientStop Color="#B0E0B0" Offset="0.5"/>
            <GradientStop Color="#88CC88" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="OpenHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EAFAEA" Offset="0"/>
            <GradientStop Color="#C0EAC0" Offset="0.5"/>
            <GradientStop Color="#98DC98" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="OpenPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#70B870" Offset="0"/>
            <GradientStop Color="#90CC90" Offset="1"/>
        </LinearGradientBrush>

        <!-- Close button — soft red -->
        <LinearGradientBrush x:Key="CloseFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F5E0E0" Offset="0"/>
            <GradientStop Color="#E0B0B0" Offset="0.5"/>
            <GradientStop Color="#CC8888" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CloseHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FAEAEA" Offset="0"/>
            <GradientStop Color="#EAC0C0" Offset="0.5"/>
            <GradientStop Color="#DC9898" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ClosePress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#B87070" Offset="0"/>
            <GradientStop Color="#CC9090" Offset="1"/>
        </LinearGradientBrush>

        <!-- ListView rows -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,7"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                    <Setter Property="Foreground" Value="#1A3A8A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                    <Setter Property="Foreground" Value="#0A2060"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- ── Raised 3-D bevel button ── -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Open Shift button — green accent -->
        <Style x:Key="OpenBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A3A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#70AA70" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource OpenFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource OpenHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource OpenPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Shift button — red accent -->
        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#3A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#AA7070" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource CloseFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource CloseHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource ClosePress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
            <RowDefinition Height="Auto"/>
            <!-- Action panels -->
            <RowDefinition Height="*"/>
            <!-- History -->
            <RowDefinition Height="Auto"/>
            <!-- Close -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Label Content="🕐  Shift Management"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#2B6CC4" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label Content="Track cashier shifts, starting cash and end-of-shift reconciliation"
                           FontSize="11" Foreground="#555555" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>
                <Border Grid.Column="1" x:Name="bdShiftStatus"
                        Background="#FFF0F0" BorderBrush="#E0B0B0"
                        BorderThickness="1" CornerRadius="3"
                        Padding="14,6" VerticalAlignment="Center">
                    <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1" CornerRadius="2">
                        <Label x:Name="lblShiftStatus"
                               Content="No Active Shift"
                               FontSize="13" FontWeight="Bold"
                               Foreground="#B00000" Padding="4,0"
                               FontFamily="Segoe UI, Tahoma"/>
                    </Border>
                </Border>
            </Grid>
        </Border>

        <!-- ══ CURRENT SHIFT INFO ══ -->
        <Border Grid.Row="1" x:Name="pnlActiveShift"
                Background="#EEF4FF" BorderBrush="#2B6CC4"
                BorderThickness="0,0,0,2"
                Padding="16,10" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,32,0">
                    <Label Content="CASHIER" FontSize="9" Foreground="#555555"
                           FontWeight="Bold" Padding="0" FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblActiveUser" Content="—"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#1A1A1A" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,32,0">
                    <Label Content="OPENED AT" FontSize="9" Foreground="#555555"
                           FontWeight="Bold" Padding="0" FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblActiveOpenedAt" Content="—"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#1A1A1A" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,32,0">
                    <Label Content="STARTING CASH" FontSize="9" Foreground="#555555"
                           FontWeight="Bold" Padding="0" FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblActiveStartCash" Content="—"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#1A7A1A" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <Label Content="SALES THIS SHIFT" FontSize="9" Foreground="#555555"
                           FontWeight="Bold" Padding="0" FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblActiveSales" Content="—"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#2B6CC4" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ ACTION PANELS ══ -->
        <Grid Grid.Row="2" Margin="16,12,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- OPEN SHIFT -->
            <Border Grid.Column="0" Background="#FAFAFA"
                    BorderBrush="#C0C0C0" BorderThickness="1"
                    Margin="0,0,8,0" Padding="16,14">
                <StackPanel>
                    <Label Content="▶  Open New Shift"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#1A7A1A" Padding="0" Margin="0,0,0,10"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label Content="STARTING CASH (LBP)"
                           FontSize="10" FontWeight="Bold"
                           Foreground="#555555" Padding="0" Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1"
                            Background="#FFFFFF" Margin="0,0,0,10">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtStartingCash"
                                     Background="Transparent" Foreground="#1A1A1A"
                                     BorderThickness="0" FontSize="18" FontWeight="SemiBold"
                                     Padding="10,8" Text="0"
                                     HorizontalContentAlignment="Right"
                                     FontFamily="Segoe UI, Tahoma"
                                     CaretBrush="#2B6CC4"/>
                        </Border>
                    </Border>
                    <Label Content="NOTES (optional)"
                           FontSize="10" FontWeight="Bold"
                           Foreground="#555555" Padding="0" Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1"
                            Background="#FFFFFF" Margin="0,0,0,10">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtOpenNotes"
                                     Background="Transparent" Foreground="#1A1A1A"
                                     BorderThickness="0" FontSize="12"
                                     Padding="8,7"
                                     FontFamily="Segoe UI, Tahoma"
                                     CaretBrush="#2B6CC4"/>
                        </Border>
                    </Border>
                    <Button Content="▶  Open Shift"
                            Height="40"
                            Style="{StaticResource OpenBtn}"
                            Click="btnOpenShift_Click"/>
                </StackPanel>
            </Border>

            <!-- CLOSE SHIFT -->
            <Border Grid.Column="1" Background="#FAFAFA"
                    BorderBrush="#C0C0C0" BorderThickness="1"
                    Margin="0,0,8,0" Padding="16,14">
                <StackPanel>
                    <Label Content="⏹  Close Current Shift"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#B00000" Padding="0" Margin="0,0,0,10"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label Content="COUNTED CASH (LBP)"
                           FontSize="10" FontWeight="Bold"
                           Foreground="#555555" Padding="0" Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1"
                            Background="#FFFFFF" Margin="0,0,0,6">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtCountedCash"
                                     Background="Transparent" Foreground="#1A1A1A"
                                     BorderThickness="0" FontSize="18" FontWeight="SemiBold"
                                     Padding="10,8" Text="0"
                                     HorizontalContentAlignment="Right"
                                     TextChanged="txtCountedCash_Changed"
                                     FontFamily="Segoe UI, Tahoma"
                                     CaretBrush="#2B6CC4"/>
                        </Border>
                    </Border>
                    <!-- Live difference preview -->
                    <Border Background="{StaticResource PanelBrush}" Padding="10,6" Margin="0,0,0,10"
                            BorderBrush="#D0D0D0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="DIFFERENCE:" FontSize="11"
                                   FontWeight="Bold" Foreground="#555555" Padding="0"
                                   FontFamily="Segoe UI, Tahoma"/>
                            <Label Grid.Column="1" x:Name="lblDiffPreview"
                                   Content="LBP 0" FontSize="14" FontWeight="Bold"
                                   Foreground="#555555" Padding="0"
                                   FontFamily="Segoe UI, Tahoma"/>
                        </Grid>
                    </Border>
                    <Button Content="⏹  Close Shift"
                            Height="40"
                            Style="{StaticResource CloseBtn}"
                            Click="btnCloseShift_Click"/>
                </StackPanel>
            </Border>

            <!-- SUMMARY CARD -->
            <Border Grid.Column="2" Background="#FAFAFA"
                    BorderBrush="#C0C0C0" BorderThickness="1"
                    Padding="16,14">
                <StackPanel>
                    <Label Content="📊  Today's Summary"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#1A1A1A" Padding="0" Margin="0,0,0,12"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Total Sales:" Foreground="#555555" FontSize="12" Padding="0"
                               FontFamily="Segoe UI, Tahoma"/>
                        <Label Grid.Column="1" x:Name="lblSummaryCount"
                               Content="0" FontSize="13" FontWeight="SemiBold"
                               Foreground="#2B6CC4" Padding="0"
                               FontFamily="Segoe UI, Tahoma"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Total Revenue:" Foreground="#555555" FontSize="12" Padding="0"
                               FontFamily="Segoe UI, Tahoma"/>
                        <Label Grid.Column="1" x:Name="lblSummaryRevenue"
                               Content="LBP 0" FontSize="13" FontWeight="SemiBold"
                               Foreground="#1A7A1A" Padding="0"
                               FontFamily="Segoe UI, Tahoma"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Cash Sales:" Foreground="#555555" FontSize="12" Padding="0"
                               FontFamily="Segoe UI, Tahoma"/>
                        <Label Grid.Column="1" x:Name="lblSummaryCash"
                               Content="LBP 0" FontSize="13" FontWeight="SemiBold"
                               Foreground="#1A1A1A" Padding="0"
                               FontFamily="Segoe UI, Tahoma"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Card Sales:" Foreground="#555555" FontSize="12" Padding="0"
                               FontFamily="Segoe UI, Tahoma"/>
                        <!-- X-Report Button -->
                        <Button Content="📋  Print X-Report (Current Shift)"
                                Height="36" Margin="25,25,0,0"
                                Style="{StaticResource BigBtn}"
                                Click="btnXReport_Click"/>
                        <Label Grid.Column="1" x:Name="lblSummaryCard"
                               Content="LBP 0" FontSize="13" FontWeight="SemiBold"
                               Foreground="#1A1A1A" Padding="0"
                               FontFamily="Segoe UI, Tahoma"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ SHIFT HISTORY ══ -->
        <Border Grid.Row="3" Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="1"
                Margin="16,12,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                        BorderBrush="#D0D0D0" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <Label Content="Shift History"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#1A1A1A" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </Border>
                <ListView Grid.Row="1" x:Name="lvShifts"
                          Background="#FFFFFF"
                          BorderThickness="0"
                          FontFamily="Segoe UI, Tahoma">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="ID"           Width="50"  DisplayMemberBinding="{Binding Id}"/>
                            <GridViewColumn Header="Cashier"      Width="120" DisplayMemberBinding="{Binding OpenedBy}"/>
                            <GridViewColumn Header="Opened"       Width="140" DisplayMemberBinding="{Binding OpenedAt}"/>
                            <GridViewColumn Header="Closed"       Width="140" DisplayMemberBinding="{Binding ClosedAt}"/>
                            <GridViewColumn Header="Start Cash"   Width="110" DisplayMemberBinding="{Binding StartCashDisplay}"/>
                            <GridViewColumn Header="Expected"     Width="120" DisplayMemberBinding="{Binding ExpectedDisplay}"/>
                            <GridViewColumn Header="Counted"      Width="120" DisplayMemberBinding="{Binding CountedDisplay}"/>
                            <GridViewColumn Header="Difference"   Width="110">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DiffDisplay}"
                                                   Foreground="{Binding DiffColor}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   FontFamily="Segoe UI, Tahoma"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Sales"        Width="60"  DisplayMemberBinding="{Binding TotalSales}"/>
                            <GridViewColumn Header="Revenue"      Width="120" DisplayMemberBinding="{Binding RevenueDisplay}"/>
                            <GridViewColumn Header="Status"       Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusColor}"
                                                CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="{Binding Status}"
                                                       Foreground="White" FontSize="10"
                                                       FontWeight="SemiBold"
                                                       FontFamily="Segoe UI, Tahoma"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- ══ FOOTER ══ -->
        <Border Grid.Row="4" Background="{StaticResource PanelBrush}"
