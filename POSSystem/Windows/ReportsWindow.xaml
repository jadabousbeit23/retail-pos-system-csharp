<Window x:Class="POSSystem.Windows.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Reports" Height="750" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>
        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- ListView rows -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 3D Bevel Button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="20,15" Margin="20,20,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="📊  Reports"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#2B6CC4" Padding="0"
                       FontFamily="Segoe UI, Tahoma"/>
                <Button Grid.Column="1" Content="📄  Export PDF"
                        Width="130" Height="36" Margin="0,0,8,0"
                        Style="{StaticResource BigBtn}"
                        Click="btnExportPdf_Click"/>
                <Button Grid.Column="2" Content="📊  Export Excel"
                        Width="140" Height="36" Margin="0,0,8,0"
                        Style="{StaticResource BigBtn}"
                        Click="btnExportExcel_Click"/>
                <Button Grid.Column="3" Content="📋  Z-Report"
                        Width="130" Height="36" Margin="0,0,8,0"
                        Style="{StaticResource BigBtn}"
                        Click="btnZReport_Click"/>
                <Button Grid.Column="4" Content="🔒  Close Day"
                        Width="130" Height="36"
                        Style="{StaticResource BigBtn}"
                        Click="btnCloseDay_Click"/>
            </Grid>
        </Border>

        <!-- Tab Buttons -->
        <Border Grid.Row="1" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1"
                Padding="10" Margin="20,0,20,12">
            <WrapPanel>
                <Button x:Name="btnTabDaily" Content="📅  Daily"
                        Width="130" Height="36" Margin="0,0,8,0"
                        Style="{StaticResource BigBtn}"
                        Click="btnTabDaily_Click"/>
                <Button x:Name="btnTabMonthly" Content="📆  Monthly"
                        Width="130" Height="36" Margin="0,0,8,0"
                        Style="{StaticResource BigBtn}"
                        Click="btnTabMonthly_Click"/>
                <Button x:Name="btnTabYearly" Content="📈  Yearly"
                        Width="130" Height="36"
                        Style="{StaticResource BigBtn}"
                        Click="btnTabYearly_Click"/>
            </WrapPanel>
        </Border>

        <!-- Stats Cards -->
        <Grid Grid.Row="2" Margin="20,0,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FAFAFA"
                    BorderBrush="#D0D0D0" BorderThickness="1"
                    Padding="15" Margin="0,0,6,0">
                <StackPanel>
                    <Label x:Name="lblPeriodLabel" Content="TODAY'S SALES"
                           FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblTotalSales" Content="0"
                           FontSize="28" FontWeight="Bold"
                           Foreground="#1A1A1A" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#FAFAFA"
                    BorderBrush="#D0D0D0" BorderThickness="1"
                    Padding="15" Margin="6,0,6,0">
                <StackPanel>
                    <Label x:Name="lblRevLabel" Content="TODAY'S REVENUE"
                           FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblTotalRevenue" Content="$0.00"
                           FontSize="28" FontWeight="Bold"
                           Foreground="#1A1A1A" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#FAFAFA"
                    BorderBrush="#D0D0D0" BorderThickness="1"
                    Padding="15" Margin="6,0,0,0">
                <StackPanel>
                    <Label Content="PERIOD" FontSize="10"
                           Foreground="#555555" FontWeight="Bold" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblPeriod" Content="Today"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#1A1A1A" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Search + List -->
        <Border Grid.Row="3" Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="1"
                Margin="20,0,20,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <Border Grid.Row="0" Background="#F4F4F4"
                        BorderBrush="#D0D0D0" BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <Grid x:Name="pnlSearch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BorderBrush="#99AABB" BorderThickness="1"
                                Margin="0,0,6,0">
                            <Border BorderBrush="#FFFFFF" BorderThickness="1">
                                <TextBox x:Name="txtDateSearch" Background="#FFFFFF"
                                         Foreground="#1A1A1A" BorderThickness="0"
                                         FontSize="13" Padding="8,6"
                                         CaretBrush="#2B6CC4"
                                         FontFamily="Segoe UI, Tahoma"/>
                            </Border>
                        </Border>
                        <Button Grid.Column="1" Content="Search"
                                Height="34" Margin="0,0,6,0"
                                Style="{StaticResource BigBtn}"
                                Click="btnDateSearch_Click"/>
                        <Button Grid.Column="2" Content="All"
                                Height="34" Margin="0,0,6,0"
                                Style="{StaticResource BigBtn}"
                                Click="btnShowAll_Click"/>
                        <Button Grid.Column="3" Content="📋  Load Report"
                                Height="34"
                                Style="{StaticResource BigBtn}"
                                Click="btnLoadReport_Click"/>
                    </Grid>
                </Border>

                <ListView Grid.Row="1" x:Name="lvSales"
                          Background="#FFFFFF" Foreground="#1A1A1A"
                          BorderThickness="0" FontFamily="Segoe UI, Tahoma"
                          Margin="4"
                          SelectionChanged="lvSales_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridView.ColumnHeaderContainerStyle>
                                <Style TargetType="GridViewColumnHeader">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </GridView.ColumnHeaderContainerStyle>
                            <GridViewColumn x:Name="colId" Width="55"
                                            DisplayMemberBinding="{Binding Id}"/>
                            <GridViewColumn x:Name="colDate" Width="200"
                                            DisplayMemberBinding="{Binding Date}"/>
                            <GridViewColumn x:Name="colAmount" Width="150"
                                            DisplayMemberBinding="{Binding TotalAmount}"/>
                            <GridViewColumn x:Name="colExtra" Width="200"
                                            DisplayMemberBinding="{Binding Extra}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- Footer -->
        <Label Grid.Row="4"
               Content="💡 Daily: click sale to view receipt  |  Z-Report: End of day summary  |  Close Day archives today's data  |  Export Excel exports current tab + full history + inventory"
               Foreground="#888888" FontSize="11"
               Margin="20,0,20,10"
               FontFamily="Segoe UI, Tahoma"/>
    </Grid>
</Window>