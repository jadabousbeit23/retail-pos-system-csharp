<Window x:Class="POSSystem.Windows.StockAdjustmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stock Adjustment"
        Height="680" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <!--
    ═══════════════════════════════════════════════════════════
      CLASSIC WINDOWS LIGHT THEME  — softer, airier palette
        Page bg       : #F0F0F0  (standard Win dialog gray)
        Surface       : #FAFAFA
        Button face   : #FDFDFD → #E8E8E8
        Button hover  : #EEF4FF → #D0DFFA
        Button press  : #D8D8D8 → #E4E4E4
        Bevel outer   : #B8B8B8
        Bevel hi      : #FFFFFF / shadow #A0A0A0
        Header        : soft sky-blue gradient
        Edit border   : #99AABB / inner #FFFFFF
        Text primary  : #1A1A1A
        Text muted    : #555555
        Text subtle   : #888888
        Accent blue   : #2B6CC4
        Green success : #1A7A1A
        Amber warning : #A0520A
        Red error     : #B00000
    ═══════════════════════════════════════════════════════════
    -->

    <Window.Resources>

        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header — very soft sky blue -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Panel surface -->
        <LinearGradientBrush x:Key="PanelBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FAFAFA" Offset="0"/>
            <GradientStop Color="#F0F0F0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush — top-left highlight / bottom-right shadow -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- Apply button — soft purple accent -->
        <LinearGradientBrush x:Key="ApplyFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8E0F0" Offset="0"/>
            <GradientStop Color="#C8B8E0" Offset="0.5"/>
            <GradientStop Color="#A890D0" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ApplyHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F0E8F8" Offset="0"/>
            <GradientStop Color="#D8C8F0" Offset="0.5"/>
            <GradientStop Color="#B8A0E0" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ApplyPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#9878C0" Offset="0"/>
            <GradientStop Color="#B090D0" Offset="1"/>
        </LinearGradientBrush>

        <!-- ListView rows -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                    <Setter Property="Foreground" Value="#1A3A8A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                    <Setter Property="Foreground" Value="#0A2060"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Raised 3-D bevel button ── -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Apply button style — purple accent -->
        <Style x:Key="ApplyBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#4A3060"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#A080C0" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource ApplyFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource ApplyHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource ApplyPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- FIX: ComboBox style with solid white background and clear dropdown -->
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,6"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="Foreground" Value="#1A1A1A"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#EEF4FF"/>
                                <Setter Property="Foreground" Value="#1A3A8A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#C8DBFA"/>
                                <Setter Property="Foreground" Value="#0A2060"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ ROW 0 — HEADER ══ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="16,12"
                Margin="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <Label Content="⚙️  Stock Adjustment"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#2B6CC4" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblProductName"
                           Content="Product: —"
                           FontSize="12" Foreground="#555555"
                           Padding="0" FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>
                <!-- Current Stock badge -->
                <Border Grid.Column="1"
                        BorderBrush="#B8B8B8" BorderThickness="1"
                        CornerRadius="3" Padding="14,8">
                    <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1" CornerRadius="2">
                        <Border CornerRadius="1" Background="#F8F8F8">
                            <StackPanel HorizontalAlignment="Center">
                                <Label Content="CURRENT STOCK"
                                       FontSize="10" Foreground="#555555"
                                       FontWeight="Bold" Padding="0"
                                       HorizontalContentAlignment="Center"
                                       FontFamily="Segoe UI, Tahoma"/>
                                <Label x:Name="lblCurrentStock"
                                       Content="0"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="#1A7A1A" Padding="0"
                                       HorizontalContentAlignment="Center"
                                       FontFamily="Segoe UI, Tahoma"/>
                            </StackPanel>
                        </Border>
                    </Border>
                </Border>
            </Grid>
        </Border>

        <!-- ══ ROW 1 — ADJUSTMENT FORM ══ -->
        <Border Grid.Row="1" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Type: Add or Remove -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <Label Content="TYPE"
                           FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0"
                           Margin="0,0,0,4" FontFamily="Segoe UI, Tahoma"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="rbAdd"
                                     Content="  ➕ Add"
                                     GroupName="adjType"
                                     IsChecked="True"
                                     Foreground="#1A7A1A"
                                     FontWeight="Bold" FontSize="13"
                                     Margin="0,0,16,0"
                                     VerticalContentAlignment="Center"
                                     FontFamily="Segoe UI, Tahoma"/>
                        <RadioButton x:Name="rbRemove"
                                     Content="  ➖ Remove"
                                     GroupName="adjType"
                                     Foreground="#B00000"
                                     FontWeight="Bold" FontSize="13"
                                     VerticalContentAlignment="Center"
                                     FontFamily="Segoe UI, Tahoma"/>
                    </StackPanel>
                </StackPanel>

                <!-- Quantity -->
                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <Label Content="QUANTITY"
                           FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0"
                           Margin="0,0,0,4" FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtAdjQty"
                                     Background="#FFFFFF"
                                     Foreground="#2B6CC4"
                                     BorderThickness="0"
                                     FontSize="14" FontWeight="Bold"
                                     Padding="8,6"
                                     CaretBrush="#2B6CC4"
                                     FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                    </Border>
                </StackPanel>

                <!-- Reason dropdown -->
                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <Label Content="REASON"
                           FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0"
                           Margin="0,0,0,4" FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <ComboBox x:Name="cmbReason"
                                      Style="{StaticResource ComboStyle}"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Damaged"/>
                                <ComboBoxItem Content="Expired"/>
                                <ComboBoxItem Content="Recount / Correction"/>
                                <ComboBoxItem Content="Return to Supplier"/>
                                <ComboBoxItem Content="Customer Return"/>
                                <ComboBoxItem Content="Theft / Loss"/>
                                <ComboBoxItem Content="Manual Addition"/>
                                <ComboBoxItem Content="Other"/>
                            </ComboBox>
                        </Border>
                    </Border>
                </StackPanel>

                <!-- Apply Button -->
                <Button Grid.Column="3"
                        Content="✔ Apply"
                        Height="36" Padding="16,0"
                        Style="{StaticResource ApplyBtn}"
                        VerticalAlignment="Bottom"
                        Click="btnApply_Click"/>
            </Grid>
        </Border>

        <!-- ══ ROW 2 — NOTES ══ -->
        <Border Grid.Row="2" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel>
                <Label Content="ADDITIONAL NOTES (optional)"
                       FontSize="10" Foreground="#555555"
                       FontWeight="Bold" Padding="0"
                       Margin="0,0,0,4" FontFamily="Segoe UI, Tahoma"/>
                <Border BorderBrush="#99AABB" BorderThickness="1">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <TextBox x:Name="txtNotes"
                                 Background="#FFFFFF"
                                 Foreground="#1A1A1A"
                                 BorderThickness="0"
                                 FontSize="12" Padding="8,6"
                                 CaretBrush="#2B6CC4"
                                 FontFamily="Segoe UI, Tahoma"/>
                    </Border>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══ ROW 3 — HISTORY LIST ══ -->
        <Border Grid.Row="3" Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="1"
                Margin="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- List header -->
                <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                        BorderBrush="#D0D0D0" BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <Label Content="📋  ADJUSTMENT HISTORY (this product)"
                           Foreground="#555555" FontSize="11"
                           FontWeight="Bold" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </Border>
                <ListView Grid.Row="1" x:Name="lvHistory"
                          Background="#FFFFFF"
                          BorderThickness="0"
                          FontFamily="Segoe UI, Tahoma"
                          Margin="4">
                    <ListView.View>
                        <GridView>
                            <GridView.ColumnHeaderContainerStyle>
                                <Style TargetType="GridViewColumnHeader">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </GridView.ColumnHeaderContainerStyle>
                            <GridViewColumn Width="130" DisplayMemberBinding="{Binding AdjustedAt}"/>
                            <GridViewColumn Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding ChangeColor}"
                                                CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="{Binding ChangeDisplay}"
                                                       Foreground="White"
                                                       FontWeight="Bold" FontSize="11"
                                                       FontFamily="Segoe UI, Tahoma"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="80"  DisplayMemberBinding="{Binding NewStock}"/>
                            <GridViewColumn Width="150" DisplayMemberBinding="{Binding Reason}"/>
                            <GridViewColumn Width="100" DisplayMemberBinding="{Binding AdjustedBy}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- ══ ROW 4 — MESSAGE ══ -->
        <Label Grid.Row="4" x:Name="lblMessage"
               Content="" FontSize="12" FontWeight="Bold"
               Padding="16,4" Margin="0" MinHeight="18"
               FontFamily="Segoe UI, Tahoma"/>

        <!-- ══ ROW 5 — CLOSE BUTTON ══ -->
        <Border Grid.Row="5" Background="{StaticResource PanelBrush}"
                BorderBrush="#D0D0D0" BorderThickness="0,1,0,0"
                Padding="16,12">
            <Button Content="✕  Close"
                    Height="40"
                    Background="Transparent"
                    Foreground="#555555"
                    FontWeight="Bold" FontSize="13"
                    BorderThickness="0" Cursor="Hand"
                    Style="{StaticResource BigBtn}"
                    HorizontalAlignment="Stretch"
                    Click="btnClose_Click"/>
        </Border>
    </Grid>
</Window>