<Window x:Class="POSSystem.Windows.ExcelExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export to Excel" Height="520" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <Window.Resources>
        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- 3D Bevel Button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="16,14" Margin="0,0,0,0">
            <StackPanel>
                <Label Content="📊  Export to Excel"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2B6CC4" Padding="0"
                       FontFamily="Segoe UI, Tahoma"/>
                <Label Content="Choose what to export"
                       FontSize="11" Foreground="#555555"
                       Padding="0"
                       FontFamily="Segoe UI, Tahoma"/>
            </StackPanel>
        </Border>

        <Button Grid.Row="1"
                Content="📅  Daily Report (Today)"
                Height="56" Margin="20,16,20,6"
                Style="{StaticResource BigBtn}"
                Cursor="Hand"
                Click="btnExportDaily_Click"/>

        <Button Grid.Row="2"
                Content="📆  Monthly Report"
                Height="56" Margin="20,0,20,6"
                Style="{StaticResource BigBtn}"
                Cursor="Hand"
                Click="btnExportMonthly_Click"/>

        <Button Grid.Row="3"
                Content="📈  Yearly Report"
                Height="56" Margin="20,0,20,6"
                Style="{StaticResource BigBtn}"
                Cursor="Hand"
                Click="btnExportYearly_Click"/>

        <Button Grid.Row="4"
                Content="🧾  Full Sales History"
                Height="56" Margin="20,0,20,6"
                Style="{StaticResource BigBtn}"
                Cursor="Hand"
                Click="btnExportHistory_Click"/>

        <Button Grid.Row="5"
                Content="📦  Products &amp; Inventory"
                Height="56" Margin="20,0,20,6"
                Style="{StaticResource BigBtn}"
                Cursor="Hand"
                Click="btnExportProducts_Click"/>

        <Button Grid.Row="6"
                Content="✕  Close"
                Height="42" Margin="20,0,20,20"
                Style="{StaticResource BigBtn}"
                FontSize="13"
                Cursor="Hand"
                Click="btnClose_Click"/>

        <!-- Loading Overlay -->
        <Border x:Name="loadingOverlay" 
                Grid.Row="0" Grid.RowSpan="7"
                Background="#F0F0F0" 
                Opacity="0.85"
                Visibility="Collapsed"
                Panel.ZIndex="9999">
            <Grid>
                <Border Width="320" Height="120" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Background="#FAFAFA"
                        BorderBrush="#B8B8B8" 
                        BorderThickness="1"
                        CornerRadius="4">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="4" Opacity="0.15" Color="#000000"/>
                    </Border.Effect>

                    <Border BorderBrush="#FFFFFF" BorderThickness="1" CornerRadius="3">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="lblLoadingMessage" 
                                       Text="Processing..." 
                                       FontFamily="Segoe UI, Tahoma"
                                       FontSize="14" 
                                       FontWeight="SemiBold"
                                       Foreground="#1A1A1A"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,15"/>

                            <Border Grid.Row="1" 
                                    Height="24" 
                                    Background="#E8E8E8"
                                    BorderBrush="#99AABB" 
                                    BorderThickness="1"
                                    CornerRadius="2">
                                <Border BorderBrush="#FFFFFF" BorderThickness="1" CornerRadius="1">
                                    <ProgressBar IsIndeterminate="True"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="#2B6CC4"/>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>