<Window x:Class="POSSystem.Windows.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Change Password" Height="480" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <Window.Resources>
        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- 3D Bevel Button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="15,12" Margin="25,25,25,20">
            <Label Content="🔑  Change Password"
                   FontSize="20" FontWeight="Bold"
                   Foreground="#2B6CC4" Padding="0"
                   FontFamily="Segoe UI, Tahoma"/>
        </Border>

        <!-- Current Password label -->
        <Label Grid.Row="1" Content="CURRENT PASSWORD"
               FontSize="10" Foreground="#555555"
               FontWeight="Bold" Padding="0"
               Margin="25,0,25,4"
               FontFamily="Segoe UI, Tahoma"/>

        <!-- Current Password field -->
        <Border Grid.Row="2" BorderBrush="#99AABB" BorderThickness="1"
                Margin="25,0,25,15">
            <Border BorderBrush="#FFFFFF" BorderThickness="1">
                <PasswordBox x:Name="txtCurrent"
                             Background="#FFFFFF"
                             Foreground="#1A1A1A"
                             BorderThickness="0"
                             FontSize="13" Padding="10,9"
                             FontFamily="Segoe UI, Tahoma"/>
            </Border>
        </Border>

        <!-- New Password label -->
        <Label Grid.Row="3" Content="NEW PASSWORD"
               FontSize="10" Foreground="#555555"
               FontWeight="Bold" Padding="0"
               Margin="25,0,25,4"
               FontFamily="Segoe UI, Tahoma"/>

        <!-- New Password field -->
        <Border Grid.Row="4" BorderBrush="#99AABB" BorderThickness="1"
                Margin="25,0,25,15">
            <Border BorderBrush="#FFFFFF" BorderThickness="1">
                <PasswordBox x:Name="txtNew"
                             Background="#FFFFFF"
                             Foreground="#1A1A1A"
                             BorderThickness="0"
                             FontSize="13" Padding="10,9"
                             FontFamily="Segoe UI, Tahoma"/>
            </Border>
        </Border>

        <!-- Confirm Password label -->
        <Label Grid.Row="5" Content="CONFIRM NEW PASSWORD"
               FontSize="10" Foreground="#555555"
               FontWeight="Bold" Padding="0"
               Margin="25,0,25,4"
               FontFamily="Segoe UI, Tahoma"/>

        <!-- Confirm Password field -->
        <Border Grid.Row="6" BorderBrush="#99AABB" BorderThickness="1"
                Margin="25,0,25,10">
            <Border BorderBrush="#FFFFFF" BorderThickness="1">
                <PasswordBox x:Name="txtConfirm"
                             Background="#FFFFFF"
                             Foreground="#1A1A1A"
                             BorderThickness="0"
                             FontSize="13" Padding="10,9"
                             FontFamily="Segoe UI, Tahoma"/>
            </Border>
        </Border>

        <!-- Message label -->
        <Label Grid.Row="7" x:Name="lblMessage"
               Content="" FontSize="12"
               Padding="0" Margin="25,0,25,10"
               MinHeight="20"
               Foreground="#B71C1C"
               FontFamily="Segoe UI, Tahoma"/>

        <!-- Save Button -->
        <Button Grid.Row="8" Content="💾  Save Password"
                Height="46" Margin="25,0,25,25"
                Style="{StaticResource BigBtn}"
                Click="btnSave_Click"/>
    </Grid>
</Window>