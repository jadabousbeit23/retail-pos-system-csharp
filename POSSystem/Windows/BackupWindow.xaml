<Window x:Class="POSSystem.Windows.BackupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Backup &amp; Restore" Height="620" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <Window.Resources>
        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- ListView rows -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 3D Bevel Button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="16,12" Margin="20,20,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Label Content="💾  Backup &amp; Restore"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#2B6CC4" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label Content="Manage your database backups"
                           FontSize="11" Foreground="#555555"
                           Padding="0" FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#E8F2FF"
                        BorderBrush="#B8CCEE" BorderThickness="1"
                        CornerRadius="6" Padding="12,4"
                        VerticalAlignment="Center">
                    <Label x:Name="lblBackupCount"
                           Content="0 backups"
                           Foreground="#1A1A1A" FontSize="12"
                           FontWeight="Bold" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </Border>
            </Grid>
        </Border>

        <!-- Backup Folder Path -->
        <Border Grid.Row="1" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1"
                Padding="14,10" Margin="20,0,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0"
                       Content="📁  Backup Folder:"
                       Foreground="#555555"
                       FontSize="11" FontWeight="Bold"
                       VerticalContentAlignment="Center"
                       Padding="0" Margin="0,0,10,0"
                       FontFamily="Segoe UI, Tahoma"/>
                <Border Grid.Column="1"
                        Background="#FFFFFF"
                        BorderBrush="#99AABB" BorderThickness="1">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <TextBox x:Name="txtBackupFolder"
                                 Background="Transparent"
                                 Foreground="#1A1A1A"
                                 BorderThickness="0"
                                 FontSize="11" Padding="8,6"
                                 CaretBrush="#1A1A1A"
                                 IsReadOnly="True"
                                 FontFamily="Segoe UI, Tahoma"/>
                    </Border>
                </Border>
                <Button Grid.Column="2"
                        x:Name="btnBrowse"
                        Content="📂 Browse"
                        Width="90" Height="32"
                        Margin="8,0,0,0"
                        Style="{StaticResource BigBtn}"
                        Click="btnBrowse_Click"/>
            </Grid>
        </Border>

        <!-- Action Buttons -->
        <Grid Grid.Row="2" Margin="20,0,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="btnCreate"
                    Grid.Column="0"
                    Content="💾  Create Backup"
                    Height="46" Margin="0,0,6,0"
                    Style="{StaticResource BigBtn}"
                    Click="btnCreateBackup_Click"/>

            <Button x:Name="btnRestore"
                    Grid.Column="1"
                    Content="🔄  Restore Selected"
                    Height="46" Margin="6,0,6,0"
                    Style="{StaticResource BigBtn}"
                    Click="btnRestore_Click"/>

            <Button x:Name="btnDelete"
                    Grid.Column="2"
                    Content="🗑️  Delete Selected"
                    Height="46" Margin="6,0,0,0"
                    Style="{StaticResource BigBtn}"
                    Click="btnDelete_Click"/>
        </Grid>

        <!-- Backup List -->
        <Border Grid.Row="3" Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="1"
                Margin="20,0,20,12">
            <ListView x:Name="lvBackups"
                      Background="Transparent"
                      Foreground="#1A1A1A"
                      BorderThickness="0"
                      FontFamily="Segoe UI, Tahoma"
                      Margin="4"
                      SelectionChanged="lvBackups_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding TypeColor}"
                                            CornerRadius="4"
                                            Padding="6,2">
                                        <TextBlock
                                            Text="{Binding TypeText}"
                                            Foreground="White"
                                            FontSize="10"
                                            FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="290"
                            DisplayMemberBinding="{Binding FileName}"/>
                        <GridViewColumn Width="160"
                            DisplayMemberBinding="{Binding DisplayDate}"/>
                        <GridViewColumn Width="80"
                            DisplayMemberBinding="{Binding SizeText}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Status Message -->
        <Label Grid.Row="4"
               x:Name="lblMessage" Content=""
               FontSize="12" FontWeight="Bold"
               Foreground="#1A1A1A"
               Padding="0" Margin="20,0,20,8"
               MinHeight="20"
               FontFamily="Segoe UI, Tahoma"/>

        <!-- Close -->
        <Button Grid.Row="5"
                x:Name="btnClose"
                Content="✕  Close"
                Height="42" Margin="20,0,20,20"
                Style="{StaticResource BigBtn}"
                Click="btnClose_Click"/>

        <!-- Loading Overlay (Built-in - No separate control needed) -->
        <Border x:Name="loadingOverlay" 
                Grid.Row="0" Grid.RowSpan="6"
                Background="#F0F0F0" 
                Opacity="0.85"
                Visibility="Collapsed"
                Panel.ZIndex="9999">
            <Grid>
                <Border Width="320" Height="120" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Background="#FAFAFA"
                        BorderBrush="#B8B8B8" 
                        BorderThickness="1"
                        CornerRadius="4">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="4" Opacity="0.15" Color="#000000"/>
                    </Border.Effect>

                    <Border BorderBrush="#FFFFFF" BorderThickness="1" CornerRadius="3">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="lblLoadingMessage" 
                                       Text="Processing..." 
                                       FontFamily="Segoe UI, Tahoma"
                                       FontSize="14" 
                                       FontWeight="SemiBold"
                                       Foreground="#1A1A1A"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,15"/>

                            <Border Grid.Row="1" 
                                    Height="24" 
                                    Background="#E8E8E8"
                                    BorderBrush="#99AABB" 
                                    BorderThickness="1"
                                    CornerRadius="2">
                                <Border BorderBrush="#FFFFFF" BorderThickness="1" CornerRadius="1">
                                    <ProgressBar IsIndeterminate="True"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="#2B6CC4"/>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>