<Window x:Class="POSSystem.FirstRunWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome — First Time Setup"
        Width="520" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#E8F2FF" Offset="0"/>
                    <GradientStop Color="#C8DCFA" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" Margin="24,0">
                <TextBlock Text="Welcome to POS System" FontSize="18"
                           FontWeight="SemiBold" Foreground="#1A1A1A"/>
                <TextBlock Text="Let's set up your store before you get started."
                           FontSize="12" Foreground="#555555" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Form -->
        <StackPanel Grid.Row="1" Margin="32,24">

            <TextBlock Text="Store Name" FontSize="12" FontWeight="SemiBold"
                       Foreground="#1A1A1A" Margin="0,0,0,4"/>
            <TextBox x:Name="txtStoreName" Height="30" FontSize="13"
                     Padding="6,4" Margin="0,0,0,16"
                     BorderBrush="#99AABB"/>

            <TextBlock Text="Store Phone" FontSize="12" FontWeight="SemiBold"
                       Foreground="#1A1A1A" Margin="0,0,0,4"/>
            <TextBox x:Name="txtPhone" Height="30" FontSize="13"
                     Padding="6,4" Margin="0,0,0,16"
                     BorderBrush="#99AABB"/>

            <TextBlock Text="Store Address" FontSize="12" FontWeight="SemiBold"
                       Foreground="#1A1A1A" Margin="0,0,0,4"/>
            <TextBox x:Name="txtAddress" Height="30" FontSize="13"
                     Padding="6,4" Margin="0,0,0,16"
                     BorderBrush="#99AABB"/>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Exchange Rate (LBP per $1)" FontSize="12"
                               FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtRate" Height="30" FontSize="13"
                             Padding="6,4" BorderBrush="#99AABB" Text="90000"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Tax Rate (%)" FontSize="12"
                               FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtTax" Height="30" FontSize="13"
                             Padding="6,4" BorderBrush="#99AABB" Text="0"/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="lblError" Foreground="#B00000" FontSize="12"
                       Visibility="Collapsed" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#C0C0C0"
                Background="#F0F0F0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,24,0">
                <TextBlock x:Name="lblVersion"
                           Text="" VerticalAlignment="Center"
                           FontSize="11" Foreground="#888888" Margin="0,0,20,0"/>
                <Button x:Name="btnFinish" Content="Finish Setup →"
                        Width="140" Height="34" FontSize="13"
                        FontWeight="SemiBold" Click="BtnFinish_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FDFDFD" Offset="0"/>
                            <GradientStop Color="#E8E8E8" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>