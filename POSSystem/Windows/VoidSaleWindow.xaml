<Window x:Class="POSSystem.Windows.VoidedSalesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Voided Sales" Height="620" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <!--
    ═══════════════════════════════════════════════════════════
      CLASSIC WINDOWS LIGHT THEME
        Page bg       : #F0F0F0
        Surface       : #FAFAFA
        Button face   : #FDFDFD → #E8E8E8
        Button hover  : #EEF4FF → #D0DFFA
        Button press  : #D8D8D8 → #E4E4E4
        Bevel outer   : #B8B8B8
        Bevel hi      : #FFFFFF / shadow #A0A0A0
        Header        : soft sky-blue gradient
        Edit border   : #99AABB / inner #FFFFFF
        Text primary  : #1A1A1A
        Text muted    : #555555
        Text subtle   : #888888
        Accent blue   : #2B6CC4
        Green total   : #1A7A1A
        Amber disc    : #A0520A
        Red delete    : #B00000
    ═══════════════════════════════════════════════════════════
    -->

    <Window.Resources>

        <!-- Header — very soft sky blue -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Column header -->
        <LinearGradientBrush x:Key="ColHeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F8F8F8" Offset="0"/>
            <GradientStop Color="#E4E4E4" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush — top-left highlight / bottom-right shadow -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <!-- ListView rows -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                    <Setter Property="Foreground" Value="#1A3A8A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                    <Setter Property="Foreground" Value="#0A2060"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- GridViewColumnHeader style -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{StaticResource ColHeaderBrush}"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#C8C8C8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

    </Window.Resources>

    <Grid Background="#F0F0F0">
        <StackPanel Margin="20">

            <!-- Header -->
            <Border Background="{StaticResource HeaderBrush}"
                    BorderBrush="#B8CCEE" BorderThickness="1"
                    Padding="15,12" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0"
                           Content="⛔  Voided Sales"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#2B6CC4" FontFamily="Segoe UI, Tahoma" Padding="0"/>
                    <Border Grid.Column="1"
                            BorderBrush="#B8B8B8" BorderThickness="1"
                            CornerRadius="3" Padding="12,6">
                        <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1" CornerRadius="2">
                            <Border CornerRadius="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#4A90D9" Offset="0"/>
                                        <GradientStop Color="#2B6CC4" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Label x:Name="lblVoidCount"
                                       Content="0 records"
                                       Foreground="White" FontSize="13"
                                       FontWeight="Bold" FontFamily="Segoe UI, Tahoma" Padding="0"/>
                            </Border>
                        </Border>
                    </Border>
                </Grid>
            </Border>

            <!-- ListView -->
            <Border Background="#FFFFFF"
                    BorderBrush="#99AABB" BorderThickness="1">
                <Border BorderBrush="#FFFFFF" BorderThickness="1">
                    <ListView x:Name="lvVoided" Height="460"
                              Background="#FFFFFF"
                              Foreground="#1A1A1A"
                              FontFamily="Segoe UI, Tahoma"
                              BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" Width="50"
                                                DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Header="Date" Width="160"
                                                DisplayMemberBinding="{Binding Date}"/>
                                <GridViewColumn Header="Cashier" Width="110"
                                                DisplayMemberBinding="{Binding CashierName}"/>
                                <GridViewColumn Header="Items Voided" Width="490"
                                                DisplayMemberBinding="{Binding Items}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Border>

        </StackPanel>
    </Grid>
</Window>