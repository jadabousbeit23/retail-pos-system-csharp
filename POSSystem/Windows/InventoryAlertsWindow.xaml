<Window x:Class="POSSystem.Windows.InventoryAlertsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventory Alerts"
        Height="620" Width="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <Window.Resources>
        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- ListView rows -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 3D Bevel Button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="15,12" Margin="16,16,16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0"
                       Content="🔔  Inventory Alerts"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#2B6CC4" Padding="0"
                       FontFamily="Segoe UI, Tahoma"/>
                <!-- Summary badges -->
                <Border Grid.Column="1" Background="#FADBD8"
                        BorderBrush="#E6B0AA" BorderThickness="1"
                        CornerRadius="6" Padding="12,4"
                        Margin="0,0,6,0" VerticalAlignment="Center">
                    <Label x:Name="lblOutCount"
                           Content="🔴 0 Out of Stock"
                           Foreground="#922B21" FontSize="12"
                           FontWeight="Bold" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </Border>
                <Border Grid.Column="2" Background="#FCF3CF"
                        BorderBrush="#F9E79F" BorderThickness="1"
                        CornerRadius="6" Padding="12,4"
                        Margin="0,0,6,0" VerticalAlignment="Center">
                    <Label x:Name="lblLowCount"
                           Content="⚠️ 0 Low Stock"
                           Foreground="#B7950B" FontSize="12"
                           FontWeight="Bold" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </Border>
                <Border Grid.Column="3" Background="#FADBD8"
                        BorderBrush="#E6B0AA" BorderThickness="1"
                        CornerRadius="6" Padding="12,4"
                        VerticalAlignment="Center">
                    <Label x:Name="lblExpiredCount"
                           Content="🔴 0 Expired"
                           Foreground="#922B21" FontSize="12"
                           FontWeight="Bold" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </Border>
            </Grid>
        </Border>

        <!-- Tab Buttons -->
        <Border Grid.Row="1" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1"
                Padding="10,8" Margin="16,0,16,10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnTabLow"
                        Content="⚠️  Low Stock"
                        Width="160"
                        Style="{StaticResource BigBtn}"
                        Margin="0,0,8,0"
                        Click="btnTab_Click"/>
                <Button x:Name="btnTabExpiring"
                        Content="🟡  Expiring Soon"
                        Width="160"
                        Style="{StaticResource BigBtn}"
                        Margin="0,0,8,0"
                        Click="btnTab_Click"/>
                <Button x:Name="btnTabExpired"
                        Content="🔴  Expired"
                        Width="160"
                        Style="{StaticResource BigBtn}"
                        Click="btnTab_Click"/>
                <Button Content="🔄 Refresh"
                        Width="100" Margin="16,0,0,0"
                        Style="{StaticResource BigBtn}"
                        Click="btnRefresh_Click"/>
            </StackPanel>
        </Border>

        <!-- Content area — shared ListView -->
        <Border Grid.Row="2" Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="1"
                Margin="16,0,16,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Dynamic column header bar -->
                <Border Grid.Row="0" x:Name="headerBar"
                        Background="#F4F4F4" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1"
                        Padding="8,6" Margin="0,0,0,2">
                    <Grid x:Name="headerGrid"/>
                </Border>

                <!-- Low Stock Tab -->
                <ListView Grid.Row="1" x:Name="lvLowStock"
                          Background="Transparent" BorderThickness="0"
                          FontFamily="Segoe UI, Tahoma"
                          Margin="4"
                          Visibility="Visible">
                    <ListView.View>
                        <GridView>
                            <GridView.ColumnHeaderContainerStyle>
                                <Style TargetType="GridViewColumnHeader">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </GridView.ColumnHeaderContainerStyle>
                            <GridViewColumn Width="50" DisplayMemberBinding="{Binding Id}"/>
                            <GridViewColumn Width="200" DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Width="120" DisplayMemberBinding="{Binding Category}"/>
                            <GridViewColumn Width="70" DisplayMemberBinding="{Binding Stock}"/>
                            <GridViewColumn Width="70" DisplayMemberBinding="{Binding MinStock}"/>
                            <GridViewColumn Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusColor}"
                                                CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="White"
                                                       FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="100" DisplayMemberBinding="{Binding PriceDisplay}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Expiry Tab -->
                <ListView Grid.Row="1" x:Name="lvExpiry"
                          Background="Transparent" BorderThickness="0"
                          FontFamily="Segoe UI, Tahoma"
                          Margin="4"
                          Visibility="Collapsed">
                    <ListView.View>
                        <GridView>
                            <GridView.ColumnHeaderContainerStyle>
                                <Style TargetType="GridViewColumnHeader">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </GridView.ColumnHeaderContainerStyle>
                            <GridViewColumn Width="180" DisplayMemberBinding="{Binding ProductName}"/>
                            <GridViewColumn Width="130" DisplayMemberBinding="{Binding BatchNumber}"/>
                            <GridViewColumn Width="110" DisplayMemberBinding="{Binding ExpiryDate}"/>
                            <GridViewColumn Width="80" DisplayMemberBinding="{Binding Quantity}"/>
                            <GridViewColumn Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusColor}"
                                                CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="White"
                                                       FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="90" DisplayMemberBinding="{Binding DaysLeft}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- Close -->
        <Button Grid.Row="3"
                Content="✕  Close"
                Height="40" Margin="16,0,16,16"
                Style="{StaticResource BigBtn}"
                Click="btnClose_Click"/>
    </Grid>
</Window>