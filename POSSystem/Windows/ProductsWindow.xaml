<Window x:Class="POSSystem.Windows.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Products Management"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="{Binding RowBackground}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox style matching AuditLogWindow exactly -->
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="Foreground" Value="#1A1A1A"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#EEF4FF"/>
                                <Setter Property="Foreground" Value="#1A3A8A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#C8DBFA"/>
                                <Setter Property="Foreground" Value="#0A2060"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="15,12" Margin="20,20,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0"
                       Content="📦  Products Management"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#2B6CC4" Padding="0"
                       FontFamily="Segoe UI, Tahoma"/>
                <Button Grid.Column="1"
                        Content="🔔  Alerts"
                        Width="110" Height="34"
                        Margin="0,0,8,0"
                        Style="{StaticResource BigBtn}"
                        Click="btnAlerts_Click"/>
                <Button Grid.Column="2"
                        Content="⚙️  Adjust Stock"
                        Width="130" Height="34"
                        Style="{StaticResource BigBtn}"
                        Click="btnAdjustStock_Click"/>
            </Grid>
        </Border>

        <!-- Form Row 1: Name + Category + Code -->
        <Border Grid.Row="1" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1"
                Padding="15,12,15,8" Margin="20,0,20,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <!-- Product Name -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <Label Content="PRODUCT NAME" FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0" Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtName" Background="#FFFFFF"
                                     Foreground="#1A1A1A" BorderThickness="0"
                                     FontSize="13" Padding="8,7" CaretBrush="#2B6CC4"
                                     FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                    </Border>
                </StackPanel>

                <!-- Category - Matching AuditLogWindow exactly -->
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="CATEGORY" 
                               FontSize="10" Foreground="#555555"
                               FontWeight="Bold" Padding="0" 
                               Margin="0,0,0,4"
                               FontFamily="Segoe UI, Tahoma"/>
                        <Button Grid.Column="1" Content="📁"
                                Width="24" Height="20"
                                Style="{StaticResource BigBtn}"
                                FontSize="10"
                                ToolTip="Manage Categories"
                                Click="btnManageCategories_Click"/>
                    </Grid>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <ComboBox x:Name="cmbCategory" Style="{StaticResource ComboStyle}"
                                      SelectionChanged="cmbCategory_SelectionChanged"/>
                        </Border>
                    </Border>
                </StackPanel>

                <!-- Product Code -->
                <StackPanel Grid.Column="2">
                    <Label Content="PRODUCT CODE / BARCODE" FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0" Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="🔄 Gen" Width="52"
                                        Style="{StaticResource BigBtn}"
                                        FontSize="11" ToolTip="Auto-generate code"
                                        Click="btnGenerateCode_Click"/>
                                <TextBox x:Name="txtProductCode" Background="#FFFFFF"
                                         Foreground="#1A1A1A" BorderThickness="0"
                                         FontSize="13" Padding="8,7" CaretBrush="#2B6CC4"
                                         FontFamily="Segoe UI, Tahoma"/>
                            </DockPanel>
                        </Border>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Form Row 2 -->
        <Border Grid.Row="2" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1"
                Padding="15,8,15,12" Margin="20,0,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <Label Content="SELL PRICE (LBP)" FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0" Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtPrice" Background="#FFFFFF"
                                     Foreground="#1A1A1A" BorderThickness="0"
                                     FontSize="13" Padding="8,7" CaretBrush="#2B6CC4"
                                     FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <Label Content="COST PRICE (LBP)" FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0" Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtCostPrice" Background="#FFFFFF"
                                     Foreground="#1A1A1A" BorderThickness="0"
                                     FontSize="13" Padding="8,7" CaretBrush="#2B6CC4"
                                     ToolTip="What you paid the supplier"
                                     FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <Label Content="STOCK (QTY)" FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0" Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtStock" Background="#FFFFFF"
                                     Foreground="#1A1A1A" BorderThickness="0"
                                     FontSize="13" Padding="8,7" CaretBrush="#2B6CC4"
                                     FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,8,0">
                    <Label Content="MIN STOCK" FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0" Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtMinStock" Background="#FFFFFF"
                                     Foreground="#1A1A1A" BorderThickness="0"
                                     FontSize="13" Padding="8,7" CaretBrush="#2B6CC4"
                                     Text="5" ToolTip="Alert when stock drops below this"
                                     FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="4"/>

                <Button Grid.Column="5" Content="📦 Batches"
                        Height="36" Width="100" Margin="0,0,6,0"
                        Style="{StaticResource BigBtn}"
                        VerticalAlignment="Bottom"
                        Click="btnBatches_Click"/>

                <Button Grid.Column="6" Content="📱 QR Code"
                        Height="36" Width="100" Margin="0,0,6,0"
                        Style="{StaticResource BigBtn}"
                        VerticalAlignment="Bottom"
                        Click="btnShowQR_Click"/>

                <Button Grid.Column="7" Content="➕ Add"
                        Height="36" Width="80" Margin="0,0,6,0"
                        Style="{StaticResource BigBtn}"
                        VerticalAlignment="Bottom"
                        Click="btnAdd_Click"/>

                <Button Grid.Column="8" Content="✏️ Update"
                        Height="36" Width="90" Margin="0,0,6,0"
                        Style="{StaticResource BigBtn}"
                        VerticalAlignment="Bottom"
                        Click="btnUpdate_Click"/>

                <Button Grid.Column="9" Content="🗑️ Delete"
                        Height="36" Width="90"
                        Style="{StaticResource BigBtn}"
                        VerticalAlignment="Bottom"
                        Click="btnDelete_Click"/>
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="3" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1"
                Padding="12" Margin="20,0,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <Label Content="SEARCH BY NAME" FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0" Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtSearch" Background="#FFFFFF"
                                     Foreground="#1A1A1A" BorderThickness="0"
                                     FontSize="13" Padding="8,7" CaretBrush="#2B6CC4"
                                     TextChanged="txtSearch_TextChanged"
                                     FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <Label Content="SEARCH BY CODE" FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0" Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtSearchCode" Background="#FFFFFF"
                                     Foreground="#1A1A1A" BorderThickness="0"
                                     FontSize="13" Padding="8,7" CaretBrush="#2B6CC4"
                                     TextChanged="txtSearchCode_TextChanged"
                                     FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <Label Content="FILTER BY CATEGORY" FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0" Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtFilterCat" Background="#FFFFFF"
                                     Foreground="#1A1A1A" BorderThickness="0"
                                     FontSize="13" Padding="8,7" CaretBrush="#2B6CC4"
                                     TextChanged="txtFilterCat_TextChanged"
                                     FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                    <Label Content="STATUS" FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0" Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnFilterAll" Content="All"
                                Width="46" Height="34" Margin="0,0,4,0"
                                Style="{StaticResource BigBtn}"
                                Click="btnFilterStatus_Click"/>
                        <Button x:Name="btnFilterLow" Content="⚠️Low"
                                Width="58" Height="34" Margin="0,0,4,0"
                                Style="{StaticResource BigBtn}"
                                Click="btnFilterStatus_Click"/>
                        <Button x:Name="btnFilterOk" Content="✅OK"
                                Width="50" Height="34"
                                Style="{StaticResource BigBtn}"
                                Click="btnFilterStatus_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Product List -->
        <Border Grid.Row="4" Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="1"
                Margin="20,0,20,6">
            <ListView x:Name="lvProducts"
                      Background="Transparent"
                      Foreground="#1A1A1A"
                      BorderThickness="0"
                      FontFamily="Segoe UI, Tahoma"
                      Margin="4"
                      SelectionChanged="lvProducts_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Width="40"
                            DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Width="110"
                            DisplayMemberBinding="{Binding ProductCode}"/>
                        <GridViewColumn Width="160"
                            DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Width="110"
                            DisplayMemberBinding="{Binding BatchDisplay}"/>
                        <GridViewColumn Width="95"
                            DisplayMemberBinding="{Binding Category}"/>
                        <GridViewColumn Width="90"
                            DisplayMemberBinding="{Binding PriceDisplay}"/>
                        <GridViewColumn Width="75"
                            DisplayMemberBinding="{Binding CostPriceDisplay}"/>
                        <GridViewColumn Width="65"
                            DisplayMemberBinding="{Binding MarginDisplay}"/>
                        <GridViewColumn Width="90"
                            DisplayMemberBinding="{Binding MarginLBPDisplay}"/>
                        <GridViewColumn Width="50"
                            DisplayMemberBinding="{Binding Stock}"/>
                        <GridViewColumn Width="40"
                            DisplayMemberBinding="{Binding MinStock}"/>
                        <GridViewColumn Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding StatusColor}"
                                            CornerRadius="4" Padding="5,2">
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="White" FontSize="10"
                                                   FontWeight="Bold" TextAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="145">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding ExpiryColor}"
                                            CornerRadius="4" Padding="5,2">
                                        <TextBlock Text="{Binding ExpiryText}"
                                                   Foreground="White" FontSize="10"
                                                   FontWeight="Bold" TextAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="5" Margin="20,0,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label x:Name="lblMessage" Content=""
                   FontSize="12" FontWeight="Bold"
                   Padding="0" VerticalContentAlignment="Center"
                   Foreground="#1A1A1A"
                   FontFamily="Segoe UI, Tahoma"/>
            <Label Grid.Column="1" x:Name="lblLowStock"
                   Content="" Foreground="#B71C1C"
                   FontSize="11" FontWeight="Bold"
                   Padding="0" VerticalContentAlignment="Center"
                   FontFamily="Segoe UI, Tahoma"/>
        </Grid>
    </Grid>
</Window>