<Window x:Class="POSSystem.Windows.NewOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Purchase Order" Height="680" Width="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <Window.Resources>
        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- ListView rows -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 3D Bevel Button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- FIX: ComboBox style with solid white background and clear dropdown items -->
        <Style x:Key="LightCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#99AABB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="Foreground" Value="#1A1A1A"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#EEF4FF"/>
                                <Setter Property="Foreground" Value="#1A3A8A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#C8DBFA"/>
                                <Setter Property="Foreground" Value="#0A2060"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="15,12" Margin="20,20,20,12">
            <Label Content="➕  New Purchase Order"
                   FontSize="20" FontWeight="Bold"
                   Foreground="#2B6CC4" Padding="0"
                   FontFamily="Segoe UI, Tahoma"/>
        </Border>

        <!-- Supplier + Notes -->
        <Border Grid.Row="1" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1"
                Padding="14" Margin="20,0,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <Label Content="SUPPLIER"
                           FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0"
                           Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <ComboBox x:Name="cmbSupplier"
                              DisplayMemberPath="Name"
                              Style="{StaticResource LightCombo}"
                              SelectionChanged="cmbSupplier_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Label Content="NOTES (OPTIONAL)"
                           FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0"
                           Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtNotes"
                                     Background="#FFFFFF"
                                     Foreground="#1A1A1A"
                                     BorderThickness="0"
                                     FontSize="13" Padding="8,7"
                                     CaretBrush="#2B6CC4"
                                     FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Add Item Row -->
        <Border Grid.Row="2" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1"
                Padding="14" Margin="20,0,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          x:Name="cmbProduct"
                          DisplayMemberPath="Name"
                          Style="{StaticResource LightCombo}"
                          Margin="0,0,8,0"/>

                <Border Grid.Column="1" BorderBrush="#99AABB" BorderThickness="1"
                        Margin="0,0,8,0">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <TextBox x:Name="txtQty"
                                 Background="#FFFFFF"
                                 Foreground="#1A1A1A"
                                 BorderThickness="0"
                                 FontSize="13" Padding="8,7"
                                 CaretBrush="#2B6CC4"
                                 Text="1"
                                 FontFamily="Segoe UI, Tahoma"/>
                    </Border>
                </Border>

                <Border Grid.Column="2" BorderBrush="#99AABB" BorderThickness="1"
                        Margin="0,0,8,0">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <TextBox x:Name="txtCost"
                                 Background="#FFFFFF"
                                 Foreground="#1A1A1A"
                                 BorderThickness="0"
                                 FontSize="13" Padding="8,7"
                                 CaretBrush="#2B6CC4"
                                 Text="0"
                                 FontFamily="Segoe UI, Tahoma"/>
                    </Border>
                </Border>

                <Button Grid.Column="3"
                        Content="➕ Add Item"
                        Height="36" Padding="14,0"
                        Style="{StaticResource BigBtn}"
                        Click="btnAddItem_Click"/>
            </Grid>
        </Border>

        <!-- Items List -->
        <Border Grid.Row="3" Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="1"
                Margin="20,0,20,12">
            <ListView x:Name="lvItems"
                      Background="Transparent"
                      Foreground="#1A1A1A"
                      BorderThickness="0"
                      FontFamily="Segoe UI, Tahoma"
                      Margin="4">
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Width="200"
                            DisplayMemberBinding="{Binding ProductName}"/>
                        <GridViewColumn Width="70"
                            DisplayMemberBinding="{Binding Quantity}"/>
                        <GridViewColumn Width="110"
                            DisplayMemberBinding="{Binding UnitCostText}"/>
                        <GridViewColumn Width="100"
                            DisplayMemberBinding="{Binding TotalCostText}"/>
                        <GridViewColumn Width="60">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑️"
                                            Width="40" Height="26"
                                            Style="{StaticResource BigBtn}"
                                            Tag="{Binding}"
                                            Click="btnRemoveItem_Click"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Total + Message -->
        <Grid Grid.Row="4" Margin="20,0,20,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label x:Name="lblMessage" Content=""
                   FontSize="12" FontWeight="Bold"
                   Foreground="#B71C1C"
                   VerticalContentAlignment="Center"
                   Padding="0"
                   FontFamily="Segoe UI, Tahoma"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Label Content="ORDER TOTAL:"
                       Foreground="#555555"
                       FontSize="13" FontWeight="Bold"
                       VerticalContentAlignment="Center"
                       Padding="0" Margin="0,0,8,0"
                       FontFamily="Segoe UI, Tahoma"/>
                <Label x:Name="lblTotal"
                       Content="LBP 0"
                       Foreground="#1A1A1A"
                       FontSize="20" FontWeight="Bold"
                       Padding="0"
                       FontFamily="Segoe UI, Tahoma"/>
            </StackPanel>
        </Grid>

        <!-- Save / Cancel -->
        <Grid Grid.Row="5" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="💾  Save Order"
                    Height="46" Margin="0,0,6,0"
                    Style="{StaticResource BigBtn}"
                    Click="btnSave_Click"/>
            <Button Grid.Column="1"
                    Content="✕  Cancel"
                    Height="46" Margin="6,0,0,0"
                    Style="{StaticResource BigBtn}"
                    Click="btnCancel_Click"/>
        </Grid>
    </Grid>
</Window>