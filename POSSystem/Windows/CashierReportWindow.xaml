<Window x:Class="POSSystem.Windows.CashierReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cashier Performance Report"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>
        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,7"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                    <Setter Property="Foreground" Value="#2B6CC4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- 3D Bevel Button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterBtn" TargetType="Button" BasedOn="{StaticResource BigBtn}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FilterBtnActive" TargetType="Button" BasedOn="{StaticResource BigBtn}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#2B6CC4" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="#5A8FD4"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="#2B6CC4"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="#1A5AB4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="16,12" Margin="20,20,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Label Content="👤  Cashier Performance Report"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#2B6CC4" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblSubtitle"
                           Content="Loading…"
                           FontSize="11" Foreground="#555555" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="📥 Export Excel"
                        Margin="0,0,8,0" Height="36" Width="120"
                        Style="{StaticResource BigBtn}"
                        Click="btnExport_Click"/>

                <Button Grid.Column="2"
                        Content="✕ Close"
                        Height="36" Width="80"
                        Style="{StaticResource BigBtn}"
                        Click="btnClose_Click"/>
            </Grid>
        </Border>

        <!-- FILTER BAR -->
        <Border Grid.Row="1" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1"
                Padding="16,12" Margin="20,0,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Quick filters -->
                <Button Grid.Column="0" x:Name="btnToday"
                        Content="Today"
                        Style="{StaticResource FilterBtnActive}"
                        Margin="0,0,6,0"
                        Click="btnQuickFilter_Click"/>
                <Button Grid.Column="1" x:Name="btnThisWeek"
                        Content="This Week"
                        Style="{StaticResource FilterBtn}"
                        Margin="0,0,6,0"
                        Click="btnQuickFilter_Click"/>
                <Button Grid.Column="2" x:Name="btnThisMonth"
                        Content="This Month"
                        Style="{StaticResource FilterBtn}"
                        Margin="0,0,6,0"
                        Click="btnQuickFilter_Click"/>
                <Button Grid.Column="3" x:Name="btnAllTime"
                        Content="All Time"
                        Style="{StaticResource FilterBtn}"
                        Click="btnQuickFilter_Click"/>

                <!-- Separator -->
                <Border Grid.Column="4" Background="#D0D0D0"
                        Width="1" Margin="8,4"/>

                <!-- Custom range -->
                <Label Grid.Column="5" Content="From:"
                       Foreground="#555555" FontSize="12"
                       VerticalContentAlignment="Center"
                       Padding="0,0,6,0"
                       FontFamily="Segoe UI, Tahoma"/>
                <Border Grid.Column="6" BorderBrush="#99AABB" BorderThickness="1">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <TextBox x:Name="txtFrom"
                                 Background="#FFFFFF" Foreground="#1A1A1A"
                                 BorderThickness="0" FontSize="12"
                                 Padding="8,5" ToolTip="dd/MM/yyyy"
                                 FontFamily="Segoe UI, Tahoma"/>
                    </Border>
                </Border>
                <Label Grid.Column="7" Content="To:"
                       Foreground="#555555" FontSize="12"
                       VerticalContentAlignment="Center"
                       Padding="8,0,6,0"
                       FontFamily="Segoe UI, Tahoma"/>
                <Border Grid.Column="8" BorderBrush="#99AABB" BorderThickness="1">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <TextBox x:Name="txtTo"
                                 Background="#FFFFFF" Foreground="#1A1A1A"
                                 BorderThickness="0" FontSize="12"
                                 Padding="8,5" ToolTip="dd/MM/yyyy"
                                 FontFamily="Segoe UI, Tahoma"/>
                    </Border>
                </Border>
                <Button Grid.Column="9" Content="Apply"
                        Height="30" Margin="6,0,-5,0"
                        Style="{StaticResource FilterBtnActive}"
                        Click="btnApply_Click"/>
            </Grid>
        </Border>

        <!-- SUMMARY CARDS -->
        <Grid Grid.Row="2" Margin="20,0,20,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FAFAFA"
                    BorderBrush="#D0D0D0" BorderThickness="1"
                    Padding="14,12" Margin="0,0,6,0">
                <StackPanel>
                    <Label Content="ACTIVE CASHIERS" FontSize="10"
                           FontWeight="Bold" Foreground="#555555" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblTotalCashiers"
                           Content="0" FontSize="26" FontWeight="Bold"
                           Foreground="#2B6CC4" Padding="0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#FAFAFA"
                    BorderBrush="#D0D0D0" BorderThickness="1"
                    Padding="14,12" Margin="0,0,6,0">
                <StackPanel>
                    <Label Content="TOTAL SALES" FontSize="10"
                           FontWeight="Bold" Foreground="#555555" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblTotalSales"
                           Content="0" FontSize="26" FontWeight="Bold"
                           Foreground="#1A1A1A" Padding="0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#FAFAFA"
                    BorderBrush="#D0D0D0" BorderThickness="1"
                    Padding="14,12" Margin="0,0,6,0">
                <StackPanel>
                    <Label Content="TOTAL REVENUE" FontSize="10"
                           FontWeight="Bold" Foreground="#555555" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblTotalRevenue"
                           Content="LBP 0" FontSize="22" FontWeight="Bold"
                           Foreground="#2E7D32" Padding="0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="#FAFAFA"
                    BorderBrush="#D0D0D0" BorderThickness="1"
                    Padding="14,12">
                <StackPanel>
                    <Label Content="TOP CASHIER" FontSize="10"
                           FontWeight="Bold" Foreground="#555555" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblTopCashier"
                           Content="—" FontSize="18" FontWeight="Bold"
                           Foreground="#E65100" Padding="0"/>
                    <Label x:Name="lblTopCashierRev"
                           Content="" FontSize="11" Foreground="#555555" Padding="0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- TAB BUTTONS -->
        <Border Grid.Row="3" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1"
                Padding="16,12" Margin="20,0,20,12">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnTabOverview"
                        Content="📊  Overview"
                        Style="{StaticResource FilterBtnActive}"
                        Margin="0,0,6,0"
                        Click="btnTab_Click"/>
                <Button x:Name="btnTabDrillDown"
                        Content="🔍  Drill Down"
                        Style="{StaticResource FilterBtn}"
                        Margin="0,0,6,0"
                        Click="btnTab_Click"/>
                <Button x:Name="btnTabChart"
                        Content="📈  Comparison Chart"
                        Style="{StaticResource FilterBtn}"
                        Click="btnTab_Click"/>
            </StackPanel>
        </Border>

        <!-- CONTENT AREA -->
        <Grid Grid.Row="4" Margin="20,0,20,0">

            <!-- TAB 1: OVERVIEW -->
            <Border x:Name="tabOverview" Visibility="Visible"
                    Background="#FFFFFF" BorderBrush="#C0C0C0"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                            BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <Label Content="All Cashiers — Performance Summary"
                               FontSize="13" FontWeight="Bold"
                               Foreground="#2B6CC4" Padding="0"
                               FontFamily="Segoe UI, Tahoma"/>
                    </Border>
                    <ListView Grid.Row="1" x:Name="lvOverview"
                              Background="Transparent" BorderThickness="0"
                              FontFamily="Segoe UI, Tahoma">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Rank" Width="55">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding RankColor}"
                                                    CornerRadius="4" Padding="6,2" Width="36">
                                                <TextBlock Text="{Binding Rank}"
                                                           Foreground="White"
                                                           FontWeight="Bold" FontSize="12"
                                                           TextAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Cashier" Width="160" DisplayMemberBinding="{Binding Cashier}"/>
                                <GridViewColumn Header="Sales Count" Width="100" DisplayMemberBinding="{Binding SalesCount}"/>
                                <GridViewColumn Header="Total Revenue" Width="150" DisplayMemberBinding="{Binding RevenueDisplay}"/>
                                <GridViewColumn Header="Avg Sale" Width="130" DisplayMemberBinding="{Binding AvgSaleDisplay}"/>
                                <GridViewColumn Header="Cash Sales" Width="130" DisplayMemberBinding="{Binding CashDisplay}"/>
                                <GridViewColumn Header="Card Sales" Width="130" DisplayMemberBinding="{Binding CardDisplay}"/>
                                <GridViewColumn Header="Voids" Width="70" DisplayMemberBinding="{Binding Voids}"/>
                                <GridViewColumn Header="Top Product" Width="180" DisplayMemberBinding="{Binding TopProduct}"/>
                                <GridViewColumn Header="Share %" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding ShareDisplay}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="#2B6CC4"/>
                                                <Border Height="4" CornerRadius="2"
                                                        Background="#E0E0E0" Margin="0,2,0,0">
                                                    <Border x:Name="progressBar"
                                                            Background="#2B6CC4"
                                                            CornerRadius="2"
                                                            HorizontalAlignment="Left"
                                                            Width="{Binding ShareBarWidth}"/>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <!-- TAB 2: DRILL DOWN -->
            <Grid x:Name="tabDrillDown" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cashier picker -->
                <Border Grid.Column="0" Background="#FFFFFF"
                        BorderBrush="#C0C0C0" BorderThickness="1"
                        Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                                Padding="10,8">
                            <Label Content="Select Cashier"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="#2B6CC4" Padding="0"
                                   FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                        <ListView Grid.Row="1" x:Name="lvCashierPicker"
                                  Background="Transparent" BorderThickness="0"
                                  SelectionChanged="lvCashierPicker_Changed"
                                  FontFamily="Segoe UI, Tahoma">
                            <ListView.View>
                                <GridView>
                                    <GridView.ColumnHeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </Style>
                                    </GridView.ColumnHeaderContainerStyle>
                                    <GridViewColumn Width="200">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="4,2">
                                                    <TextBlock Text="{Binding Cashier}"
                                                               FontSize="13" FontWeight="Bold"
                                                               Foreground="#1A1A1A"/>
                                                    <TextBlock Text="{Binding RevenueDisplay}"
                                                               FontSize="11" Foreground="#555555"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Sales detail -->
                <Border Grid.Column="1" Background="#FFFFFF"
                        BorderBrush="#C0C0C0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Selected cashier stats -->
                        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                                Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0"
                                       x:Name="lblDrillName"
                                       Content="Select a cashier →"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#2B6CC4" Padding="0"
                                       FontFamily="Segoe UI, Tahoma"/>
                                <StackPanel Grid.Column="1" Margin="0,0,24,0">
                                    <Label Content="SALES" FontSize="9" FontWeight="Bold"
                                           Foreground="#555555" Padding="0"
                                           FontFamily="Segoe UI, Tahoma"/>
                                    <Label x:Name="lblDrillSales"
                                           Content="—" FontSize="16" FontWeight="Bold"
                                           Foreground="#1A1A1A" Padding="0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="0,0,24,0">
                                    <Label Content="REVENUE" FontSize="9" FontWeight="Bold"
                                           Foreground="#555555" Padding="0"
                                           FontFamily="Segoe UI, Tahoma"/>
                                    <Label x:Name="lblDrillRevenue"
                                           Content="—" FontSize="16" FontWeight="Bold"
                                           Foreground="#2E7D32" Padding="0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <Label Content="AVG SALE" FontSize="9" FontWeight="Bold"
                                           Foreground="#555555" Padding="0"
                                           FontFamily="Segoe UI, Tahoma"/>
                                    <Label x:Name="lblDrillAvg"
                                           Content="—" FontSize="16" FontWeight="Bold"
                                           Foreground="#E65100" Padding="0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Column headers for sales list -->
                        <Border Grid.Row="1" Background="#FAFAFA"
                                BorderBrush="#D0D0D0" BorderThickness="0,0,0,1"
                                Padding="8,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="SALE #" FontSize="10" FontWeight="Bold" Foreground="#555555" Padding="4,0"/>
                                <Label Grid.Column="1" Content="DATE" FontSize="10" FontWeight="Bold" Foreground="#555555" Padding="4,0"/>
                                <Label Grid.Column="2" Content="AMOUNT" FontSize="10" FontWeight="Bold" Foreground="#555555" Padding="4,0"/>
                                <Label Grid.Column="3" Content="METHOD" FontSize="10" FontWeight="Bold" Foreground="#555555" Padding="4,0"/>
                                <Label Grid.Column="4" Content="ITEMS" FontSize="10" FontWeight="Bold" Foreground="#555555" Padding="4,0"/>
                            </Grid>
                        </Border>

                        <!-- Sales list -->
                        <ListView Grid.Row="2" x:Name="lvDrillSales"
                                  Background="Transparent" BorderThickness="0"
                                  FontFamily="Segoe UI, Tahoma">
                            <ListView.View>
                                <GridView>
                                    <GridView.ColumnHeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </Style>
                                    </GridView.ColumnHeaderContainerStyle>
                                    <GridViewColumn Width="60" DisplayMemberBinding="{Binding SaleId}"/>
                                    <GridViewColumn Width="160" DisplayMemberBinding="{Binding Date}"/>
                                    <GridViewColumn Width="120" DisplayMemberBinding="{Binding AmountDisplay}"/>
                                    <GridViewColumn Width="100" DisplayMemberBinding="{Binding Method}"/>
                                    <GridViewColumn Width="300" DisplayMemberBinding="{Binding ItemsSummary}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- TAB 3: COMPARISON CHART -->
            <Border x:Name="tabChart" Visibility="Collapsed"
                    Background="#FFFFFF" BorderBrush="#C0C0C0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                            BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Revenue Comparison by Cashier"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="#2B6CC4" Padding="0"
                                   VerticalContentAlignment="Center"
                                   Margin="0,0,16,0"
                                   FontFamily="Segoe UI, Tahoma"/>
                            <Border Background="#C8DBFA" CornerRadius="4"
                                    Padding="10,3" VerticalAlignment="Center">
                                <Label Content="Blue bar = Revenue   |   Number = Sales count"
                                       FontSize="10" Foreground="#2B6CC4" Padding="0"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="16">
                        <ItemsControl x:Name="icChart">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Cashier name -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Cashier}"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="#1A1A1A"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Bar -->
                                        <Grid Grid.Column="1" Margin="8,0">
                                            <Border Background="#F0F0F0" Height="28"
                                                    CornerRadius="4"/>
                                            <Border Background="{Binding BarColor}"
                                                    Height="28" CornerRadius="4"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}">
                                                <Label Content="{Binding SalesCount}"
                                                       Foreground="White" FontSize="11"
                                                       FontWeight="Bold"
                                                       VerticalContentAlignment="Center"
                                                       HorizontalContentAlignment="Center"
                                                       Padding="8,0"/>
                                            </Border>
                                        </Grid>

                                        <!-- Revenue -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding RevenueDisplay}"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="#2E7D32"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Border Grid.Row="2" Background="#FAFAFA"
                            BorderBrush="#D0D0D0" BorderThickness="0,1,0,0"
                            Padding="12,6">
                        <Label x:Name="lblChartNote" Content=""
                               FontSize="10" Foreground="#555555" Padding="0"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="5" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="0,1,0,0"
                Padding="16,8" Margin="20,12,20,10">
            <Label x:Name="lblStatus"
                   Content="Ready"
                   FontSize="11" Foreground="#555555" Padding="0"/>
        </Border>
    </Grid>
</Window>