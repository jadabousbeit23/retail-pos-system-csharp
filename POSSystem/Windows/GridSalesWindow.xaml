<Window x:Class="POSSystem.Windows.GridSalesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Grid Sale"
        WindowState="Maximized"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <!--
    ═══════════════════════════════════════════════════════════
      CLASSIC WINDOWS LIGHT THEME  — softer, airier palette
        Page bg       : #F0F0F0  (standard Win dialog gray)
        Surface       : #FAFAFA
        Button face   : #FDFDFD → #E8E8E8
        Button hover  : #EEF4FF → #D0DFFA
        Button press  : #D8D8D8 → #E4E4E4
        Bevel outer   : #B8B8B8
        Bevel hi      : #FFFFFF / shadow #A0A0A0
        Header        : soft sky-blue gradient
        Edit border   : #99AABB / inner #FFFFFF
        Text primary  : #1A1A1A
        Text muted    : #555555
        Text subtle   : #888888
        Accent blue   : #2B6CC4
        Green total   : #1A7A1A
        Amber disc    : #A0520A
        Red delete    : #B00000
    ═══════════════════════════════════════════════════════════
    -->

    <Window.Resources>

        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header — very soft sky blue -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Scan bar — near white -->
        <LinearGradientBrush x:Key="ScanBarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#F4F4F4" Offset="1"/>
        </LinearGradientBrush>

        <!-- Column header -->
        <LinearGradientBrush x:Key="ColHeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F8F8F8" Offset="0"/>
            <GradientStop Color="#E4E4E4" Offset="1"/>
        </LinearGradientBrush>

        <!-- Footer -->
        <LinearGradientBrush x:Key="FooterBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F4F4F4" Offset="0"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <!-- Panel surface -->
        <LinearGradientBrush x:Key="PanelBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FAFAFA" Offset="0"/>
            <GradientStop Color="#F0F0F0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush — top-left highlight / bottom-right shadow -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- PAY button face — soft green -->
        <LinearGradientBrush x:Key="PayFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E0F5E0" Offset="0"/>
            <GradientStop Color="#B0E0B0" Offset="0.5"/>
            <GradientStop Color="#88CC88" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PayHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EAFAEA" Offset="0"/>
            <GradientStop Color="#C0EAC0" Offset="0.5"/>
            <GradientStop Color="#98DC98" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PayPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#70B870" Offset="0"/>
            <GradientStop Color="#90CC90" Offset="1"/>
        </LinearGradientBrush>

        <!-- ListView rows -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                    <Setter Property="Foreground" Value="#1A3A8A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                    <Setter Property="Foreground" Value="#0A2060"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Raised 3-D bevel button ── -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Numpad key — same bevel, larger -->
        <Style x:Key="NumBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#C0C0C0" BorderThickness="1"
                                CornerRadius="4">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="3">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="2" Padding="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>

        <!-- ══ ROW 0 — HEADER (soft sky blue) ══ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="#B8B8B8" BorderThickness="1"
                        CornerRadius="3" Margin="10,9,8,9">
                    <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1" CornerRadius="2">
                        <Border CornerRadius="1" Padding="16,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#4A90D9" Offset="0"/>
                                    <GradientStop Color="#2B6CC4" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label Content="🔲 GRID SALE" Foreground="White"
                                   FontFamily="Segoe UI, Tahoma" FontSize="14" FontWeight="Bold"
                                   VerticalContentAlignment="Center"/>
                        </Border>
                    </Border>
                </Border>

                <Button Grid.Column="1" Content="⚡  Fast Mode"
                        Width="110" Margin="4,10,0,10"
                        Foreground="#1A1A1A"
                        Style="{StaticResource BigBtn}" FontSize="12"
                        Click="btnFastMode_Click"/>

                <Label Grid.Column="2" x:Name="lblInvoice"
                       Content="Invoice #: ---"
                       Foreground="#4466AA" FontFamily="Segoe UI, Tahoma" FontSize="12"
                       VerticalContentAlignment="Center" Margin="16,0,0,0"/>

                <Label Grid.Column="3" x:Name="lblHeldCount"
                       Content=""
                       Foreground="#A0520A" FontFamily="Segoe UI, Tahoma" FontSize="12" FontWeight="Bold"
                       VerticalContentAlignment="Center" Margin="0,0,12,0"
                       Cursor="Hand"
                       MouseLeftButtonUp="lblHeldCount_Click"
                       ToolTip="Click to view held carts"/>

                <Label Grid.Column="4" x:Name="lblDate"
                       Content="📅" Foreground="#4466AA" FontFamily="Segoe UI, Tahoma" FontSize="12"
                       VerticalContentAlignment="Center" Margin="0,0,12,0"/>

                <Label Grid.Column="5" x:Name="lblTime"
                       Content="🕐" Foreground="#4466AA" FontFamily="Segoe UI, Tahoma" FontSize="12"
                       VerticalContentAlignment="Center" Margin="0,0,12,0"/>

                <!-- Cashier badge — same raised bevel -->
                <Border Grid.Column="6"
                        BorderBrush="#B8B8B8" BorderThickness="1"
                        CornerRadius="3" Margin="0,9,12,9">
                    <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1" CornerRadius="2">
                        <Border CornerRadius="1" Padding="12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFF8E8" Offset="0"/>
                                    <GradientStop Color="#F0E0B0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label x:Name="lblCashier" Content="👤 Cashier"
                                   Foreground="#7A4A00" FontFamily="Segoe UI, Tahoma" FontSize="12" FontWeight="Bold"
                                   VerticalContentAlignment="Center"/>
                        </Border>
                    </Border>
                </Border>
            </Grid>
        </Border>

        <!-- ══ ROW 1 — SCAN BAR ══ -->
        <Border Grid.Row="1" Background="{StaticResource ScanBarBrush}"
                BorderBrush="#D8D8D8" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="📷 Barcode:"
                       Foreground="#2B6CC4" FontWeight="Bold" FontFamily="Segoe UI, Tahoma" FontSize="12"
                       VerticalContentAlignment="Center" Padding="0,0,8,0"/>

                <Border Grid.Column="1"
                        BorderBrush="#99AABB" BorderThickness="1" CornerRadius="0">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <TextBox x:Name="txtScanCode"
                                 Background="#FFFFFF" Foreground="#1A1A1A"
                                 BorderThickness="0" FontFamily="Segoe UI, Tahoma" FontSize="13" FontWeight="SemiBold"
                                 Padding="6,4" CaretBrush="#2B6CC4"
                                 KeyDown="txtScanCode_KeyDown"/>
                    </Border>
                </Border>

                <Label Grid.Column="2" Content="QTY:"
                       Foreground="#555555" FontFamily="Segoe UI, Tahoma" FontSize="12" FontWeight="Bold"
                       VerticalContentAlignment="Center" Margin="10,0,5,0"/>

                <Border Grid.Column="3"
                        BorderBrush="#99AABB" BorderThickness="1" Width="58">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <TextBox x:Name="txtQty" Text="1"
                                 Background="#FFFFFF" Foreground="#1A1A1A"
                                 BorderThickness="0" FontFamily="Segoe UI, Tahoma" FontSize="13" FontWeight="Bold"
                                 Padding="6,4" TextAlignment="Center"/>
                    </Border>
                </Border>

                <Label Grid.Column="4" x:Name="lblScanMsg" Content=""
                       Foreground="#1A7A1A" FontFamily="Segoe UI, Tahoma" FontSize="11" FontWeight="Bold"
                       VerticalContentAlignment="Center" Margin="10,0,0,0"/>

                <!-- NET PAY with USD below -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <Label Content="NET PAY:" Foreground="#555555"
                           FontFamily="Segoe UI, Tahoma" FontSize="12" FontWeight="Bold"
                           VerticalContentAlignment="Center" Padding="0,0,6,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <Label x:Name="lblNetPayLBP" Content="LBP 0"
                               Foreground="#2B6CC4" FontFamily="Segoe UI, Tahoma" FontSize="20" FontWeight="Bold" Padding="0"/>
                        <Label x:Name="lblNetPayUSD" Content="$0.00"
                               Foreground="#5F5F5F" FontFamily="Segoe UI, Tahoma" FontSize="11" Padding="0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ ROW 2 — MAIN ══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="330"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: product tiles -->
            <Grid Grid.Column="0" Margin="8,8,4,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Category bar -->
                <Border Grid.Row="0" Background="{StaticResource ColHeaderBrush}"
                        BorderBrush="#C8C8C8" BorderThickness="1,1,1,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="btnBack"
                                Content="← All Categories"
                                Height="28" Padding="12,0"
                                Foreground="#1A1A1A"
                                BorderThickness="0" FontSize="12"
                                FontWeight="Normal" Cursor="Hand"
                                Visibility="Collapsed"
                                Style="{StaticResource BigBtn}"
                                Click="btnBack_Click"/>

                        <Label Grid.Column="1" x:Name="lblCategory"
                               Content="Select a Category"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#1A1A1A" Padding="8,0,0,0"
                               VerticalContentAlignment="Center"/>

                        <Label Grid.Column="2" x:Name="lblTileCount"
                               Content="" FontSize="11" Foreground="#888888"
                               VerticalContentAlignment="Center" Padding="0,0,8,0"/>
                    </Grid>
                </Border>

                <!-- Tiles scroll area -->
                <Border Grid.Row="1" Background="#FFFFFF"
                        BorderBrush="#99AABB" BorderThickness="1,0,1,1">
                    <Border BorderBrush="#FFFFFF" BorderThickness="0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <WrapPanel x:Name="wpTiles" Margin="8"/>
                        </ScrollViewer>
                    </Border>
                </Border>
            </Grid>

            <!-- RIGHT: Cart + Actions -->
            <Grid Grid.Column="1" Margin="4,8,8,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cart header row -->
                <Border Grid.Row="0" Background="{StaticResource ColHeaderBrush}"
                        BorderBrush="#C8C8C8" BorderThickness="1,1,1,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="#"          Foreground="#555555" FontFamily="Segoe UI, Tahoma" FontSize="11" FontWeight="Bold" Padding="8,5"/>
                        <Label Grid.Column="1" Content="PRODUCT"    Foreground="#555555" FontFamily="Segoe UI, Tahoma" FontSize="11" FontWeight="Bold" Padding="4,5"/>
                        <Label Grid.Column="2" Content="QTY"        Foreground="#555555" FontFamily="Segoe UI, Tahoma" FontSize="11" FontWeight="Bold" Padding="4,5" HorizontalContentAlignment="Center"/>
                        <Label Grid.Column="3" Content="UNIT"       Foreground="#555555" FontFamily="Segoe UI, Tahoma" FontSize="11" FontWeight="Bold" Padding="4,5" HorizontalContentAlignment="Right"/>
                        <Label Grid.Column="4" Content="DISC"       Foreground="#555555" FontFamily="Segoe UI, Tahoma" FontSize="11" FontWeight="Bold" Padding="4,5" HorizontalContentAlignment="Center"/>
                        <Label Grid.Column="5" Content="TOTAL"      Foreground="#555555" FontFamily="Segoe UI, Tahoma" FontSize="11" FontWeight="Bold" Padding="4,5" HorizontalContentAlignment="Right"/>
                        <Label Grid.Column="6"                       Padding="4,5"/>
                    </Grid>
                </Border>

                <!-- Cart ListView -->
                <Border Grid.Row="1"
                        BorderBrush="#99AABB" BorderThickness="1,0,1,1">
                    <Border BorderBrush="#FFFFFF" BorderThickness="0">
                        <ListView x:Name="lvCart"
                                  Background="#FFFFFF"
                                  BorderThickness="0"
                                  FontFamily="Segoe UI, Tahoma"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  SelectionChanged="lvCart_SelectionChanged">
                            <ListView.View>
                                <GridView>
                                    <GridView.ColumnHeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </Style>
                                    </GridView.ColumnHeaderContainerStyle>
                                    <GridViewColumn Width="44">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding RowNumber}" FontSize="12" FontFamily="Segoe UI" Foreground="#888888" Padding="4,0" Width="36" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="110">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ProductName}" FontSize="12" FontFamily="Segoe UI" Foreground="#1A1A1A" Padding="4,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="70">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Quantity}" FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" Foreground="#2B6CC4" TextAlignment="Center" Width="62" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="130">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding UnitPriceDisplay}" FontSize="12" FontFamily="Segoe UI" Foreground="#1A1A1A" TextAlignment="Right" Width="122" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding UnitPriceUSD}" FontSize="9" FontFamily="Segoe UI" Foreground="#8A8A8A" TextAlignment="Right" Width="122" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="70">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DiscountDisplay}" FontSize="12" FontFamily="Segoe UI" Foreground="#A0520A" TextAlignment="Center" Width="62" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="130">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding TotalPriceDisplay}" FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" Foreground="#1A7A1A" TextAlignment="Right" Width="122" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding TotalPriceUSD}" FontSize="9" FontFamily="Segoe UI" Foreground="#8A8A8A" TextAlignment="Right" Width="122" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="44">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✕" Width="26" Height="22"
                                                        Foreground="#B00000"
                                                        FontSize="11" FontWeight="Bold"
                                                        Cursor="Hand"
                                                        Tag="{Binding ProductId}"
                                                        Click="btnRemoveItem_Click"
                                                        Style="{StaticResource BigBtn}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                </Border>

                <!-- Action buttons -->
                <Grid Grid.Row="2" Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="58"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Row="0" Grid.Column="0" Content="✔ SET QTY"
                            Margin="0,0,3,3" Foreground="#1A1A1A"
                            Style="{StaticResource BigBtn}" FontSize="11"
                            Click="btnSetQty_Click"/>
                    <Button Grid.Row="0" Grid.Column="1" Content="CLR"
                            Margin="3,0,0,3" Foreground="#555555"
                            Style="{StaticResource BigBtn}" FontSize="11"
                            Click="btnNumClear_Click"/>

                    <Button Grid.Row="1" Grid.Column="0" Content="🏷️ DISCOUNT"
                            Margin="0,0,3,3" Foreground="#A0520A"
                            Style="{StaticResource BigBtn}" FontSize="11"
                            Click="btnDiscount_Click"/>
                    <Button Grid.Row="1" Grid.Column="1" Content="⛔ VOID"
                            Margin="3,0,0,3" Foreground="#B00000"
                            Style="{StaticResource BigBtn}" FontSize="11"
                            Click="btnVoid_Click"/>

                    <Button Grid.Row="2" Grid.Column="0" Content="⏸️ HOLD"
                            Margin="0,0,3,3" Foreground="#2B6CC4"
                            Style="{StaticResource BigBtn}" FontSize="11"
                            Click="btnHold_Click"/>
                    <Button Grid.Row="2" Grid.Column="1" Content="👤 CUSTOMER"
                            Margin="3,0,0,3" Foreground="#1A7A1A"
                            Style="{StaticResource BigBtn}" FontSize="11"
                            Click="btnCustomer_Click"/>

                    <Button Grid.Row="3" Grid.Column="0" Content="⚡ QUICK PAY"
                            Margin="0,0,3,3" Foreground="#A0520A"
                            Style="{StaticResource BigBtn}" FontSize="12" FontWeight="Bold"
                            Click="btnQuickPay_Click"/>
                    <Button Grid.Row="3" Grid.Column="1" Content="🖨️ PRINT"
                            Margin="3,0,0,3" Foreground="#444444"
                            Style="{StaticResource BigBtn}" FontSize="12" FontWeight="Bold"
                            Click="btnPrint_Click"/>

                    <!-- PAY — soft green raised bevel -->
                    <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                            Margin="0,3,0,0"
                            Foreground="#1A3A1A" FontSize="18" FontWeight="Bold"
                            FontFamily="Segoe UI, Tahoma"
                            Cursor="Hand"
                            Click="btnPay_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="OuterBorder"
                                        BorderBrush="#70AA70" BorderThickness="1" CornerRadius="4">
                                    <Border x:Name="InnerBorder" BorderThickness="1" CornerRadius="3">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#C8F0C8" Offset="0"/>
                                                <GradientStop Color="#C8F0C8" Offset="0.49"/>
                                                <GradientStop Color="#508050" Offset="0.50"/>
                                                <GradientStop Color="#508050" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Border x:Name="FaceBorder" CornerRadius="2" Padding="4"
                                                Background="{StaticResource PayFace}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Border>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource PayHover}"/>
                                        <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource PayPress}"/>
                                        <Setter TargetName="InnerBorder" Property="BorderBrush">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#508050" Offset="0"/>
                                                    <GradientStop Color="#508050" Offset="0.49"/>
                                                    <GradientStop Color="#C8F0C8" Offset="0.50"/>
                                                    <GradientStop Color="#C8F0C8" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Content>✅  PAY</Button.Content>
                    </Button>
                </Grid>
            </Grid>
        </Grid>

        <!-- ══ ROW 3 — FOOTER ══ -->
        <Border Grid.Row="3" Background="{StaticResource FooterBrush}"
                BorderBrush="#D0D0D0" BorderThickness="0,1,0,0"
                Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Label Content="ITEMS:" Foreground="#888888" FontFamily="Segoe UI, Tahoma" FontSize="11" FontWeight="Bold" VerticalContentAlignment="Center" Padding="0,0,4,0"/>
                    <Label x:Name="lblFooterItems" Content="0" Foreground="#1A1A1A" FontFamily="Segoe UI, Tahoma" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center" Padding="0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Label Content="QTY:" Foreground="#888888" FontFamily="Segoe UI, Tahoma" FontSize="11" FontWeight="Bold" VerticalContentAlignment="Center" Padding="0,0,4,0"/>
                    <Label x:Name="lblFooterQty" Content="0" Foreground="#1A1A1A" FontFamily="Segoe UI, Tahoma" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center" Padding="0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Label Content="DISCOUNT:" Foreground="#888888" FontFamily="Segoe UI, Tahoma" FontSize="11" FontWeight="Bold" VerticalContentAlignment="Center" Padding="0,0,4,0"/>
                    <Label x:Name="lblFooterDiscount" Content="LBP 0" Foreground="#A0520A" FontFamily="Segoe UI, Tahoma" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center" Padding="0"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Label Content="SUBTOTAL:" Foreground="#888888" FontFamily="Segoe UI, Tahoma" FontSize="11" FontWeight="Bold" VerticalContentAlignment="Center" Padding="0,0,4,0"/>
                    <Label x:Name="lblFooterSubtotal" Content="LBP 0" Foreground="#1A1A1A" FontFamily="Segoe UI, Tahoma" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center" Padding="0"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Label x:Name="lblCustomerFooter" Content="" Foreground="#2B6CC4" FontFamily="Segoe UI, Tahoma" FontSize="12" FontWeight="Bold" VerticalContentAlignment="Center" Padding="0"/>
                </StackPanel>

                <!-- NET PAY with USD below -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <Label Content="NET PAY:" Foreground="#888888" FontFamily="Segoe UI, Tahoma" FontSize="12" FontWeight="Bold" VerticalContentAlignment="Center" Padding="0,0,6,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <Label x:Name="lblFooterTotal" Content="LBP 0" Foreground="#1A7A1A" FontFamily="Segoe UI, Tahoma" FontSize="20" FontWeight="Bold" VerticalContentAlignment="Center" Padding="0"/>
                        <Label x:Name="lblFooterTotalUSD" Content="$0.00" Foreground="#5F5F5F" FontFamily="Segoe UI, Tahoma" FontSize="11" FontWeight="SemiBold" VerticalContentAlignment="Center" Padding="0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>