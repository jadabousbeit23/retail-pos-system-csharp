<Window x:Class="POSSystem.Windows.AdvancedReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Advanced Reports"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <!--
    ═══════════════════════════════════════════════════════════
      CLASSIC WINDOWS LIGHT THEME  — matches FastSalesWindow
        Page bg       : #F0F0F0
        Surface       : #FAFAFA / #FFFFFF
        Header        : soft sky-blue gradient
        Button face   : #FDFDFD → #E8E8E8 (gradient + bevel)
        Accent blue   : #2B6CC4
        Green         : #1A7A1A
        Amber         : #A0520A
        Red           : #B00000
        Text primary  : #1A1A1A
        Text muted    : #555555
        Text subtle   : #888888
    ═══════════════════════════════════════════════════════════
    -->

    <Window.Resources>

        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header sky-blue gradient -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Tab/toolbar strip -->
        <LinearGradientBrush x:Key="ToolBarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F4F4F4" Offset="0"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <!-- Card/panel surface -->
        <LinearGradientBrush x:Key="CardBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#F4F4F4" Offset="1"/>
        </LinearGradientBrush>

        <!-- Column header -->
        <LinearGradientBrush x:Key="ColHeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F8F8F8" Offset="0"/>
            <GradientStop Color="#E4E4E4" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brushes -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- Standard raised bevel button -->
        <Style x:Key="ClassicBtn" TargetType="Button">
            <Setter Property="FontFamily"      Value="Segoe UI, Tahoma"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="#1A1A1A"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder" BorderBrush="#B8B8B8" BorderThickness="1" CornerRadius="3">
                            <Border x:Name="InnerBorder" BorderBrush="{StaticResource BevelNormal}" BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder" Background="{StaticResource BtnFace}" CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder"  Property="Background"  Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder"  Property="Background"  Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Coloured action button (blue, green, etc.) -->
        <Style x:Key="ActionBtn" TargetType="Button" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Height"  Value="30"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Tab button — inactive -->
        <Style x:Key="TabBtn" TargetType="Button" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Height"     Value="32"/>
            <Setter Property="Padding"    Value="18,0"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
        </Style>

        <!-- Tab button — active (blue pill badge) -->
        <Style x:Key="TabBtnActive" TargetType="Button">
            <Setter Property="Height"     Value="32"/>
            <Setter Property="Padding"    Value="18,0"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder" BorderBrush="#1A5AA0" BorderThickness="1" CornerRadius="3">
                            <Border x:Name="FaceBorder" CornerRadius="2" Padding="{TemplateBinding Padding}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#4A90D9" Offset="0"/>
                                        <GradientStop Color="#2B6CC4" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListView rows -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground"      Value="#1A1A1A"/>
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"     Value="#EBEBEB"/>
            <Setter Property="Padding"         Value="4,5"/>
            <Setter Property="FontFamily"      Value="Segoe UI, Tahoma"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                    <Setter Property="Foreground" Value="#1A3A8A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                    <Setter Property="Foreground" Value="#0A2060"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- GridViewColumnHeader -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"      Value="{StaticResource ColHeaderBrush}"/>
            <Setter Property="Foreground"      Value="#555555"/>
            <Setter Property="FontFamily"      Value="Segoe UI, Tahoma"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="BorderBrush"     Value="#C8C8C8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding"         Value="8,5"/>
        </Style>

    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title bar -->
            <RowDefinition Height="Auto"/>
            <!-- Tabs -->
            <RowDefinition Height="Auto"/>
            <!-- Summary cards -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════ -->
        <!-- TITLE BAR — sky-blue gradient                   -->
        <!-- ══════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title badge -->
                <Border Grid.Column="0"
                        BorderBrush="#B8B8B8" BorderThickness="1" CornerRadius="3"
                        Margin="0,0,12,0">
                    <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1" CornerRadius="2">
                        <Border CornerRadius="1" Padding="14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#4A90D9" Offset="0"/>
                                    <GradientStop Color="#2B6CC4" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Label Content="📊" FontSize="16" Padding="0,0,6,0"
                                       VerticalContentAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <Label Content="Advanced Reports"
                                           FontFamily="Segoe UI, Tahoma" FontSize="13" FontWeight="Bold"
                                           Foreground="White" Padding="0"/>
                                    <Label x:Name="lblSubtitle"
                                           Content="Profit · Best Sellers · Hourly Analysis"
                                           FontFamily="Segoe UI, Tahoma" FontSize="10"
                                           Foreground="#C8DCFA" Padding="0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Border>
                </Border>

                <!-- Date range filter -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,10,0">
                    <Label Content="From:" Foreground="#555555"
                           FontFamily="Segoe UI, Tahoma" FontSize="12"
                           VerticalContentAlignment="Center" Padding="0,0,6,0"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1" Width="110">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtDateFrom" BorderThickness="0"
                                     FontFamily="Segoe UI, Tahoma" FontSize="12"
                                     Padding="6,4" Foreground="#1A1A1A"
                                     Background="#FFFFFF"
                                     ToolTip="dd/MM/yyyy"/>
                        </Border>
                    </Border>
                    <Label Content="To:" Foreground="#555555"
                           FontFamily="Segoe UI, Tahoma" FontSize="12"
                           VerticalContentAlignment="Center" Padding="10,0,6,0"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1" Width="110">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtDateTo" BorderThickness="0"
                                     FontFamily="Segoe UI, Tahoma" FontSize="12"
                                     Padding="6,4" Foreground="#1A1A1A"
                                     Background="#FFFFFF"
                                     ToolTip="dd/MM/yyyy"/>
                        </Border>
                    </Border>

                    <!-- Apply -->
                    <Border BorderBrush="#1A5AA0" BorderThickness="1" CornerRadius="3" Margin="8,0,0,0">
                        <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1" CornerRadius="2">
                            <Border CornerRadius="1" Padding="12,4">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#4A90D9" Offset="0"/>
                                        <GradientStop Color="#2B6CC4" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Button Content="🔍 Apply"
                                        BorderThickness="0" Background="Transparent"
                                        Foreground="White" FontFamily="Segoe UI, Tahoma"
                                        FontSize="12" FontWeight="Bold" Cursor="Hand"
                                        Click="btnApplyFilter_Click"/>
                            </Border>
                        </Border>
                    </Border>

                    <Button Content="Clear" Margin="6,0,0,0"
                            Style="{StaticResource ActionBtn}"
                            Padding="12,0" Foreground="#555555"
                            Click="btnClearFilter_Click"/>
                </StackPanel>

                <!-- Export Excel -->
                <Border Grid.Column="3"
                        BorderBrush="#0F5A0F" BorderThickness="1" CornerRadius="3"
                        Margin="0,0,8,0">
                    <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1" CornerRadius="2">
                        <Border CornerRadius="1" Padding="12,4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#2A9A2A" Offset="0"/>
                                    <GradientStop Color="#1A7A1A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Button Content="📥 Export Excel"
                                    BorderThickness="0" Background="Transparent"
                                    Foreground="White" FontFamily="Segoe UI, Tahoma"
                                    FontSize="12" FontWeight="Bold" Cursor="Hand"
                                    Click="btnExportExcel_Click"/>
                        </Border>
                    </Border>
                </Border>

                <!-- Close -->
                <Button Grid.Column="4" Content="✕ Close"
                        Style="{StaticResource ActionBtn}"
                        Padding="14,0" Foreground="#B00000"
                        Click="btnClose_Click"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════ -->
        <!-- TAB BUTTONS                                     -->
        <!-- ══════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource ToolBarBrush}"
                BorderBrush="#C8C8C8" BorderThickness="0,0,0,1"
                Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnTabProfit"
                        Content="💰  Profit Report"
                        Style="{StaticResource TabBtnActive}"
                        Margin="0,0,5,0"
                        Click="btnTab_Click"/>
                <Button x:Name="btnTabBestSellers"
                        Content="🏆  Best Sellers"
                        Style="{StaticResource TabBtn}"
                        Margin="0,0,5,0"
                        Click="btnTab_Click"/>
                <Button x:Name="btnTabHourly"
                        Content="⏰  Hourly Analysis"
                        Style="{StaticResource TabBtn}"
                        Click="btnTab_Click"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════ -->
        <!-- SUMMARY CARDS                                   -->
        <!-- ══════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="12,10,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Revenue -->
            <Border Grid.Column="0"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="#C0C0C0" BorderThickness="1"
                    CornerRadius="3" Padding="14,10" Margin="0,0,5,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.10" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <Label Content="TOTAL REVENUE"
                           FontFamily="Segoe UI, Tahoma" FontSize="9" FontWeight="Bold"
                           Foreground="#888888" Padding="0"/>
                    <Label x:Name="lblTotalRevenue" Content="LBP 0"
                           FontFamily="Segoe UI, Tahoma" FontSize="20" FontWeight="Bold"
                           Foreground="#2B6CC4" Padding="0"/>
                    <Label x:Name="lblRevenueRange" Content="All time"
                           FontFamily="Segoe UI, Tahoma" FontSize="10"
                           Foreground="#888888" Padding="0"/>
                </StackPanel>
            </Border>

            <!-- Total Cost -->
            <Border Grid.Column="1"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="#C0C0C0" BorderThickness="1"
                    CornerRadius="3" Padding="14,10" Margin="0,0,5,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.10" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <Label Content="TOTAL COST"
                           FontFamily="Segoe UI, Tahoma" FontSize="9" FontWeight="Bold"
                           Foreground="#888888" Padding="0"/>
                    <Label x:Name="lblTotalCost" Content="LBP 0"
                           FontFamily="Segoe UI, Tahoma" FontSize="20" FontWeight="Bold"
                           Foreground="#A0520A" Padding="0"/>
                    <Label Content="Sum of cost prices sold"
                           FontFamily="Segoe UI, Tahoma" FontSize="10"
                           Foreground="#888888" Padding="0"/>
                </StackPanel>
            </Border>

            <!-- Net Profit -->
            <Border Grid.Column="2"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="#C0C0C0" BorderThickness="1"
                    CornerRadius="3" Padding="14,10" Margin="0,0,5,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.10" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <Label Content="NET PROFIT"
                           FontFamily="Segoe UI, Tahoma" FontSize="9" FontWeight="Bold"
                           Foreground="#888888" Padding="0"/>
                    <Label x:Name="lblNetProfit" Content="LBP 0"
                           FontFamily="Segoe UI, Tahoma" FontSize="20" FontWeight="Bold"
                           Foreground="#1A7A1A" Padding="0"/>
                    <Label x:Name="lblMarginPct" Content="0% margin"
                           FontFamily="Segoe UI, Tahoma" FontSize="10"
                           Foreground="#888888" Padding="0"/>
                </StackPanel>
            </Border>

            <!-- Total Sales -->
            <Border Grid.Column="3"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="#C0C0C0" BorderThickness="1"
                    CornerRadius="3" Padding="14,10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.10" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <Label Content="TOTAL SALES"
                           FontFamily="Segoe UI, Tahoma" FontSize="9" FontWeight="Bold"
                           Foreground="#888888" Padding="0"/>
                    <Label x:Name="lblTotalSales" Content="0"
                           FontFamily="Segoe UI, Tahoma" FontSize="20" FontWeight="Bold"
                           Foreground="#1A1A1A" Padding="0"/>
                    <Label x:Name="lblAvgSale" Content="LBP 0 avg"
                           FontFamily="Segoe UI, Tahoma" FontSize="10"
                           Foreground="#888888" Padding="0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════ -->
        <!-- CONTENT AREA                                    -->
        <!-- ══════════════════════════════════════════════ -->
        <Grid Grid.Row="3" Margin="12,10,12,10">

            <!-- ── TAB 1: PROFIT REPORT ── -->
            <Grid x:Name="tabProfit" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <!-- Product profit table -->
                <Border Grid.Column="0"
                        Background="#FFFFFF"
                        BorderBrush="#C0C0C0" BorderThickness="1"
                        CornerRadius="3" Margin="0,0,8,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.10" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource ColHeaderBrush}"
                                BorderBrush="#C8C8C8" BorderThickness="0,0,0,1"
                                CornerRadius="3,3,0,0" Padding="12,7">
                            <Label Content="Profit by Product"
                                   FontFamily="Segoe UI, Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A1A1A" Padding="0"/>
                        </Border>
                        <ListView Grid.Row="1" x:Name="lvProfit"
                                  Background="Transparent" BorderThickness="0"
                                  FontFamily="Segoe UI, Tahoma">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Product"  Width="180" DisplayMemberBinding="{Binding ProductName}"/>
                                    <GridViewColumn Header="Qty Sold" Width="80"  DisplayMemberBinding="{Binding QtySold}"/>
                                    <GridViewColumn Header="Revenue"  Width="120" DisplayMemberBinding="{Binding RevenueDisplay}"/>
                                    <GridViewColumn Header="Cost"     Width="120" DisplayMemberBinding="{Binding CostDisplay}"/>
                                    <GridViewColumn Header="Profit"   Width="120" DisplayMemberBinding="{Binding ProfitDisplay}"/>
                                    <GridViewColumn Header="Margin"   Width="80">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding MarginColor}"
                                                        BorderBrush="#A0A0A0" BorderThickness="1"
                                                        CornerRadius="2" Padding="6,2">
                                                    <TextBlock Text="{Binding MarginDisplay}"
                                                               FontFamily="Segoe UI, Tahoma"
                                                               Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Daily profit breakdown -->
                <Border Grid.Column="1"
                        Background="#FFFFFF"
                        BorderBrush="#C0C0C0" BorderThickness="1"
                        CornerRadius="3">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.10" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource ColHeaderBrush}"
                                BorderBrush="#C8C8C8" BorderThickness="0,0,0,1"
                                CornerRadius="3,3,0,0" Padding="12,7">
                            <Label Content="Daily Profit Breakdown"
                                   FontFamily="Segoe UI, Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A1A1A" Padding="0"/>
                        </Border>
                        <ListView Grid.Row="1" x:Name="lvDailyProfit"
                                  Background="Transparent" BorderThickness="0"
                                  FontFamily="Segoe UI, Tahoma">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Date"    Width="100" DisplayMemberBinding="{Binding Date}"/>
                                    <GridViewColumn Header="Revenue" Width="110" DisplayMemberBinding="{Binding RevenueDisplay}"/>
                                    <GridViewColumn Header="Profit"  Width="110" DisplayMemberBinding="{Binding ProfitDisplay}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── TAB 2: BEST SELLERS ── -->
            <Grid x:Name="tabBestSellers" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#FFFFFF"
                        BorderBrush="#C0C0C0" BorderThickness="1"
                        CornerRadius="3" Margin="0,0,8,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.10" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource ColHeaderBrush}"
                                BorderBrush="#C8C8C8" BorderThickness="0,0,0,1"
                                CornerRadius="3,3,0,0" Padding="12,7">
                            <Label Content="🏆  Top 10 by Quantity Sold"
                                   FontFamily="Segoe UI, Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A1A1A" Padding="0"/>
                        </Border>
                        <ListView Grid.Row="1" x:Name="lvBestQty"
                                  Background="Transparent" BorderThickness="0"
                                  FontFamily="Segoe UI, Tahoma">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="#"        Width="35"  DisplayMemberBinding="{Binding Rank}"/>
                                    <GridViewColumn Header="Product"  Width="180" DisplayMemberBinding="{Binding ProductName}"/>
                                    <GridViewColumn Header="Category" Width="110" DisplayMemberBinding="{Binding Category}"/>
                                    <GridViewColumn Header="Qty Sold" Width="80"  DisplayMemberBinding="{Binding QtySold}"/>
                                    <GridViewColumn Header="Revenue"  Width="120" DisplayMemberBinding="{Binding RevenueDisplay}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="#FFFFFF"
                        BorderBrush="#C0C0C0" BorderThickness="1"
                        CornerRadius="3">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.10" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource ColHeaderBrush}"
                                BorderBrush="#C8C8C8" BorderThickness="0,0,0,1"
                                CornerRadius="3,3,0,0" Padding="12,7">
                            <Label Content="💰  Top 10 by Revenue"
                                   FontFamily="Segoe UI, Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A1A1A" Padding="0"/>
                        </Border>
                        <ListView Grid.Row="1" x:Name="lvBestRevenue"
                                  Background="Transparent" BorderThickness="0"
                                  FontFamily="Segoe UI, Tahoma">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="#"        Width="35"  DisplayMemberBinding="{Binding Rank}"/>
                                    <GridViewColumn Header="Product"  Width="180" DisplayMemberBinding="{Binding ProductName}"/>
                                    <GridViewColumn Header="Category" Width="110" DisplayMemberBinding="{Binding Category}"/>
                                    <GridViewColumn Header="Qty Sold" Width="80"  DisplayMemberBinding="{Binding QtySold}"/>
                                    <GridViewColumn Header="Revenue"  Width="120" DisplayMemberBinding="{Binding RevenueDisplay}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── TAB 3: HOURLY ANALYSIS ── -->
            <Grid x:Name="tabHourly" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Legend -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Label Content="Colour intensity = number of sales that hour"
                           FontFamily="Segoe UI, Tahoma" Foreground="#555555" FontSize="11"
                           VerticalContentAlignment="Center" Padding="0,0,14,0"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1"
                            Width="18" Height="18" Margin="0,0,4,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#EEF4FF" Offset="0"/>
                                <GradientStop Color="#C8DBFA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Label Content="Low" FontFamily="Segoe UI, Tahoma" FontSize="11"
                           Foreground="#555555" VerticalContentAlignment="Center" Padding="0,0,12,0"/>
                    <Border BorderBrush="#1A5AA0" BorderThickness="1"
                            Width="18" Height="18" Margin="0,0,4,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#4A90D9" Offset="0"/>
                                <GradientStop Color="#2B6CC4" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Label Content="High" FontFamily="Segoe UI, Tahoma" FontSize="11"
                           Foreground="#555555" VerticalContentAlignment="Center" Padding="0"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#FFFFFF"
                            BorderBrush="#C0C0C0" BorderThickness="1"
                            CornerRadius="3" Margin="0,0,8,0" Padding="12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.10" Color="#000000"/>
                        </Border.Effect>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid x:Name="heatmapGrid"/>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#FFFFFF"
                            BorderBrush="#C0C0C0" BorderThickness="1"
                            CornerRadius="3">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.10" Color="#000000"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource ColHeaderBrush}"
                                    BorderBrush="#C8C8C8" BorderThickness="0,0,0,1"
                                    CornerRadius="3,3,0,0" Padding="12,7">
                                <Label Content="Sales by Hour"
                                       FontFamily="Segoe UI, Tahoma" FontSize="12" FontWeight="Bold"
                                       Foreground="#1A1A1A" Padding="0"/>
                            </Border>
                            <ListView Grid.Row="1" x:Name="lvHourly"
                                      Background="Transparent" BorderThickness="0"
                                      FontFamily="Segoe UI, Tahoma">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Hour"    Width="80"  DisplayMemberBinding="{Binding HourLabel}"/>
                                        <GridViewColumn Header="Sales"   Width="60"  DisplayMemberBinding="{Binding SalesCount}"/>
                                        <GridViewColumn Header="Revenue" Width="130" DisplayMemberBinding="{Binding RevenueDisplay}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════ -->
        <!-- STATUS BAR                                      -->
        <!-- ══════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{StaticResource ToolBarBrush}"
                BorderBrush="#C8C8C8" BorderThickness="0,1,0,0"
                Padding="14,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="lblStatus" Content="Ready"
                       FontFamily="Segoe UI, Tahoma" Foreground="#555555" FontSize="11" Padding="0"/>
                <Label Grid.Column="1" x:Name="lblDbStatus" Content="🟢 Local DB"
                       FontFamily="Segoe UI, Tahoma" Foreground="#1A7A1A"
                       FontSize="11" FontWeight="Bold" Padding="0"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border x:Name="loadingOverlay" 
                Grid.Row="0" Grid.RowSpan="5"
                Background="#F0F0F0" 
                Opacity="0.85"
                Visibility="Collapsed"
                Panel.ZIndex="9999">
            <Grid>
                <Border Width="320" Height="120" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Background="#FAFAFA"
                        BorderBrush="#B8B8B8" 
                        BorderThickness="1"
                        CornerRadius="4">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="4" Opacity="0.15" Color="#000000"/>
                    </Border.Effect>

                    <Border BorderBrush="#FFFFFF" BorderThickness="1" CornerRadius="3">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="lblLoadingMessage" 
                                       Text="Processing..." 
                                       FontFamily="Segoe UI, Tahoma"
                                       FontSize="14" 
                                       FontWeight="SemiBold"
                                       Foreground="#1A1A1A"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,15"/>

                            <Border Grid.Row="1" 
                                    Height="24" 
                                    Background="#E8E8E8"
                                    BorderBrush="#99AABB" 
                                    BorderThickness="1"
                                    CornerRadius="2">
                                <Border BorderBrush="#FFFFFF" BorderThickness="1" CornerRadius="1">
                                    <ProgressBar IsIndeterminate="True"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="#2B6CC4"/>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>