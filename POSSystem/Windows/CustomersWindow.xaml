<Window x:Class="POSSystem.Windows.CustomersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Management"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>
        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                    <Setter Property="Foreground" Value="#2B6CC4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 3D Bevel Button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="15,12" Margin="20,20,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0"
                       Content="👥  Customer Management"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#2B6CC4" Padding="0"
                       FontFamily="Segoe UI, Tahoma"/>
                <Border Grid.Column="1" Background="#2B6CC4"
                        CornerRadius="4" Padding="12,4"
                        Margin="0,0,8,0" VerticalAlignment="Center">
                    <Label x:Name="lblCustomerCount"
                           Content="0 customers"
                           Foreground="White" FontSize="12"
                           FontWeight="Bold" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </Border>
                <Button Grid.Column="2"
                        Content="🖨️ Print Card"
                        Width="120" Height="34"
                        Style="{StaticResource BigBtn}"
                        Click="btnPrintCard_Click"/>
            </Grid>
        </Border>

        <!-- FORM -->
        <Border Grid.Row="1" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1"
                Padding="15,12" Margin="20,0,20,12">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <Label Content="CUSTOMER NAME" FontSize="10"
                               Foreground="#555555" FontWeight="Bold"
                               Padding="0" Margin="0,0,0,4"
                               FontFamily="Segoe UI, Tahoma"/>
                        <Border BorderBrush="#99AABB" BorderThickness="1">
                            <Border BorderBrush="#FFFFFF" BorderThickness="1">
                                <TextBox x:Name="txtCustName" Background="#FFFFFF"
                                         Foreground="#1A1A1A" BorderThickness="0"
                                         FontSize="13" Padding="8,7" CaretBrush="#2B6CC4"
                                         FontFamily="Segoe UI, Tahoma"/>
                            </Border>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <Label Content="PHONE" FontSize="10"
                               Foreground="#555555" FontWeight="Bold"
                               Padding="0" Margin="0,0,0,4"
                               FontFamily="Segoe UI, Tahoma"/>
                        <Border BorderBrush="#99AABB" BorderThickness="1">
                            <Border BorderBrush="#FFFFFF" BorderThickness="1">
                                <TextBox x:Name="txtCustPhone" Background="#FFFFFF"
                                         Foreground="#1A1A1A" BorderThickness="0"
                                         FontSize="13" Padding="8,7" CaretBrush="#2B6CC4"
                                         FontFamily="Segoe UI, Tahoma"/>
                            </Border>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                        <Label Content="EMAIL" FontSize="10"
                               Foreground="#555555" FontWeight="Bold"
                               Padding="0" Margin="0,0,0,4"
                               FontFamily="Segoe UI, Tahoma"/>
                        <Border BorderBrush="#99AABB" BorderThickness="1">
                            <Border BorderBrush="#FFFFFF" BorderThickness="1">
                                <TextBox x:Name="txtCustEmail" Background="#FFFFFF"
                                         Foreground="#1A1A1A" BorderThickness="0"
                                         FontSize="13" Padding="8,7" CaretBrush="#2B6CC4"
                                         FontFamily="Segoe UI, Tahoma"/>
                            </Border>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <Label Content="NOTES" FontSize="10"
                               Foreground="#555555" FontWeight="Bold"
                               Padding="0" Margin="0,0,0,4"
                               FontFamily="Segoe UI, Tahoma"/>
                        <Border BorderBrush="#99AABB" BorderThickness="1">
                            <Border BorderBrush="#FFFFFF" BorderThickness="1">
                                <TextBox x:Name="txtCustNotes" Background="#FFFFFF"
                                         Foreground="#1A1A1A" BorderThickness="0"
                                         FontSize="13" Padding="8,7" CaretBrush="#2B6CC4"
                                         FontFamily="Segoe UI, Tahoma"/>
                            </Border>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" x:Name="lblMessage"
                           Content="" FontSize="12" FontWeight="Bold"
                           Padding="0" VerticalContentAlignment="Center"
                           Foreground="#B71C1C"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Button Grid.Column="1" Content="➕ Add"
                            Width="90" Height="34" Margin="0,0,6,0"
                            Style="{StaticResource BigBtn}"
                            Click="btnAddCustomer_Click"/>
                    <Button Grid.Column="2" Content="✏️ Update"
                            Width="100" Height="34" Margin="0,0,6,0"
                            Style="{StaticResource BigBtn}"
                            Click="btnUpdateCustomer_Click"/>
                    <Button Grid.Column="3" Content="🏷️ Add Points"
                            Width="110" Height="34" Margin="0,0,6,0"
                            Style="{StaticResource BigBtn}"
                            Click="btnAddPoints_Click"/>
                    <Button Grid.Column="4" Content="🗑️ Delete"
                            Width="90" Height="34"
                            Style="{StaticResource BigBtn}"
                            Click="btnDeleteCustomer_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- SEARCH + SCAN -->
        <Border Grid.Row="2" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1"
                Padding="12,8" Margin="20,0,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="#99AABB" BorderThickness="1"
                        Margin="0,0,8,0">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <TextBox x:Name="txtSearch"
                                 Background="#FFFFFF" Foreground="#1A1A1A"
                                 BorderThickness="0" FontSize="13" Padding="8,7"
                                 CaretBrush="#2B6CC4"
                                 ToolTip="Search by name, phone or email"
                                 TextChanged="txtSearch_TextChanged"
                                 FontFamily="Segoe UI, Tahoma"/>
                    </Border>
                </Border>

                <Border Grid.Column="1" BorderBrush="#2E7D32" BorderThickness="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="📷"
                               Foreground="#2E7D32" FontSize="14"
                               VerticalContentAlignment="Center" Padding="6,0"/>
                        <TextBox Grid.Column="1" x:Name="txtScanCard"
                                 Background="#FFFFFF" Foreground="#2E7D32"
                                 BorderThickness="0" FontSize="13" Padding="6,7"
                                 CaretBrush="#2E7D32"
                                 ToolTip="Scan loyalty card"
                                 KeyDown="txtScanCard_KeyDown"
                                 FontFamily="Segoe UI, Tahoma"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- LIST -->
        <Border Grid.Row="3" Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="1"
                Padding="5" Margin="20,0,20,12">
            <ListView x:Name="lvCustomers"
                      Background="Transparent" Foreground="#1A1A1A"
                      BorderThickness="0"
                      SelectionChanged="lvCustomers_SelectionChanged"
                      FontFamily="Segoe UI, Tahoma">
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="#F5F5F5"/>
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
                                <Setter Property="BorderBrush" Value="#D0D0D0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding" Value="8,6"/>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Header="ID" Width="45"
                            DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="Name" Width="170"
                            DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Phone" Width="120"
                            DisplayMemberBinding="{Binding Phone}"/>
                        <GridViewColumn Header="Email" Width="180"
                            DisplayMemberBinding="{Binding Email}"/>
                        <GridViewColumn Header="Points" Width="70"
                            DisplayMemberBinding="{Binding Points}"/>
                        <GridViewColumn Header="Stamps" Width="65"
                            DisplayMemberBinding="{Binding Stamps}"/>
                        <GridViewColumn Header="Total Spent" Width="120"
                            DisplayMemberBinding="{Binding TotalSpentDisplay}"/>
                        <GridViewColumn Header="Card Code" Width="140"
                            DisplayMemberBinding="{Binding LoyaltyCode}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- CLOSE -->
        <Button Grid.Row="4" Content="✕  Close"
                Height="40" Margin="20,0,20,16"
                Style="{StaticResource BigBtn}"
                Click="btnClose_Click"/>
    </Grid>
</Window>