<Window x:Class="POSSystem.Windows.ZReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Z-Report (End of Day)" 
        Width="750" Height="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F0F0"
        FontFamily="Segoe UI, Tahoma">

    <Window.Resources>

        <!-- Button face gradient -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header - soft sky blue -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- 3D Bevel Button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="#D0D0D0"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Day button - Red accent with 3D effect -->
        <Style x:Key="CloseDayBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#A02015" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="#C42B1C"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="#A82015"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#801010"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="#801810"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F0F0" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
            <RowDefinition Height="*"/>
            <!-- Report Content -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="20,16">
            <StackPanel>
                <Label Content="🔒  Z-REPORT (END OF DAY)" 
                       FontSize="26" FontWeight="Bold"
                       Foreground="#2B6CC4" Padding="0"
                       HorizontalAlignment="Center"
                       FontFamily="Segoe UI, Tahoma"/>
                <Label x:Name="lblDate" Content="Date: --"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="#555555" 
                       Padding="0,4,0,0" HorizontalAlignment="Center"
                       FontFamily="Segoe UI, Tahoma"/>
            </StackPanel>
        </Border>

        <!-- ══ WARNING BANNER ══ -->
        <Border Grid.Row="1" Background="#FFF3E0" 
                BorderBrush="#FFB74D" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="⚠️" FontSize="24" 
                           Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" 
                           Text="WARNING: Closing the day will archive all sales data to Monthly/Yearly reports and reset daily counters. This action cannot be undone."
                           TextWrapping="Wrap"
                           Foreground="#E65100" FontSize="13" FontWeight="SemiBold"
                           FontFamily="Segoe UI, Tahoma"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══ REPORT CONTENT ══ -->
        <Border Grid.Row="2" Background="#FAFAFA" 
                BorderBrush="#C0C0C0" BorderThickness="0,1"
                Margin="20,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="24">
                <StackPanel x:Name="spZReport">
                    <!-- Content generated in code -->
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ══ BUTTONS ══ -->
        <Border Grid.Row="3" Background="#F5F5F5"
                BorderBrush="#D0D0D0" BorderThickness="0,1,0,0"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="btnPrint" 
                        Content="🖨️  Print Report" 
                        Style="{StaticResource BigBtn}" 
                        Margin="0,0,8,0"
                        HorizontalAlignment="Left"
                        Click="btnPrint_Click"/>
                <Button Grid.Column="1" x:Name="btnSavePdf"
                        Content="📄  Save PDF" 
                        Style="{StaticResource BigBtn}" 
                        Margin="0,0,8,0"
                        Click="btnSavePdf_Click"/>
                <Button Grid.Column="2" x:Name="btnCancel"
                        Content="✕  Cancel" 
                        Style="{StaticResource BigBtn}" 
                        Margin="0,0,12,0"
                        IsCancel="True" 
                        Click="btnCancel_Click"/>
                <Button Grid.Column="3" x:Name="btnCloseDay"
                        Content="🔒  CLOSE DAY" 
                        Style="{StaticResource CloseDayBtn}"
                        Click="btnCloseDay_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>