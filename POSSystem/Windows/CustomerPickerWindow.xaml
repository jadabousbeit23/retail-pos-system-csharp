<Window x:Class="POSSystem.Windows.CustomerPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Customer"
        Height="500" Width="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <Window.Resources>
        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,7"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 3D Bevel Button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="14,12" Margin="14,14,14,10">
            <Label Content="👤  Select Customer"
                   FontSize="18" FontWeight="Bold"
                   Foreground="#2B6CC4" Padding="0"
                   FontFamily="Segoe UI, Tahoma"/>
        </Border>

        <Grid Grid.Row="1" Margin="14,0,14,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="210"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="#99AABB" BorderThickness="1"
                    Margin="0,0,8,0">
                <Border BorderBrush="#FFFFFF" BorderThickness="1">
                    <TextBox x:Name="txtSearch"
                             Background="#FFFFFF" Foreground="#1A1A1A"
                             BorderThickness="0" FontSize="13" Padding="8,7"
                             CaretBrush="#2B6CC4"
                             ToolTip="Search by name or phone"
                             TextChanged="txtSearch_TextChanged"
                             FontFamily="Segoe UI, Tahoma"/>
                </Border>
            </Border>
            <Border Grid.Column="1" BorderBrush="#2E7D32" BorderThickness="2">
                <Border BorderBrush="#FFFFFF" BorderThickness="1">
                    <TextBox x:Name="txtScanCard"
                             Background="#FFFFFF" Foreground="#2E7D32"
                             BorderThickness="0" FontSize="13" Padding="8,7"
                             CaretBrush="#2E7D32"
                             ToolTip="📷 Scan loyalty card"
                             KeyDown="txtScanCard_KeyDown"
                             FontFamily="Segoe UI, Tahoma"/>
                </Border>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="1"
                Margin="14,0,14,10">
            <ListView x:Name="lvCustomers"
                      Background="Transparent" BorderThickness="0"
                      MouseDoubleClick="lvCustomers_MouseDoubleClick"
                      FontFamily="Segoe UI, Tahoma">
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="#F5F5F5"/>
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
                                <Setter Property="BorderBrush" Value="#D0D0D0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding" Value="8,6"/>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Header="Name" Width="160"
                            DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Phone" Width="110"
                            DisplayMemberBinding="{Binding Phone}"/>
                        <GridViewColumn Header="Points" Width="70"
                            DisplayMemberBinding="{Binding Points}"/>
                        <GridViewColumn Header="Stamps" Width="65"
                            DisplayMemberBinding="{Binding Stamps}"/>
                        <GridViewColumn Header="Spent" Width="110"
                            DisplayMemberBinding="{Binding TotalSpentDisplay}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <Label Grid.Row="3" x:Name="lblMsg" Content=""
               Foreground="#B71C1C" FontSize="12" FontWeight="Bold"
               Padding="0" Margin="14,0,14,6"
               FontFamily="Segoe UI, Tahoma"/>

        <Grid Grid.Row="4" Margin="14,0,14,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="✅ Select Customer"
                    Height="40" Margin="0,0,6,0"
                    Style="{StaticResource BigBtn}"
                    Click="btnSelect_Click"/>
            <Button Grid.Column="1" Content="⏩ Skip / No Customer"
                    Height="40" Margin="6,0,0,0"
                    Style="{StaticResource BigBtn}"
                    Click="btnNoCustomer_Click"/>
        </Grid>
    </Grid>
</Window>