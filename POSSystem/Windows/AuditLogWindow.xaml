<Window x:Class="POSSystem.Windows.AuditLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audit Log"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>
        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- 3D Bevel Button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- FIX: ComboBox style with solid white background and clear dropdown items -->
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="Foreground" Value="#1A1A1A"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#EEF4FF"/>
                                <Setter Property="Foreground" Value="#1A3A8A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#C8DBFA"/>
                                <Setter Property="Foreground" Value="#0A2060"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="16,12" Margin="20,20,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Label Content="📋  Audit Log"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#2B6CC4" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label Content="Every action recorded — who did what, when"
                           FontSize="11" Foreground="#555555" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#FFFFFF"
                        BorderBrush="#D0D0D0" BorderThickness="1"
                        CornerRadius="4" Padding="14,4" VerticalAlignment="Center">
                    <Label x:Name="lblCount" Content="0 records"
                           FontSize="12" FontWeight="Bold"
                           Foreground="#555555" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </Border>
            </Grid>
        </Border>

        <!-- FILTERS -->
        <Border Grid.Row="1" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1"
                Padding="16,10" Margin="20,0,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Border Grid.Column="0" BorderBrush="#99AABB" BorderThickness="1"
                        Margin="0,0,8,0">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <TextBox x:Name="txtSearch"
                                 Background="#FFFFFF" Foreground="#1A1A1A"
                                 BorderThickness="0" FontSize="12" Padding="8,6"
                                 ToolTip="Search actions or details"
                                 TextChanged="txtSearch_Changed"
                                 FontFamily="Segoe UI, Tahoma"/>
                    </Border>
                </Border>

                <!-- User filter -->
                <Border Grid.Column="1" BorderBrush="#99AABB" BorderThickness="1"
                        Margin="0,0,8,0">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <ComboBox x:Name="cmbUser" Style="{StaticResource ComboStyle}"
                                  SelectionChanged="Filter_Changed"/>
                    </Border>
                </Border>

                <!-- Module filter -->
                <Border Grid.Column="2" BorderBrush="#99AABB" BorderThickness="1"
                        Margin="0,0,8,0">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <ComboBox x:Name="cmbModule" Style="{StaticResource ComboStyle}"
                                  SelectionChanged="Filter_Changed"/>
                    </Border>
                </Border>

                <!-- Date from -->
                <Border Grid.Column="3" BorderBrush="#99AABB" BorderThickness="1"
                        Margin="0,0,8,0">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <TextBox x:Name="txtDateFrom"
                                 Background="#FFFFFF" Foreground="#1A1A1A"
                                 BorderThickness="0" FontSize="12" Padding="8,6"
                                 ToolTip="From date dd/MM/yyyy"
                                 FontFamily="Segoe UI, Tahoma"/>
                    </Border>
                </Border>

                <!-- Date to -->
                <Border Grid.Column="4" BorderBrush="#99AABB" BorderThickness="1"
                        Margin="0,0,8,0" Width="160">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <TextBox x:Name="txtDateTo"
                                 Background="#FFFFFF" Foreground="#1A1A1A"
                                 BorderThickness="0" FontSize="12" Padding="8,6"
                                 ToolTip="To date dd/MM/yyyy"
                                 FontFamily="Segoe UI, Tahoma"/>
                    </Border>
                </Border>

                <Button Grid.Column="5"
                        Content="🔍 Search"
                        Height="34" Width="90" Margin="0,0,6,0"
                        Style="{StaticResource BigBtn}"
                        Click="btnSearch_Click"/>

                <Button Grid.Column="7"
                        Content="Clear"
                        Height="34" Width="70"
                        Style="{StaticResource BigBtn}"
                        Click="btnClear_Click"/>
            </Grid>
        </Border>

        <!-- LOG LIST -->
        <Border Grid.Row="2" Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="1"
                Margin="20,0,20,0">
            <ListView x:Name="lvLog" Background="Transparent" BorderThickness="0"
                      FontFamily="Segoe UI, Tahoma">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID" Width="60" DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="Time" Width="150" DisplayMemberBinding="{Binding LoggedAt}"/>
                        <GridViewColumn Header="User" Width="120" DisplayMemberBinding="{Binding Username}"/>
                        <GridViewColumn Header="Module" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding ModuleColor}"
                                            CornerRadius="3" Padding="6,2">
                                        <TextBlock Text="{Binding Module}"
                                                   Foreground="White" FontSize="10"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Action" Width="180" DisplayMemberBinding="{Binding Action}"/>
                        <GridViewColumn Header="Details" Width="500" DisplayMemberBinding="{Binding Details}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- FOOTER -->
        <Grid Grid.Row="3" Margin="20,12,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Content="💡 Audit log is admin-only. All sales, voids, user changes, returns and logins are recorded."
                   Foreground="#555555" FontSize="11"
                   VerticalContentAlignment="Center" Padding="0"
                   FontFamily="Segoe UI, Tahoma"/>
            <Button Grid.Column="1" Content="✕  Close"
                    Height="34" Width="90"
                    Style="{StaticResource BigBtn}"
                    Click="btnClose_Click"/>
        </Grid>
    </Grid>
</Window>