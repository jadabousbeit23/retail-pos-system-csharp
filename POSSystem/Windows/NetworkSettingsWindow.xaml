<Window x:Class="POSSystem.Windows.NetworkSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database &amp; Network Settings"
        Height="580" Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <!--
    ═══════════════════════════════════════════════════════════
      CLASSIC WINDOWS LIGHT THEME  — matches FastSalesWindow
      Height 580 / Width 640 — all content fits without clipping.
    ═══════════════════════════════════════════════════════════
    -->

    <Window.Resources>

        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CardBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#F4F4F4" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="InfoBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="FooterBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F4F4F4" Offset="0"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BluePill" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#4A90D9" Offset="0"/>
            <GradientStop Color="#2B6CC4" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GreenPill" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#2A9A2A" Offset="0"/>
            <GradientStop Color="#1A7A1A" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AmberPill" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#CC6A18" Offset="0"/>
            <GradientStop Color="#A0520A" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- Standard raised-bevel button -->
        <Style x:Key="ClassicBtn" TargetType="Button">
            <Setter Property="FontFamily"      Value="Segoe UI, Tahoma"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="#1A1A1A"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder" BorderBrush="#B8B8B8" BorderThickness="1" CornerRadius="3">
                            <Border x:Name="InnerBorder" BorderBrush="{StaticResource BevelNormal}" BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder" Background="{StaticResource BtnFace}"
                                        CornerRadius="1" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder"  Property="Background"  Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder"  Property="Background"  Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Gradient coloured action button -->
        <Style x:Key="PillBtn" TargetType="Button">
            <Setter Property="FontFamily"      Value="Segoe UI, Tahoma"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="12,10">
            <Border BorderBrush="#B8B8B8" BorderThickness="1" CornerRadius="3">
                <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1" CornerRadius="2">
                    <Border CornerRadius="1" Padding="14,8" Background="{StaticResource BluePill}">
                        <StackPanel>
                            <Label Content="🌐  Database &amp; Network Settings"
                                   FontFamily="Segoe UI, Tahoma" FontSize="14" FontWeight="Bold"
                                   Foreground="White" Padding="0"/>
                            <Label Content="Connect all PCs to one shared database on a network drive"
                                   FontFamily="Segoe UI, Tahoma" FontSize="10"
                                   Foreground="#C8DCFA" Padding="0"/>
                        </StackPanel>
                    </Border>
                </Border>
            </Border>
        </Border>

        <!-- CURRENT STATUS -->
        <Border Grid.Row="1"
                Background="{StaticResource CardBrush}"
                BorderBrush="#C0C0C0" BorderThickness="1"
                CornerRadius="3" Margin="12,10,12,0" Padding="14,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.10" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Label Content="CURRENT DATABASE"
                           FontFamily="Segoe UI, Tahoma" FontSize="9" FontWeight="Bold"
                           Foreground="#888888" Padding="0"/>
                    <Label x:Name="lblCurrentPath" Content="Loading…"
                           FontFamily="Segoe UI, Tahoma" FontSize="12" FontWeight="Bold"
                           Foreground="#1A1A1A" Padding="0"/>
                </StackPanel>
                <Border Grid.Column="1" x:Name="statusBadge"
                        Background="{StaticResource GreenPill}"
                        BorderBrush="#0F5A0F" BorderThickness="1"
                        CornerRadius="3" Padding="12,4" VerticalAlignment="Center">
                    <Label x:Name="lblStatus" Content="🟢 Connected"
                           FontFamily="Segoe UI, Tahoma" Foreground="White"
                           FontSize="11" FontWeight="Bold" Padding="0"/>
                </Border>
            </Grid>
        </Border>

        <!-- NETWORK PATH -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBrush}"
                BorderBrush="#C0C0C0" BorderThickness="1"
                CornerRadius="3" Margin="12,8,12,0" Padding="14,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.10" Color="#000000"/>
            </Border.Effect>
            <StackPanel>
                <Label Content="SET NETWORK DATABASE PATH"
                       FontFamily="Segoe UI, Tahoma" FontSize="9" FontWeight="Bold"
                       Foreground="#888888" Padding="0" Margin="0,0,0,6"/>
                <Label Content="Enter the path to the shared .db file on your network drive:"
                       FontFamily="Segoe UI, Tahoma" FontSize="12" Foreground="#1A1A1A"
                       Padding="0" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" BorderBrush="#99AABB" BorderThickness="1" Margin="0,0,6,0">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtNetworkPath"
                                     BorderThickness="0" Background="#FFFFFF"
                                     FontFamily="Segoe UI, Tahoma" FontSize="12"
                                     Padding="7,5" Foreground="#1A1A1A"
                                     ToolTip="Example: \\SERVER\SharedFolder\pos.db"/>
                        </Border>
                    </Border>
                    <Button Grid.Column="1" Content="Browse…"
                            Style="{StaticResource ClassicBtn}"
                            Click="btnBrowse_Click"/>
                </Grid>
                <Label Content="Example: \\192.168.1.10\POSShare\pos.db  or  Z:\POS\pos.db"
                       FontFamily="Segoe UI, Tahoma" FontSize="10" Foreground="#888888"
                       Padding="0" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ACTIONS -->
        <Border Grid.Row="3"
                Background="{StaticResource CardBrush}"
                BorderBrush="#C0C0C0" BorderThickness="1"
                CornerRadius="3" Margin="12,8,12,0" Padding="14,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.10" Color="#000000"/>
            </Border.Effect>
            <StackPanel>
                <Label Content="ACTIONS"
                       FontFamily="Segoe UI, Tahoma" FontSize="9" FontWeight="Bold"
                       Foreground="#888888" Padding="0" Margin="0,0,0,8"/>
                <WrapPanel>
                    <Button Content="🔍 Test Connection"
                            Style="{StaticResource PillBtn}"
                            Background="{StaticResource BluePill}"
                            BorderBrush="#1A5AA0"
                            Margin="0,0,6,0"
                            Click="btnTest_Click"/>
                    <Button Content="✅ Save &amp; Use Network DB"
                            Style="{StaticResource PillBtn}"
                            Background="{StaticResource GreenPill}"
                            BorderBrush="#0F5A0F"
                            Margin="0,0,6,0"
                            Click="btnSave_Click"/>
                    <Button Content="📤 Copy Local → Network"
                            Style="{StaticResource PillBtn}"
                            Background="{StaticResource AmberPill}"
                            BorderBrush="#7A3A00"
                            Margin="0,0,6,0"
                            Click="btnCopyToNetwork_Click"/>
                    <Button Content="🏠 Use Local DB"
                            Style="{StaticResource ClassicBtn}"
                            Foreground="#B00000" FontWeight="Bold"
                            Click="btnUseLocal_Click"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- INFO BOX -->
        <Border Grid.Row="4"
                Background="{StaticResource InfoBrush}"
                BorderBrush="#99AABB" BorderThickness="1"
                CornerRadius="3" Margin="12,8,12,0" Padding="14,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.10" Color="#000000"/>
            </Border.Effect>
            <StackPanel>
                <Label Content="ℹ️  How to set up multi-PC sync"
                       FontFamily="Segoe UI, Tahoma" FontSize="12" FontWeight="Bold"
                       Foreground="#1A3A8A" Padding="0" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="#1A1A1A"
                           FontFamily="Segoe UI, Tahoma" FontSize="11" LineHeight="18">
                    <Run FontWeight="Bold">Step 1:</Run>
                    <Run> On the server PC, create a shared folder (e.g. </Run>
                    <Run FontFamily="Courier New">C:\POSShare</Run>
                    <Run>) and share it on the network.</Run>
                    <LineBreak/>
                    <Run FontWeight="Bold">Step 2:</Run>
                    <Run> Click </Run><Run FontWeight="Bold">Copy Local → Network</Run>
                    <Run> on the main PC to upload your existing data.</Run>
                    <LineBreak/>
                    <Run FontWeight="Bold">Step 3:</Run>
                    <Run> On every other PC, enter the network path (e.g. </Run>
                    <Run FontFamily="Courier New">\\SERVER\POSShare\pos.db</Run>
                    <Run>) and click Save.</Run>
                    <LineBreak/>
                    <Run FontWeight="Bold">Step 4:</Run>
                    <Run> All PCs now read/write the same database in real time.</Run>
                    <LineBreak/><LineBreak/>
                    <Run Foreground="#7A4A00">⚠️ Make sure all PCs have read/write access to the shared folder.
SQLite handles concurrent access — for best results, limit to 3-5 PCs simultaneously.</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- FOOTER -->
        <Border Grid.Row="5"
                Background="{StaticResource FooterBrush}"
                BorderBrush="#C8C8C8" BorderThickness="0,1,0,0"
                Padding="12,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="lblMessage" Content=""
                       FontFamily="Segoe UI, Tahoma" FontSize="12" FontWeight="Bold"
                       Padding="0" VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" Content="Close"
                        Style="{StaticResource ClassicBtn}"
                        Padding="28,0"
                        Click="btnClose_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
