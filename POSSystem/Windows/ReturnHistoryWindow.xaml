<Window x:Class="POSSystem.Windows.ReturnHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Return History"
        Width="920" Height="580"
        WindowStartupLocation="CenterOwner"
        Background="#F0F0F0">

    <!--
    ═══════════════════════════════════════════════════════════
      CLASSIC WINDOWS LIGHT THEME  — softer, airier palette
        Page bg       : #F0F0F0  (standard Win dialog gray)
        Surface       : #FAFAFA
        Button face   : #FDFDFD → #E8E8E8
        Button hover  : #EEF4FF → #D0DFFA
        Button press  : #D8D8D8 → #E4E4E4
        Bevel outer   : #B8B8B8
        Bevel hi      : #FFFFFF / shadow #A0A0A0
        Header        : soft sky-blue gradient
        Edit border   : #99AABB / inner #FFFFFF
        Text primary  : #1A1A1A
        Text muted    : #555555
        Text subtle   : #888888
        Accent blue   : #2B6CC4
        Green total   : #1A7A1A
        Amber disc    : #A0520A
        Red error     : #B00000
    ═══════════════════════════════════════════════════════════
    -->

    <Window.Resources>

        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header — very soft sky blue -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Panel surface -->
        <LinearGradientBrush x:Key="PanelBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FAFAFA" Offset="0"/>
            <GradientStop Color="#F0F0F0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush — top-left highlight / bottom-right shadow -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- ListView rows -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                    <Setter Property="Foreground" Value="#1A3A8A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                    <Setter Property="Foreground" Value="#0A2060"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
        </Style>

        <!-- ── Raised 3-D bevel button ── -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Content="📋  Return History"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#2B6CC4"
                       VerticalContentAlignment="Center"
                       FontFamily="Segoe UI, Tahoma"/>
                <Label Grid.Column="1" x:Name="lblCount"
                       Content="0 records"
                       Foreground="#555555" FontSize="12"
                       VerticalContentAlignment="Center"
                       Margin="0,0,16,0"
                       FontFamily="Segoe UI, Tahoma"/>
                <Border Grid.Column="2"
                        BorderBrush="#B8B8B8" BorderThickness="1"
                        CornerRadius="3" Padding="12,6">
                    <Border BorderBrush="{StaticResource BevelNormal}" BorderThickness="1" CornerRadius="2">
                        <Border CornerRadius="1" Background="#EEF4FF">
                            <Label x:Name="lblTotal"
                                   Content="Total Refunded: LBP 0"
                                   Foreground="#2B6CC4" FontSize="12"
                                   FontWeight="Bold"
                                   VerticalContentAlignment="Center"
                                   Padding="4,0"
                                   FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                    </Border>
                </Border>
            </Grid>
        </Border>

        <!-- ══ FILTER BAR ══ -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}"
                BorderBrush="#D0D0D0" BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Label Content="🔍 Filter:" Foreground="#555555"
                       FontSize="12" VerticalContentAlignment="Center"
                       Padding="0,0,8,0"
                       FontFamily="Segoe UI, Tahoma"/>
                <Border BorderBrush="#99AABB" BorderThickness="1" Width="200">
                    <Border BorderBrush="#FFFFFF" BorderThickness="1">
                        <TextBox x:Name="txtFilter"
                                 Background="#FFFFFF" Foreground="#1A1A1A"
                                 BorderThickness="0" FontSize="12"
                                 Padding="8,5" CaretBrush="#2B6CC4"
                                 ToolTip="Filter by invoice, cashier or type"
                                 TextChanged="txtFilter_TextChanged"
                                 FontFamily="Segoe UI, Tahoma"/>
                    </Border>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══ LIST ══ -->
        <Border Grid.Row="2" Background="#FFFFFF"
                Margin="16,12" BorderBrush="#C0C0C0" BorderThickness="1">
            <ListView x:Name="lvHistory"
                      Background="#FFFFFF"
                      BorderThickness="0"
                      Foreground="#1A1A1A"
                      FontFamily="Segoe UI, Tahoma">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="#"       Width="44"  DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="Invoice" Width="70"  DisplayMemberBinding="{Binding OriginalSaleId}"/>
                        <GridViewColumn Header="Date"    Width="140" DisplayMemberBinding="{Binding ReturnDate}"/>
                        <GridViewColumn Header="Cashier" Width="110" DisplayMemberBinding="{Binding CashierName}"/>
                        <GridViewColumn Header="Type"    Width="90"  DisplayMemberBinding="{Binding ReturnType}"/>
                        <GridViewColumn Header="Reason"  Width="160" DisplayMemberBinding="{Binding Reason}"/>
                        <GridViewColumn Header="Refund"  Width="130" DisplayMemberBinding="{Binding RefundDisplay}"/>
                        <GridViewColumn Header="Items"   Width="130"   DisplayMemberBinding="{Binding Items}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- ══ FOOTER ══ -->
        <Border Grid.Row="3" Background="{StaticResource PanelBrush}"
                BorderBrush="#D0D0D0" BorderThickness="0,1,0,0"
                Padding="16,12">
            <Button Content="✕  Close"
                    Width="120" Height="34"
                    HorizontalAlignment="Right"
                    Style="{StaticResource BigBtn}"
                    Click="btnClose_Click"/>
        </Border>
    </Grid>
</Window>