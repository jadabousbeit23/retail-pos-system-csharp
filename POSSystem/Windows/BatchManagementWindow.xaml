<Window x:Class="POSSystem.Windows.BatchManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Management"
        Height="640" Width="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <Window.Resources>
        <!-- Button face gradients -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Bevel brush -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EBEBEB"/>
            <Setter Property="Padding" Value="4,6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8DBFA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 3D Bevel Button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="#B8CCEE" BorderThickness="0,0,0,1"
                Padding="15,12" Margin="20,20,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Label Content="📦  Batch Management"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#2B6CC4" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblProductName"
                           Content="Product: —"
                           FontSize="12" Foreground="#555555"
                           Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <Label Content="TOTAL STOCK"
                           FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Label x:Name="lblTotalStock"
                           Content="0 units"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#2E7D32" Padding="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ADD BATCH FORM -->
        <Border Grid.Row="1" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1"
                Padding="14,10" Margin="20,0,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Batch Number -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <Label Content="BATCH NUMBER"
                           FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0"
                           Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtBatchNumber"
                                     Background="#FFFFFF"
                                     Foreground="#1A1A1A"
                                     BorderThickness="0"
                                     FontSize="13" Padding="8,6"
                                     CaretBrush="#2B6CC4"
                                     ToolTip="e.g. LOT-2025-001"
                                     FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                    </Border>
                </StackPanel>

                <!-- Expiry Date with format hint -->
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <DockPanel Margin="0,0,0,4">
                        <Label Content="EXPIRY DATE"
                               FontSize="10" Foreground="#555555"
                               FontWeight="Bold" Padding="0"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI, Tahoma"/>
                        <Label Content="dd/MM/yyyy"
                               FontSize="9" Foreground="#888888"
                               Padding="4,0,0,0"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI, Tahoma"/>
                    </DockPanel>
                    <Border BorderBrush="#B71C1C" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtExpiryDate"
                                     Background="#FFFFFF"
                                     Foreground="#B71C1C"
                                     BorderThickness="0"
                                     FontSize="13" Padding="8,6"
                                     CaretBrush="#B71C1C"
                                     ToolTip="Enter as dd/MM/yyyy or dd-MM-yyyy (leave blank if no expiry)"
                                     FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                    </Border>
                </StackPanel>

                <!-- Quantity -->
                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <Label Content="QUANTITY"
                           FontSize="10" Foreground="#555555"
                           FontWeight="Bold" Padding="0"
                           Margin="0,0,0,4"
                           FontFamily="Segoe UI, Tahoma"/>
                    <Border BorderBrush="#99AABB" BorderThickness="1">
                        <Border BorderBrush="#FFFFFF" BorderThickness="1">
                            <TextBox x:Name="txtBatchQty"
                                     Background="#FFFFFF"
                                     Foreground="#2E7D32"
                                     BorderThickness="0"
                                     FontSize="13" Padding="8,6"
                                     CaretBrush="#2E7D32"
                                     FontFamily="Segoe UI, Tahoma"/>
                        </Border>
                    </Border>
                </StackPanel>

                <!-- Add Button -->
                <Button Grid.Column="3"
                        Content="➕ Add Batch"
                        Height="36" Width="110"
                        Style="{StaticResource BigBtn}"
                        VerticalAlignment="Bottom"
                        Click="btnAddBatch_Click"/>
            </Grid>
        </Border>

        <!-- ALERT BANNER (shown when expiry issues) -->
        <Border Grid.Row="2"
                x:Name="borderAlertBanner"
                Background="#FFF3E0"
                BorderBrush="#E65100" BorderThickness="1"
                Padding="12,8" Margin="20,0,20,12"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Label Content="🚨" FontSize="14" Padding="0,0,6,0" VerticalAlignment="Center"/>
                <Label x:Name="lblAlertBanner"
                       Content=""
                       FontSize="11" FontWeight="Bold"
                       Foreground="#E65100"
                       Padding="0" VerticalAlignment="Center"
                       FontFamily="Segoe UI, Tahoma"/>
            </StackPanel>
        </Border>

        <!-- BATCH LIST -->
        <Border Grid.Row="3" Background="#FFFFFF"
                BorderBrush="#C0C0C0" BorderThickness="1"
                Padding="5" Margin="20,0,20,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Column headers -->
                <Border Grid.Row="0" Background="#F5F5F5"
                        BorderBrush="#D0D0D0" BorderThickness="0,0,0,1"
                        Padding="8,6" Margin="0,0,0,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="155"/>
                            <ColumnDefinition Width="115"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="115"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="65"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="ID" Foreground="#555555" FontSize="10" FontWeight="Bold" Padding="2,0" FontFamily="Segoe UI, Tahoma"/>
                        <Label Grid.Column="1" Content="BATCH #" Foreground="#555555" FontSize="10" FontWeight="Bold" Padding="2,0" FontFamily="Segoe UI, Tahoma"/>
                        <Label Grid.Column="2" Content="EXPIRY" Foreground="#555555" FontSize="10" FontWeight="Bold" Padding="2,0" FontFamily="Segoe UI, Tahoma"/>
                        <Label Grid.Column="3" Content="QTY" Foreground="#555555" FontSize="10" FontWeight="Bold" Padding="2,0" FontFamily="Segoe UI, Tahoma"/>
                        <Label Grid.Column="4" Content="RECEIVED" Foreground="#555555" FontSize="10" FontWeight="Bold" Padding="2,0" FontFamily="Segoe UI, Tahoma"/>
                        <Label Grid.Column="5" Content="STATUS ▲ (soonest expiry first)"
                               Foreground="#2B6CC4" FontSize="10" FontWeight="Bold" Padding="2,0" FontFamily="Segoe UI, Tahoma"/>
                        <Label Grid.Column="6" Content="" Padding="2,0"/>
                    </Grid>
                </Border>

                <ListView Grid.Row="1" x:Name="lvBatches"
                          Background="Transparent"
                          BorderThickness="0"
                          FontFamily="Segoe UI, Tahoma">
                    <ListView.View>
                        <GridView>
                            <GridView.ColumnHeaderContainerStyle>
                                <Style TargetType="GridViewColumnHeader">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </GridView.ColumnHeaderContainerStyle>
                            <GridViewColumn Width="45" DisplayMemberBinding="{Binding Id}"/>
                            <GridViewColumn Width="155" DisplayMemberBinding="{Binding BatchNumber}"/>
                            <GridViewColumn Width="115" DisplayMemberBinding="{Binding ExpiryDate}"/>
                            <GridViewColumn Width="80" DisplayMemberBinding="{Binding Quantity}"/>
                            <GridViewColumn Width="115" DisplayMemberBinding="{Binding ReceivedDate}"/>
                            <GridViewColumn Width="130">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusColor}"
                                                CornerRadius="4" Padding="6,3">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="White"
                                                       FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑️"
                                                Width="36" Height="26"
                                                Style="{StaticResource BigBtn}"
                                                FontSize="10"
                                                Tag="{Binding Id}"
                                                ToolTip="Delete this batch"
                                                Click="btnDeleteBatch_Click"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- Message -->
        <Label Grid.Row="4" x:Name="lblMessage"
               Content="" FontSize="12" FontWeight="Bold"
               Padding="4,0" Margin="20,0,20,4" MinHeight="18"
               Foreground="#B71C1C"
               FontFamily="Segoe UI, Tahoma"/>

        <!-- Close -->
        <Button Grid.Row="5"
                Content="✕  Close"
                Height="40" Width="100" Margin="20,0,20,16"
                Style="{StaticResource BigBtn}"
                HorizontalAlignment="Right"
                Click="btnClose_Click"/>
    </Grid>
</Window>