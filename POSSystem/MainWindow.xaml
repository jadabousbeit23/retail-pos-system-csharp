                </ScrollViewer>
            </Border>

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- ══ HD DASHBOARD SECTION ONLY - ENHANCED BELOW ══ -->
            <!-- ════════════════════════════════════════════════════════ -->

            <!-- ══ LOW STOCK ALERT BAR HD ══ -->
            <Border Grid.Row="3" x:Name="borderLowStock"
                    Background="#FFF3E0"
                    BorderBrush="#EF6C00" BorderThickness="0,2,0,2"
                    Padding="18,10" Margin="12,8,12,6"
                    Visibility="Collapsed" UseLayoutRounding="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0"
                           Content="⚠️  LOW STOCK ALERT:"
                           FontFamily="Segoe UI, Tahoma"
                           FontSize="13" FontWeight="Bold"
                           Foreground="#BF360C" Padding="0,0,14,0"
                           VerticalContentAlignment="Center"/>

                    <ItemsControl Grid.Column="1" x:Name="icLowStock">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EF6C00" BorderThickness="1"
                                        CornerRadius="4" Padding="10,6" Margin="6,3" UseLayoutRounding="True">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFE0B2" Offset="0"/>
                                            <GradientStop Color="#FFCC80" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock FontFamily="Segoe UI, Tahoma"
                                               Foreground="#BF360C" FontSize="13"
                                               FontWeight="SemiBold">
                                        <Run Text="{Binding Name}"/>
                                        <Run Text=" ("/><Run Text="{Binding Stock}" FontWeight="Bold"/>
                                        <Run Text=" left)"/>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Grid.Column="2" Content="View Products →"
                            Height="32" Padding="14,0"
                            Style="{StaticResource BigBtn}"
                            FontSize="12" FontWeight="SemiBold"
                            Click="btnProducts_Click"/>
                </Grid>
            </Border>

            <!-- ══ STATISTICS CARDS HD ══ -->
            <Grid Grid.Row="4" Margin="12,8,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Today's Sales HD -->
                <Border Grid.Column="0"
                        Background="{StaticResource StatCardBrush}"
                        BorderBrush="#4CAF50" BorderThickness="2"
                        CornerRadius="6" Padding="20,16" Margin="0,0,8,0" UseLayoutRounding="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="3" Opacity="0.15" Color="#000000"/>
                    </Border.Effect>
                    <StackPanel>
                        <Label Content="TODAY'S SALES"
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#4CAF50" Padding="0"/>
                        <Label x:Name="lblTodaySales" Content="0"
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="40" FontWeight="Bold"
                               Foreground="#1B5E20" Padding="0"/>
                        <Label x:Name="lblTodaySalesChange" Content=""
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#555555" Padding="0"/>
                    </StackPanel>
                </Border>

                <!-- Today's Revenue HD -->
                <Border Grid.Column="1"
                        Background="{StaticResource StatCardBrush}"
                        BorderBrush="#2B6CC4" BorderThickness="2"
                        CornerRadius="6" Padding="20,16" Margin="4,0,4,0" UseLayoutRounding="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="3" Opacity="0.15" Color="#000000"/>
                    </Border.Effect>
                    <StackPanel>
                        <Label Content="TODAY'S REVENUE"
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#2B6CC4" Padding="0"/>
                        <Label x:Name="lblTodayRevenue" Content="LBP 0"
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#0D47A1" Padding="0"/>
                        <Label x:Name="lblRevenueChange" Content=""
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#555555" Padding="0"/>
                    </StackPanel>
                </Border>

                <!-- Total Products HD -->
                <Border Grid.Column="2"
                        Background="{StaticResource StatCardBrush}"
                        BorderBrush="#FF9800" BorderThickness="2"
                        CornerRadius="6" Padding="20,16" Margin="4,0,4,0" UseLayoutRounding="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="3" Opacity="0.15" Color="#000000"/>
                    </Border.Effect>
                    <StackPanel>
                        <Label Content="TOTAL PRODUCTS"
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#FF9800" Padding="0"/>
                        <Label x:Name="lblTotalProducts" Content="0"
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="40" FontWeight="Bold"
                               Foreground="#E65100" Padding="0"/>
                        <Label x:Name="lblLowStockCount" Content=""
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#B71C1C" Padding="0"/>
                    </StackPanel>
                </Border>

                <!-- Monthly Revenue HD -->
                <Border Grid.Column="3"
                        Background="{StaticResource StatCardBrush}"
                        BorderBrush="#9C27B0" BorderThickness="2"
                        CornerRadius="6" Padding="20,16" Margin="8,0,0,0" UseLayoutRounding="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="3" Opacity="0.15" Color="#000000"/>
                    </Border.Effect>
                    <StackPanel>
                        <Label Content="MONTHLY REVENUE"
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#9C27B0" Padding="0"/>
                        <Label x:Name="lblMonthRevenue" Content="LBP 0"
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#4A148C" Padding="0"/>
                        <Label x:Name="lblMonthSales" Content=""
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#555555" Padding="0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ CHARTS & PANELS HD ══ -->
            <Grid Grid.Row="5" Margin="12,0,12,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sales Chart HD -->
                <Border Grid.Column="0"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="#2B6CC4" BorderThickness="2"
                        CornerRadius="6" Padding="20" Margin="0,0,10,0" UseLayoutRounding="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="3" Opacity="0.15" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,14">
                            <Label Content="📊 Sales — Last 7 Days"
                                   FontFamily="Segoe UI, Tahoma"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#0D47A1" Padding="0"/>
                            <Label Content="Daily revenue trend"
                                   FontFamily="Segoe UI, Tahoma"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555555" Padding="0"/>
                        </StackPanel>

                        <Border Grid.Row="1" 
                                Background="#FFFFFF"
                                BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="4" UseLayoutRounding="True">
                            <Canvas x:Name="canvasChart"
                                    Background="Transparent" ClipToBounds="True"
                                    SizeChanged="canvasChart_SizeChanged" UseLayoutRounding="True"/>
                        </Border>

                        <ItemsControl Grid.Row="2" x:Name="icDayLabels" Margin="0,10,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="Segoe UI, Tahoma"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#555555"
                                               TextAlignment="Center"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Side Panels HD -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top Products HD -->
                    <Border Grid.Row="0"
                            Background="{StaticResource CardBrush}"
                            BorderBrush="#4CAF50" BorderThickness="2"
                            CornerRadius="6" Padding="20" Margin="0,0,0,8" UseLayoutRounding="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="3" Opacity="0.15" Color="#000000"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="🏆 Top Products Today"
                                   FontFamily="Segoe UI, Tahoma"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#1B5E20" Padding="0"
                                   Margin="0,0,0,12"/>

                            <ItemsControl Grid.Row="1" x:Name="icTopProducts">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Rank Badge HD -->
                                            <Border Grid.Column="0"
                                                    BorderBrush="#4CAF50" BorderThickness="2"
                                                    CornerRadius="4" Width="28" Height="28" UseLayoutRounding="True">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#66BB6A" Offset="0"/>
                                                        <GradientStop Color="#4CAF50" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Label Content="{Binding Rank}"
                                                       FontFamily="Segoe UI, Tahoma"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalContentAlignment="Center"
                                                       VerticalContentAlignment="Center"
                                                       Padding="0"/>
                                            </Border>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontFamily="Segoe UI, Tahoma"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#1A1A1A"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding QtyText}"
                                                       FontFamily="Segoe UI, Tahoma"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="#4CAF50"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- Low Stock Panel HD -->
                    <Border Grid.Row="1"
                            Background="{StaticResource CardBrush}"
                            BorderBrush="#B71C1C" BorderThickness="2"
                            CornerRadius="6" Padding="20" UseLayoutRounding="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="3" Opacity="0.15" Color="#000000"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="⚠️ Low Stock Items"
                                   FontFamily="Segoe UI, Tahoma"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#B71C1C" Padding="0"
                                   Margin="0,0,0,12"/>

                            <ItemsControl Grid.Row="1" x:Name="icLowStockPanel">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       FontFamily="Segoe UI, Tahoma"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#1A1A1A"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <Border Grid.Column="1"
                                                    BorderBrush="#B71C1C" BorderThickness="2"
                                                    CornerRadius="4"
                                                    Padding="10,4" Margin="8,0,0,0" UseLayoutRounding="True">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#FFCDD2" Offset="0"/>
                                                        <GradientStop Color="#EF9A9A" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="{Binding StockText}"
                                                           FontFamily="Segoe UI, Tahoma"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="#B71C1C"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

        </Grid>
    </Grid>
</Window>