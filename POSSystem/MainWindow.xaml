<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" x:Class="POSSystem.MainWindow"
        Title="POS System"
        WindowState="Maximized"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent">

    <!--
    ═══════════════════════════════════════════════════════════
      ENHANCED POS THEME — Fullscreen HD Layout
      Background: Pearl white → Ice blue → Steel blue (diagonal)
      Font: Segoe UI Semibold for better readability
      Colors by purpose: Sales=Green, Inventory=Blue, 
      Reports=Purple, Admin=Orange, Danger=Red
    ═══════════════════════════════════════════════════════════
    -->

    <Window.Resources>

        <!-- ══ BACKGROUND GRADIENTS (From LoginWindow) ══ -->

        <!-- Main background: pearl white → ice blue → steel blue, top-left to bottom-right -->
        <LinearGradientBrush x:Key="MainBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0.00"/>
            <GradientStop Color="#EEF5FF" Offset="0.30"/>
            <GradientStop Color="#DAEAFF" Offset="0.60"/>
            <GradientStop Color="#C2D8F5" Offset="1.00"/>
        </LinearGradientBrush>

        <!-- Diagonal hatching overlay — same blue family, very subtle -->
        <DrawingBrush x:Key="HatchingPattern" TileMode="Tile"
                      Viewport="0,0,32,32" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Thickness="0.8">
                            <Pen.Brush>
                                <SolidColorBrush Color="#4477BB" Opacity="0.06"/>
                            </Pen.Brush>
                        </Pen>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <LineGeometry StartPoint="-4,36" EndPoint="36,-4"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Button Faces -->
        <LinearGradientBrush x:Key="BtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFDFD" Offset="0"/>
            <GradientStop Color="#F2F2F2" Offset="0.5"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EEF4FF" Offset="0"/>
            <GradientStop Color="#DBE9FF" Offset="0.5"/>
            <GradientStop Color="#C8DBFA" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BtnPress" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D4D4D4" Offset="0"/>
            <GradientStop Color="#E0E0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header Gradient -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F2FF" Offset="0"/>
            <GradientStop Color="#C8DCFA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Navigation Bar -->
        <LinearGradientBrush x:Key="NavBarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F4F4F4" Offset="0"/>
            <GradientStop Color="#E8E8E8" Offset="1"/>
        </LinearGradientBrush>

        <!-- Card Background -->
        <LinearGradientBrush x:Key="CardBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FAFAFA" Offset="0"/>
            <GradientStop Color="#F0F0F0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Stat Card -->
        <LinearGradientBrush x:Key="StatCardBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#F4F4F4" Offset="1"/>
        </LinearGradientBrush>

        <!-- 3D Bevel Effect -->
        <LinearGradientBrush x:Key="BevelNormal" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFFFFF" Offset="0.49"/>
            <GradientStop Color="#A0A0A0" Offset="0.50"/>
            <GradientStop Color="#A0A0A0" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BevelPress" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A0A0A0" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.49"/>
            <GradientStop Color="#FFFFFF" Offset="0.50"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- COLOR-CODED BUTTON BRUSHES -->

        <!-- SALES - Green -->
        <LinearGradientBrush x:Key="SalesBtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8F5E9" Offset="0"/>
            <GradientStop Color="#C8E6C9" Offset="0.5"/>
            <GradientStop Color="#A5D6A7" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SalesBtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#C8E6C9" Offset="0"/>
            <GradientStop Color="#A5D6A7" Offset="0.5"/>
            <GradientStop Color="#81C784" Offset="1"/>
        </LinearGradientBrush>

        <!-- INVENTORY - Blue -->
        <LinearGradientBrush x:Key="InvBtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E3F2FD" Offset="0"/>
            <GradientStop Color="#BBDEFB" Offset="0.5"/>
            <GradientStop Color="#90CAF9" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="InvBtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#BBDEFB" Offset="0"/>
            <GradientStop Color="#90CAF9" Offset="0.5"/>
            <GradientStop Color="#64B5F6" Offset="1"/>
        </LinearGradientBrush>

        <!-- REPORTS - Purple -->
        <LinearGradientBrush x:Key="ReportBtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F3E5F5" Offset="0"/>
            <GradientStop Color="#E1BEE7" Offset="0.5"/>
            <GradientStop Color="#CE93D8" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ReportBtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E1BEE7" Offset="0"/>
            <GradientStop Color="#CE93D8" Offset="0.5"/>
            <GradientStop Color="#BA68C8" Offset="1"/>
        </LinearGradientBrush>

        <!-- ADMIN - Orange/Amber -->
        <LinearGradientBrush x:Key="AdminBtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFF8E1" Offset="0"/>
            <GradientStop Color="#FFECB3" Offset="0.5"/>
            <GradientStop Color="#FFE082" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AdminBtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFECB3" Offset="0"/>
            <GradientStop Color="#FFE082" Offset="0.5"/>
            <GradientStop Color="#FFD54F" Offset="1"/>
        </LinearGradientBrush>

        <!-- TOOLS - Gray-Blue -->
        <LinearGradientBrush x:Key="ToolBtnFace" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#ECEFF1" Offset="0"/>
            <GradientStop Color="#CFD8DC" Offset="0.5"/>
            <GradientStop Color="#B0BEC5" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ToolBtnHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#CFD8DC" Offset="0"/>
            <GradientStop Color="#B0BEC5" Offset="0.5"/>
            <GradientStop Color="#90A4AE" Offset="1"/>
        </LinearGradientBrush>

        <!-- Base Navigation Button Style -->
        <Style x:Key="NavBtnBase" TargetType="Button">
            <Setter Property="Width" Value="148"/>
            <Setter Property="Height" Value="76"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SALES Buttons - Green -->
        <Style x:Key="NavBtnSales" TargetType="Button" BasedOn="{StaticResource NavBtnBase}">
            <Setter Property="Foreground" Value="#1B5E20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#4CAF50" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource SalesBtnFace}"
                                        CornerRadius="1"
                                        Padding="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource SalesBtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#2E7D32"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- INVENTORY Buttons - Blue -->
        <Style x:Key="NavBtnInv" TargetType="Button" BasedOn="{StaticResource NavBtnBase}">
            <Setter Property="Foreground" Value="#0D47A1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#2196F3" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource InvBtnFace}"
                                        CornerRadius="1"
                                        Padding="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource InvBtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- REPORTS Buttons - Purple -->
        <Style x:Key="NavBtnReport" TargetType="Button" BasedOn="{StaticResource NavBtnBase}">
            <Setter Property="Foreground" Value="#4A148C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#9C27B0" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource ReportBtnFace}"
                                        CornerRadius="1"
                                        Padding="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource ReportBtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#6A1B9A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ADMIN Buttons - Orange -->
        <Style x:Key="NavBtnAdmin" TargetType="Button" BasedOn="{StaticResource NavBtnBase}">
            <Setter Property="Foreground" Value="#E65100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#FF9800" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource AdminBtnFace}"
                                        CornerRadius="1"
                                        Padding="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource AdminBtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#EF6C00"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TOOLS Buttons - Gray -->
        <Style x:Key="NavBtnTool" TargetType="Button" BasedOn="{StaticResource NavBtnBase}">
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#607D8B" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource ToolBtnFace}"
                                        CornerRadius="1"
                                        Padding="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource ToolBtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#455A64"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button (Logout) - Red -->
        <Style x:Key="NavBtnDanger" TargetType="Button" BasedOn="{StaticResource NavBtnBase}">
            <Setter Property="Foreground" Value="#B71C1C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#E57373" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        CornerRadius="1"
                                        Padding="4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFEBEE" Offset="0"/>
                                            <GradientStop Color="#FFCDD2" Offset="0.5"/>
                                            <GradientStop Color="#EF9A9A" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFCDD2" Offset="0"/>
                                            <GradientStop Color="#EF9A9A" Offset="0.5"/>
                                            <GradientStop Color="#E57373" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#C62828"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Standard 3D Button -->
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OuterBorder"
                                BorderBrush="#B8B8B8" BorderThickness="1"
                                CornerRadius="3">
                            <Border x:Name="InnerBorder"
                                    BorderBrush="{StaticResource BevelNormal}"
                                    BorderThickness="1" CornerRadius="2">
                                <Border x:Name="FaceBorder"
                                        Background="{StaticResource BtnFace}"
                                        CornerRadius="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnHover}"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#4488CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FaceBorder" Property="Background" Value="{StaticResource BtnPress}"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BevelPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FaceBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ══ MAIN ROOT GRID WITH LOGINWINDOW BACKGROUND ══ -->
    <Grid>
        <!-- Background layers matching LoginWindow -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.00"/>
                <GradientStop Color="#EEF5FF" Offset="0.30"/>
                <GradientStop Color="#DAEAFF" Offset="0.60"/>
                <GradientStop Color="#C2D8F5" Offset="1.00"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Diagonal hatching overlay -->
        <Rectangle Fill="{StaticResource HatchingPattern}" IsHitTestVisible="False"/>

        <!-- Main Content -->
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══ HEADER (UNCHANGED) ══ -->
            <Border Grid.Row="0"
                    Background="{StaticResource HeaderBrush}"
                    BorderBrush="#B8CCEE" BorderThickness="0,0,0,1">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo Box -->
                    <Border Grid.Column="0"
                            BorderBrush="#2B6CC4" BorderThickness="2"
                            CornerRadius="3" Margin="0,8,12,8">
                        <Border CornerRadius="2" Padding="16,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#4A90D9" Offset="0"/>
                                    <GradientStop Color="#2B6CC4" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Label Content="🛒" FontSize="18" Padding="0,0,8,0"
                                       VerticalContentAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <Label Content="POS System"
                                           FontFamily="Segoe UI, Tahoma"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="White" Padding="0"/>
                                    <Label x:Name="lblWelcome" Content=""
                                           FontFamily="Segoe UI, Tahoma"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#E3F2FD" Padding="0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Border>

                    <Label Grid.Column="1"/>

                    <!-- DB Status -->
                    <Border Grid.Column="2"
                            x:Name="bdDbStatus"
                            BorderBrush="#B8B8B8" BorderThickness="1"
                            CornerRadius="3" Padding="12,4"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#F8F8F8" Offset="0"/>
                                <GradientStop Color="#E8E8E8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Label x:Name="lblDbStatus"
                               Content="🟡 Local DB"
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#555555" Padding="0"/>
                    </Border>

                    <!-- Date/Time -->
                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                        <Label x:Name="lblDateTime" Content=""
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#2B6CC4"
                               HorizontalContentAlignment="Right"
                               Padding="0"/>
                        <Label x:Name="lblLowStockBadge" Content=""
                               FontFamily="Segoe UI, Tahoma"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#B71C1C"
                               HorizontalContentAlignment="Right"
                               Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- ══ UPDATE BANNER — hidden until update found ══ -->
            <!-- ════════════════════════════════════════════════════════ -->
            <Border x:Name="updateBanner" Grid.Row="1"
        Background="#FFF8DC" BorderBrush="#E0C040"
        BorderThickness="0,0,0,1" Visibility="Collapsed" Padding="16,8"
        Cursor="Hand">
                <Grid>
                    <TextBlock x:Name="lblUpdateBanner" FontSize="12"
                   Foreground="#7A5A00" VerticalAlignment="Center"
                   MouseLeftButtonDown="DownloadUpdate_Click"/>
                    <Button Content="✕" HorizontalAlignment="Right" Width="50" Height="40"
                Background="Transparent" BorderThickness="0"
                Click="DismissUpdate_Click" Foreground="#7A5A00"/>
                </Grid>
            </Border>

            <!-- ══ NAVIGATION BUTTONS (UNCHANGED) ══ -->
            <Border Grid.Row="2"
                    Background="{StaticResource NavBarBrush}"
                    BorderBrush="#C8C8C8" BorderThickness="0,0,0,1">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Disabled">
                    <WrapPanel HorizontalAlignment="Left" Margin="10,8,10,8">

                        <!-- SALES - Green -->
                        <Button x:Name="btnFastSale"
                                Style="{StaticResource NavBtnSales}"
                                Click="btnFastSale_Click">
                            <StackPanel HorizontalAlignment="Center">
